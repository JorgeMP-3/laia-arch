#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# laia-release — promote a dev tree to /opt/laia-vX.Y.Z and restart services
#
# Typical workflow:
#   cd ~/.laia
#   git status                       # working tree clean
#   git tag v0.4.0
#   sudo -E laia-release             # detects tag, builds, switches, restarts
#
# Internally this is essentially `laia-install --from-local "$LAIA_ROOT"` with
# version auto-detection and a post-build atomic symlink switch + service
# restart. On healthcheck failure it automatically rolls back.
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
LAIA_ROOT="$(dirname "$SCRIPT_DIR")"
LIB_DIR="$LAIA_ROOT/infra/installer/lib"

# shellcheck source=../infra/installer/lib/common.sh
source "$LIB_DIR/common.sh"
# shellcheck source=../infra/installer/lib/sudo.sh
source "$LIB_DIR/sudo.sh"
# shellcheck source=../infra/installer/lib/system.sh
source "$LIB_DIR/system.sh"
# shellcheck source=../infra/installer/lib/version.sh
source "$LIB_DIR/version.sh"
# shellcheck source=../infra/installer/lib/install.sh
source "$LIB_DIR/install.sh"
# shellcheck source=../infra/installer/lib/systemd.sh
source "$LIB_DIR/systemd.sh"
# shellcheck source=../infra/installer/lib/release.sh
source "$LIB_DIR/release.sh"

# ─── Options ────────────────────────────────────────────────────────────────
OPT_SRC=""
OPT_VERSION=""
OPT_SKIP_TESTS=false
OPT_ALLOW_DIRTY=false
OPT_PRUNE=false
OPT_KEEP=3
OPT_YES=false
OPT_DRY_RUN=false
OPT_FORCE=false
OPT_NO_SYSTEMD=false
OPT_SKIP_PIP=false
OPT_SKIP_FRONTEND=false
# Install pipeline reads these names; release uses OPT_SRC.
OPT_FROM_LOCAL=""

print_help() {
  cat <<'EOF'
laia-release — promote a dev tree to /opt/laia-vX.Y.Z and restart services

USAGE
    sudo -E laia-release [OPTIONS] [SRC_TREE]
    sudo -E laia release [OPTIONS] [SRC_TREE]

ARGUMENTS
    SRC_TREE              Dev tree to release (default: ~/.laia)

OPTIONS
    --version VER         Force release version (default: git describe HEAD tag)
    --skip-tests          Skip pre-release smoke tests
    --skip-pip            Skip venv creation / pip install (build phase)
    --skip-frontend       Skip frontend artifact check
    --no-systemd          Don't re-render or install systemd units
    --allow-dirty         Release even if the working tree has uncommitted changes
    --force               Allow re-building over an existing /opt/laia-vX.Y.Z dir
    --prune               Delete versions older than --keep N
    --keep N              When --prune, keep last N versions besides current (default: 3)
    --yes, -y             Non-interactive
    --dry-run             Show what would happen, don't change anything
    --help, -h            Show this help

WORKFLOW
    1. Validate SRC_TREE is a git repo, working tree clean (unless --allow-dirty)
    2. Run tests (unless --skip-tests)
    3. Build to /opt/laia-vX.Y.Z/ (cp + venv + pnpm build + permissions)
    4. Switch /opt/laia symlink atomically
    5. Restart systemd services
    6. Healthcheck: rollback on failure
    7. Optional: prune older versions

EXAMPLES
    sudo -E laia-release                     # detect version from git tag
    sudo -E laia-release --version v0.2.0    # explicit version
    sudo -E laia-release --skip-tests --prune
EOF
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)        print_help; exit 0 ;;
      --version)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--version requires VER" 2
        OPT_VERSION="$2"; shift 2 ;;
      --skip-tests)     OPT_SKIP_TESTS=true; shift ;;
      --skip-pip)       OPT_SKIP_PIP=true; shift ;;
      --skip-frontend)  OPT_SKIP_FRONTEND=true; shift ;;
      --no-systemd)     OPT_NO_SYSTEMD=true; shift ;;
      --allow-dirty)    OPT_ALLOW_DIRTY=true; shift ;;
      --force)          OPT_FORCE=true; shift ;;
      --prune)          OPT_PRUNE=true; shift ;;
      --keep)
        [[ $# -ge 2 && "${2:-}" =~ ^[0-9]+$ ]] || die "--keep requires a positive integer" 2
        OPT_KEEP="$2"; shift 2 ;;
      -y|--yes)         OPT_YES=true; export LAIA_NONINTERACTIVE=true; shift ;;
      --dry-run)        OPT_DRY_RUN=true; shift ;;
      -*) die "Unknown option: $1 (use --help)" 2 ;;
      *)
        if [[ -z "$OPT_SRC" ]]; then
          OPT_SRC="$(readlink -f "$1")"; shift
        else
          die "Multiple source trees given: $OPT_SRC vs $1" 2
        fi
        ;;
    esac
  done

  # Default source: the user's hidden dev tree.
  [[ -n "$OPT_SRC" ]] || OPT_SRC="$LAIA_USER_HOME/.laia"
}

# ─── Main ───────────────────────────────────────────────────────────────────
main() {
  parse_args "$@"

  log_step "laia-release"
  log_info "Source tree:     $OPT_SRC"
  log_info "Version:         ${OPT_VERSION:-<auto-detect from git>}"
  log_info "Skip tests:      $OPT_SKIP_TESTS"
  log_info "Skip pip:        $OPT_SKIP_PIP"
  log_info "Skip frontend:   $OPT_SKIP_FRONTEND"
  log_info "No systemd:      $OPT_NO_SYSTEMD"
  log_info "Allow dirty:     $OPT_ALLOW_DIRTY"
  log_info "Force overwrite: $OPT_FORCE"
  log_info "Prune:           $OPT_PRUNE (keep last $OPT_KEEP)"
  log_info "Dry-run:         $OPT_DRY_RUN"
  log_info "Admin user:      $LAIA_USER ($LAIA_USER_HOME)"

  rel_preflight_src_tree
  rel_run_tests

  # Bridge release args to the install pipeline.
  OPT_FROM_LOCAL="$OPT_SRC"

  inst_preflight
  inst_resolve_source
  inst_resolve_version
  inst_resolve_paths

  # Snapshot before any mutation so we know what to roll back to.
  REL_PREV_VERSION="$(inst_current_version)"
  rel_capture_active_units

  if [[ -n "$REL_PREV_VERSION" ]]; then
    log_info "Currently active version: $REL_PREV_VERSION"
  else
    log_info "No previous version installed (this will be the first)"
  fi

  if [[ "$OPT_DRY_RUN" == true ]]; then
    log_warn "Dry-run mode — stopping before any mutations."
    exit 0
  fi

  inst_check_existing_version

  if ! inst_is_override_mode; then
    ensure_sudo_cached
  fi

  inst_copy_source_to_dest
  inst_create_venvs
  inst_check_frontend
  inst_finalize_permissions
  inst_switch_symlink
  inst_install_wrappers
  systemd_install_all

  rel_record_previous "$REL_PREV_VERSION"
  rel_restart_active

  if ! rel_healthcheck; then
    log_error "Healthcheck failed — initiating auto-rollback"
    if [[ -n "$REL_PREV_VERSION" ]]; then
      rel_rollback_symlink "$REL_PREV_VERSION"
      rel_restart_active
      die "Release rolled back to $REL_PREV_VERSION. Investigate $INST_DEST."
    else
      die "Healthcheck failed and no previous version to roll back to. $INST_DEST left active."
    fi
  fi

  if [[ "$OPT_PRUNE" == true ]]; then
    rel_prune
  fi

  rel_print_summary
}

main "$@"
