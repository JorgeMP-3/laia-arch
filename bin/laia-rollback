#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# laia-rollback — switch the /opt/laia symlink back to a previous version
#
# After a release goes wrong, recovery is one command:
#   sudo laia-rollback                 # prev version
#   sudo laia-rollback v0.2.0          # specific version
#   sudo laia-rollback --list          # show installed versions
#
# This is intentionally separate from laia-release so it stays simple and
# never invokes builds — just flips the symlink and restarts services.
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
LAIA_ROOT="$(dirname "$SCRIPT_DIR")"
LIB_DIR="$LAIA_ROOT/infra/installer/lib"

# shellcheck source=../infra/installer/lib/common.sh
source "$LIB_DIR/common.sh"
# shellcheck source=../infra/installer/lib/sudo.sh
source "$LIB_DIR/sudo.sh"
# shellcheck source=../infra/installer/lib/system.sh
source "$LIB_DIR/system.sh"
# shellcheck source=../infra/installer/lib/version.sh
source "$LIB_DIR/version.sh"
# shellcheck source=../infra/installer/lib/install.sh
source "$LIB_DIR/install.sh"
# shellcheck source=../infra/installer/lib/release.sh
source "$LIB_DIR/release.sh"

# ─── Options ────────────────────────────────────────────────────────────────
OPT_TARGET=""
OPT_LIST=false
OPT_YES=false
OPT_DRY_RUN=false

print_help() {
  cat <<'EOF'
laia-rollback — switch /opt/laia symlink to a previous version

USAGE
    sudo laia-rollback [OPTIONS] [VERSION]
    sudo laia rollback [OPTIONS] [VERSION]

ARGUMENTS
    VERSION               Specific version to roll back to (e.g. v0.2.0).
                          Default: the version that was active immediately
                          before the current one.

OPTIONS
    --list                List installed versions in /opt and exit
    --yes, -y             Non-interactive
    --dry-run             Show what would happen, don't change anything
    --help, -h            Show this help

EXAMPLES
    sudo laia-rollback                 # most recent prior version
    sudo laia-rollback v0.2.0          # specific version
    sudo laia-rollback --list          # what versions are available

NOTE
    Rollback only flips the symlink and restarts services. It does NOT rebuild,
    re-run migrations, or touch user data in ~/LAIA-ARCH/. If a release made
    breaking schema changes, plain rollback may leave the agent in an
    inconsistent state — restore from snapshot in that case.
EOF
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)  print_help; exit 0 ;;
      --list)     OPT_LIST=true; shift ;;
      -y|--yes)   OPT_YES=true; export LAIA_NONINTERACTIVE=true; shift ;;
      --dry-run)  OPT_DRY_RUN=true; shift ;;
      -*) die "Unknown option: $1 (use --help)" 2 ;;
      *)
        if [[ -z "$OPT_TARGET" ]]; then
          OPT_TARGET="$1"; shift
        else
          die "Multiple versions given: $OPT_TARGET vs $1" 2
        fi
        ;;
    esac
  done
}

cmd_list() {
  log_step "Installed LAIA versions"
  local current versions root
  current="$(inst_current_version)"
  versions="$(inst_list_versions)"
  root="$(inst_install_root)"

  if [[ -z "$versions" ]]; then
    log_warn "No versions installed at $root/laia-v*"
    return
  fi

  local v
  while IFS= read -r v; do
    if [[ "$v" == "$current" ]]; then
      printf '  %s* %s%s  (current)\n' "$C_GRN" "$v" "$C_RST"
    else
      printf '    %s\n' "$v"
    fi
  done <<<"$versions"

  local prev
  prev="$(rel_load_previous 2>/dev/null || true)"
  if [[ -n "$prev" ]]; then
    printf '\n  Previous (default rollback target): %s\n' "$prev"
  fi
}

# ─── Main ───────────────────────────────────────────────────────────────────
main() {
  parse_args "$@"

  # rollback never builds, so INST_DEST/INST_PREFIX are set from the install
  # root directly (no version resolution needed up-front).
  INST_PREFIX="$(inst_install_prefix)"
  INST_BIN_DIR="${LAIA_BIN_DIR_OVERRIDE:-$LAIA_USR_LOCAL_BIN}"
  DATA_DIR="${LAIA_HOME_OVERRIDE:-$LAIA_USER_HOME/$LAIA_DATA_DIR_NAME}"
  SYSTEMD_DIR="${LAIA_SYSTEMD_DIR_OVERRIDE:-/etc/systemd/system}"

  if [[ "$OPT_LIST" == true ]]; then
    cmd_list
    exit 0
  fi

  log_step "laia-rollback"

  local current target
  current="$(inst_current_version)"
  if [[ -z "$current" ]]; then
    if [[ "$OPT_DRY_RUN" == true ]]; then
      log_warn "No current install at $INST_PREFIX — nothing to roll back (dry-run)"
      exit 0
    fi
    die "Nothing to roll back — no current install at $INST_PREFIX"
  fi

  if [[ -n "$OPT_TARGET" ]]; then
    target="$OPT_TARGET"
    [[ "$target" =~ ^v ]] || target="v$target"
  else
    target="$(rel_load_previous)"
    if [[ -z "$target" ]]; then
      # Fall back: pick the most recent installed version that isn't current.
      target="$(inst_list_versions | sort -Vr | grep -vxF "$current" | head -1 || true)"
      [[ -n "$target" ]] || die "No previous version recorded and no other installed version found."
      log_warn "No .previous file found; falling back to most recent other version: $target"
    fi
  fi

  log_info "Current:        $current"
  log_info "Rolling back to: $target"
  log_info "Available:      $(inst_list_versions | tr '\n' ' ')"

  [[ "$target" != "$current" ]] \
    || die "Already at $target — nothing to do"

  local root target_dir
  root="$(inst_install_root)"
  target_dir="$root/laia-$target"
  [[ -d "$target_dir" ]] \
    || die "Version $target not installed at $target_dir (use --list to see what's available)"

  if [[ "$OPT_DRY_RUN" == true ]]; then
    log_warn "Dry-run mode — no changes made."
    exit 0
  fi

  if ! inst_is_override_mode; then
    require_root "rollback writes to $INST_PREFIX"
    ensure_sudo_cached
  fi

  rel_capture_active_units

  # Set INST_DEST so inst_switch_symlink knows where to point.
  INST_DEST="$target_dir"
  inst_switch_symlink

  # The version we just rolled FROM is the new "previous".
  rel_record_previous "$current"

  rel_restart_active
  if ! rel_healthcheck; then
    log_warn "Healthcheck failed after rollback. No further automatic recovery."
    log_warn "If services are broken, investigate manually or restore from snapshot."
  fi

  rollback_print_summary
}

main "$@"
