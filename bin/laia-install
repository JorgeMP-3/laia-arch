#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# laia-install — install LAIA on a clean host
#
# Lays down /opt/laia-vX.Y.Z/, switches /opt/laia symlink, registers wrappers
# in /usr/local/bin, installs systemd units (disabled), prepares ~/LAIA-ARCH/,
# writes LAIA_HOME into shell rc files, and unless --minimal is passed,
# bootstraps a factory-default LAIA (LXD + laia-agora + auth/admin/skills).
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
LAIA_ROOT="$(dirname "$SCRIPT_DIR")"
LIB_DIR="$LAIA_ROOT/infra/installer/lib"

# shellcheck source=../infra/installer/lib/common.sh
source "$LIB_DIR/common.sh"
# shellcheck source=../infra/installer/lib/sudo.sh
source "$LIB_DIR/sudo.sh"
# shellcheck source=../infra/installer/lib/system.sh
source "$LIB_DIR/system.sh"
# shellcheck source=../infra/installer/lib/version.sh
source "$LIB_DIR/version.sh"
# shellcheck source=../infra/installer/lib/install.sh
source "$LIB_DIR/install.sh"
# shellcheck source=../infra/installer/lib/release.sh
source "$LIB_DIR/release.sh"
# shellcheck source=../infra/installer/lib/bootstrap.sh
source "$LIB_DIR/bootstrap.sh"
# shellcheck source=../infra/installer/lib/factory.sh
source "$LIB_DIR/factory.sh"
# shellcheck source=../infra/installer/lib/shell_rc.sh
source "$LIB_DIR/shell_rc.sh"
# shellcheck source=../infra/installer/lib/systemd.sh
source "$LIB_DIR/systemd.sh"

# ─── Options ────────────────────────────────────────────────────────────────
OPT_YES=false
OPT_DRY_RUN=false
OPT_FORCE=false
OPT_NO_SYSTEMD=false
OPT_SKIP_PIP=false
OPT_SKIP_FRONTEND=false
OPT_ALSO_DEV_CLONE=false
OPT_MINIMAL=false
OPT_INIT_LXD=false
OPT_AUTH_FILE=""
OPT_ADMIN_USER=""
OPT_ADMIN_PASS=""
OPT_ADMIN_PASS_FILE=""
OPT_VERSION=""
OPT_FROM_LOCAL=""

print_help() {
  cat <<'EOF'
laia-install — install LAIA on a clean host

USAGE
    sudo laia-install [OPTIONS]
    sudo laia install [OPTIONS]        # via the laia delegator

OPTIONS
    --version VER         Force install version (default: read from git tag or VERSION)
    --from-local PATH     Build from a local source tree (default: clone from GitHub)
    --also-dev-clone      Also clone the repo to ~/.laia/ for development
    --minimal             Install bare host files only; skip factory bootstrap
    --auth-file PATH      Pre-stage auth.json from PATH
    --admin-user USER     LAIA admin username for AGORA
    --admin-pass-file PATH
                          Path to a file containing the admin password
                          (recommended; mode 0600). The file is unlinked
                          immediately after the password is read so it
                          never lingers on disk.
    --admin-pass PASS     LAIA admin password for AGORA
                          [DEPRECATED — visible via `ps`/proc; use
                          --admin-pass-file in production]
    --init-lxd            Install/init LXD automatically if missing
    --no-systemd          Don't install systemd unit files
    --skip-pip            Don't create venvs / run pip install
    --skip-frontend       Don't check for laia-ui build artifacts
    --yes, -y             Non-interactive mode, accept defaults
    --force               Overwrite an existing install of the same version
    --dry-run             Print what would happen, don't change anything
    --json-progress       Emit machine-readable JSON event lines to stdout
                          for laia-wizard to render. Human log is unchanged.
    --help, -h            Show this help

ENVIRONMENT
    SUDO_USER             Must be set when invoking via sudo (preserved by `sudo -E`)
    LAIA_HOME             Override admin data directory (default: $HOME/LAIA-ARCH)

EXAMPLES
    sudo -E laia-install --from-local "$HOME/.laia" --version v0.1.0
    sudo -E laia-install --yes        # install latest tagged version

EXIT CODES
    0   Success
    1   Generic failure
    2   Bad arguments
    3   Missing prerequisites
    4   Operation timed out
    5   Network failure (download / GitHub clone)
    6   Health check failed after install
EOF
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)        print_help; exit 0 ;;
      -v|--version)
        if [[ $# -ge 2 && -n "${2:-}" && "${2:0:1}" != "-" ]]; then
          OPT_VERSION="$2"; shift 2
        else
          # `--version` with no arg → print our own version
          local self_v
          self_v="$(detect_version "$LAIA_ROOT" "" 2>/dev/null || echo 'dev')"
          printf 'laia-install %s\n' "$self_v"
          exit 0
        fi
        ;;
      --from-local)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--from-local requires PATH" 2
        OPT_FROM_LOCAL="$(readlink -f "$2")"; shift 2 ;;
      --also-dev-clone) OPT_ALSO_DEV_CLONE=true; shift ;;
      --minimal)       OPT_MINIMAL=true; shift ;;
      --auth-file)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--auth-file requires PATH" 2
        OPT_AUTH_FILE="$(readlink -f "$2")"; shift 2 ;;
      --admin-user)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--admin-user requires USER" 2
        OPT_ADMIN_USER="$2"; shift 2 ;;
      --admin-pass)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--admin-pass requires PASS" 2
        OPT_ADMIN_PASS="$2"; shift 2 ;;
      --admin-pass-file)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--admin-pass-file requires PATH" 2
        OPT_ADMIN_PASS_FILE="$2"; shift 2 ;;
      --json-progress)
        export LAIA_JSON_PROGRESS=1
        shift ;;
      --init-lxd)      OPT_INIT_LXD=true; shift ;;
      --no-systemd)     OPT_NO_SYSTEMD=true; shift ;;
      --skip-pip)       OPT_SKIP_PIP=true; shift ;;
      --skip-frontend)  OPT_SKIP_FRONTEND=true; shift ;;
      -y|--yes)         OPT_YES=true; export LAIA_NONINTERACTIVE=true; shift ;;
      --force)          OPT_FORCE=true; shift ;;
      --dry-run)        OPT_DRY_RUN=true; shift ;;
      *) die "Unknown option: $1 (use --help)" 2 ;;
    esac
  done
}

# resolve_admin_pass_file — if --admin-pass-file was given, read its content
# into OPT_ADMIN_PASS and immediately unlink the file so the password never
# survives the installer process. Rejected when both --admin-pass and
# --admin-pass-file are given to avoid silent disagreements.
resolve_admin_pass_file() {
  [[ -z "$OPT_ADMIN_PASS_FILE" ]] && return 0

  if [[ -n "$OPT_ADMIN_PASS" ]]; then
    die "Cannot combine --admin-pass and --admin-pass-file" 2
  fi
  if [[ ! -f "$OPT_ADMIN_PASS_FILE" ]]; then
    die "--admin-pass-file path not found: $OPT_ADMIN_PASS_FILE" 2
  fi
  if [[ ! -r "$OPT_ADMIN_PASS_FILE" ]]; then
    die "--admin-pass-file not readable: $OPT_ADMIN_PASS_FILE" 2
  fi

  OPT_ADMIN_PASS="$(< "$OPT_ADMIN_PASS_FILE")"
  # Strip a single trailing newline if present (heredocs / echo always add one).
  OPT_ADMIN_PASS="${OPT_ADMIN_PASS%$'\n'}"

  if [[ -z "$OPT_ADMIN_PASS" ]]; then
    die "--admin-pass-file is empty: $OPT_ADMIN_PASS_FILE" 2
  fi

  # Unlink eagerly; the file's purpose was to bridge argv to memory.
  rm -f "$OPT_ADMIN_PASS_FILE" 2>/dev/null || true
  OPT_ADMIN_PASS_FILE=""
}

# ─── Main ───────────────────────────────────────────────────────────────────
main() {
  trap_errors
  install_signal_traps
  parse_args "$@"
  resolve_admin_pass_file

  emit_json_event step_start install:preflight "Preflight checks"
  log_step "laia-install"
  log_info "Source tree:     ${OPT_FROM_LOCAL:-<clone from GitHub>}"
  log_info "Target version:  ${OPT_VERSION:-<auto-detect>}"
  log_info "Dry-run:         $OPT_DRY_RUN"
  log_info "Non-interactive: $OPT_YES"
  log_info "Install systemd: $([[ "$OPT_NO_SYSTEMD" == true ]] && echo no || echo yes)"
  log_info "Skip pip:        $OPT_SKIP_PIP"
  log_info "Skip frontend:   $OPT_SKIP_FRONTEND"
  log_info "Factory bootstrap: $([[ "$OPT_MINIMAL" == true ]] && echo no || echo yes)"
  log_info "Admin user:      $LAIA_USER ($LAIA_USER_HOME)"

  inst_preflight

  inst_resolve_source
  inst_resolve_version
  inst_resolve_paths
  emit_json_event step_done install:preflight "Preflight OK"

  if [[ "$OPT_DRY_RUN" == true ]]; then
    log_warn "Dry-run mode — stopping before any mutations."
    exit 0
  fi

  inst_check_existing_version

  if ! inst_is_override_mode; then
    ensure_sudo_cached
  fi

  emit_json_event step_start install:lay-down "Copy source, create venvs, install wrappers"
  inst_copy_source_to_dest
  inst_create_venvs
  inst_check_frontend
  inst_finalize_permissions
  inst_switch_symlink
  inst_install_wrappers
  inst_ensure_data_dir
  shell_rc_apply "$DATA_DIR"
  systemd_install_all
  emit_json_event step_done install:lay-down "Host install complete"

  if [[ "$OPT_MINIMAL" == true ]]; then
    log_step "Factory bootstrap (SKIPPED — --minimal)"
    emit_json_event step_done install:factory "Factory bootstrap skipped (--minimal)"
  else
    emit_json_event step_start install:factory "Factory bootstrap (LXD + agora + admin)"
    fact_seed_cli_config
    fact_seed_authjson
    fact_persist_env_to_container
    boot_detect_arch
    boot_check_lxd_installed
    emit_json_event step_start install:lxd-images "Build LXD images"
    boot_init_defaults
    boot_build_images
    emit_json_event step_done install:lxd-images "LXD images ready"
    emit_json_event step_start install:agora "Provision laia-agora container"
    boot_provision_agora
    boot_wait_for_agora_health
    emit_json_event step_done install:agora "AGORA reachable"
    fact_seed_admin_user
    fact_seed_base_skills
    emit_json_event step_done install:factory "Factory bootstrap complete"
  fi

  inst_print_summary
  emit_json_event step_done install:finish "Installation complete"
}

main "$@"
