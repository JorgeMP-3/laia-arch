#!/usr/bin/env zsh
# gsave — guardado guiado de proyectos LAIA en GitHub

YEL='\033[1;33m'; CYN='\033[1;36m'; GRN='\033[1;32m'
RED='\033[1;31m'; DIM='\033[2m'; RST='\033[0m'; BLD='\033[1m'

header() { echo "\n${YEL}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RST}"; echo "${BLD}  $1${RST}"; echo "${YEL}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RST}" }
ok()     { echo "${GRN}  ✓ $1${RST}" }
info()   { echo "${CYN}  → $1${RST}" }
warn()   { echo "${YEL}  ⚠ $1${RST}" }
err()    { echo "${RED}  ✕ $1${RST}" }
ask()    { printf "${BLD}  $1 ${DIM}$2${RST} "; read -r REPLY }

LAIA_CODE="$HOME/LAIA/.laia-arch"
LAIA_PRIVATE="$HOME/LAIA"
WS_UI="$LAIA_CODE/workspace-ui"
HERMES="$LAIA_CODE"

# ── Guarda un proyecto individual ────────────────────────────────────────────
# NOTA: no usar 'path' como nombre de variable — es reservada en zsh ($PATH)
save_project() {
  local _name="$1"
  local _dir="$2"
  local _remote="$3"
  local _branch="$4"

  if [[ ! -e "$_dir/.git" ]]; then
    err "$_name: directorio no encontrado ($_dir)"
    return 1
  fi

  local _changed
  _changed=$(git -C "$_dir" status --short 2>/dev/null)

  if [[ -z "$_changed" ]]; then
    ok "$_name — sin cambios"
    return 0
  fi

  info "Archivos modificados en $_name:"
  git -C "$_dir" status --short | while read -r line; do
    echo "     ${DIM}$line${RST}"
  done

  echo ""
  ask "Mensaje del commit (Enter = 'actualización'):" ""
  local _msg="${REPLY:-actualización}"

  ask "¿Confirmar commit en $_name → $_branch? (s/n)" ""
  [[ "$REPLY" =~ ^[Ss]$ ]] || { info "Saltado."; return 0 }

  git -C "$_dir" add -A
  git -C "$_dir" commit -m "$_msg" -q

  local _push_out
  _push_out=$(git -C "$_dir" push "$_remote" "$_branch" 2>&1 | grep -v "failed to get\|failed to store")
  if [[ $? -eq 0 ]]; then
    ok "$_name subido a GitHub ✓"
  else
    err "$_name: falló el push. Revisa conexión o token."
    [[ -n "$_push_out" ]] && echo "  ${DIM}$_push_out${RST}"
    return 1
  fi
}

# ── Sincroniza archivos de config importantes a laia-infra ───────────────────
sync_laia_config() {
  local _base="$LAIA_PRIVATE"

  # Memorias → laia-private
  rsync -a --delete --exclude='*.lock' \
    "$HOME/LAIA/memories/" "$_base/memories/" 2>/dev/null

  # Scripts del sistema (~/bin) → .laia-arch/bin
  rsync -a --delete \
    "$HOME/bin/" "$LAIA_CODE/bin/" 2>/dev/null

  # Archivos sueltos config
  [[ -f "$HOME/LAIA/config/ai-agents.json" ]] && \
    cp "$HOME/LAIA/ai-agents.json" "$_base/config/ai-agents.json" 2>/dev/null || true
}

# ── Actualiza laia-private (datos personales) ────────────────────────────────
update_private() {
  header "🔒  laia-private — sincronizando"

  if [[ ! -d "$LAIA_PRIVATE/.git" ]]; then
    err "laia-private no encontrado en $LAIA_PRIVATE"
    return 1
  fi

  sync_laia_config

  local _changed
  _changed=$(git -C "$LAIA_PRIVATE" status --short 2>/dev/null)

  if [[ -z "$_changed" ]]; then
    ok "laia-private ya está al día"
    return 0
  fi

  git -C "$LAIA_PRIVATE" add -A
  git -C "$LAIA_PRIVATE" commit -m "chore: sync personal data" -q

  git -C "$LAIA_PRIVATE" push origin main -q 2>&1 \
    | grep -v "failed to get\|failed to store" || true
  ok "laia-private actualizado en GitHub ✓"
}

# ── Estado rápido ─────────────────────────────────────────────────────────────
_status_line() {
  local _name="$1" _dir="$2"
  local _n
  _n=$(git -C "$_dir" status --short 2>/dev/null | wc -l | tr -d ' ')
  if [[ "$_n" -gt 0 ]]; then
    echo "  ${YEL}●${RST} ${BLD}$_name${RST} ${DIM}($_n cambios pendientes)${RST}"
  else
    echo "  ${GRN}●${RST} ${BLD}$_name${RST} ${DIM}(al día)${RST}"
  fi
}

# ── Menú ─────────────────────────────────────────────────────────────────────
clear
echo ""
echo "${YEL}  ██████╗ ███████╗ █████╗ ██╗   ██╗███████╗${RST}"
echo "${YEL}  ██╔════╝██╔════╝██╔══██╗██║   ██║██╔════╝${RST}"
echo "${YEL}  ██║  ███╗███████╗███████║██║   ██║█████╗  ${RST}"
echo "${YEL}  ██║   ██║╚════██║██╔══██║╚██╗ ██╔╝██╔══╝  ${RST}"
echo "${YEL}  ╚██████╔╝███████║██║  ██║ ╚████╔╝ ███████╗${RST}"
echo "${YEL}   ╚═════╝ ╚══════╝╚═╝  ╚═╝  ╚═══╝  ╚══════╝${RST}"
echo ""
echo "${DIM}  Guardado guiado · github.com/JorgeMP-3${RST}"
echo ""

_status_line "laia-arch (código)"   "$HERMES"
_status_line "workspace-ui"         "$WS_UI"
_status_line "LAIA (personal)"      "$LAIA_PRIVATE"

echo ""
echo "  ${BLD}1)${RST}  laia-arch        ${DIM}(código, hermes + workspace-ui)${RST}"
echo "  ${BLD}2)${RST}  LAIA personal    ${DIM}(memorias, docs, config)${RST}"
echo "  ${BLD}3)${RST}  Todo             ${DIM}(los dos repos)${RST}"
echo "  ${BLD}q)${RST}  Salir"
echo ""
ask "Elige una opción:" ""

case "$REPLY" in
  1)
    save_project "laia-arch" "$HERMES" "origin" "local-customizations"
    ;;
  2)
    update_private
    ;;
  3)
    save_project "laia-arch" "$HERMES" "origin" "local-customizations"
    update_private
    ;;
  q|Q)
    echo ""; info "Hasta luego." ;;
  *)
    err "Opción no válida." ;;
esac

echo ""
