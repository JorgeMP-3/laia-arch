#!/usr/bin/env zsh
# clone-laia вҖ” instala LAIA completo en una mГЎquina nueva (macOS y Linux)
# Uso: clone-laia

set -e

YEL='\033[1;33m'; GRN='\033[1;32m'; RED='\033[1;31m'
CYN='\033[1;36m'; DIM='\033[2m'; RST='\033[0m'; BLD='\033[1m'

ok()    { echo "${GRN}  вң“ $1${RST}" }
info()  { echo "${CYN}  вҶ’ $1${RST}" }
err()   { echo "${RED}  вң• $1${RST}"; echo ""; exit 1 }
step()  { echo "\n${YEL}${BLD}в”Җв”Җ $1 в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${RST}" }
warn()  { echo "${YEL}  вҡ  $1${RST}" }
ask()   { printf "${BLD}  $1 ${DIM}$2${RST} "; read -r REPLY }

REPO_CODE="https://github.com/JorgeMP-3/laia-arch.git"
REPO_PRIVATE="https://github.com/JorgeMP-3/laia-private.git"

LAIA_DIR="$HOME/LAIA"
CODE_DIR="$LAIA_DIR/.laia-arch"
VENV="$CODE_DIR/venv"

# Detectar sistema operativo
if [[ "$(uname)" == "Darwin" ]]; then
  OS="macos"
elif [[ "$(uname)" == "Linux" ]]; then
  OS="linux"
  if command -v apt &>/dev/null; then
    DISTRO="debian"
  elif command -v dnf &>/dev/null; then
    DISTRO="fedora"
  elif command -v pacman &>/dev/null; then
    DISTRO="arch"
  else
    DISTRO="unknown"
  fi
else
  OS="unknown"
fi

# в”Җв”Җ Header в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
clear
echo ""
echo "${YEL}  в–Ҳв–Ҳв•—      в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— ${RST}"
echo "${YEL}  в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—    в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—${RST}"
echo "${YEL}  в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘    в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ${RST}"
echo "${YEL}  в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘    в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•қ ${RST}"
echo "${YEL}  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘    в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘   в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘     ${RST}"
echo "${YEL}  в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ   в•ҡв•җв•қ    в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ     ${RST}"
echo ""
echo "${DIM}  Instalador de LAIA В· github.com/JorgeMP-3${RST}"
_distro_str=""
[[ -n "${DISTRO:-}" ]] && _distro_str=" ($DISTRO)"
echo "${DIM}  Sistema detectado: ${OS}${_distro_str}${RST}"
echo ""
echo "  Esto instalarГЎ en ~/LAIA/:"
echo "  ${DIM}  вҖў .laia-arch/   (cГіdigo: hermes-agent + workspace-ui + skills)${RST}"
echo "  ${DIM}  вҖў memories/     (memorias personales desde laia-private)${RST}"
echo "  ${DIM}  вҖў docs/         (documentaciГіn personal)${RST}"
echo ""
ask "ВҝContinuar? (s/n)" ""
[[ "$REPLY" =~ ^[Ss]$ ]] || { info "Cancelado."; exit 0 }

# в”Җв”Җ 0. Prereqs de sistema (solo Linux Debian) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [[ "$OS" == "linux" && "${DISTRO:-}" == "debian" ]]; then
  step "0/6  Verificando prereqs del sistema"

  PKGS_NEEDED=()
  command -v git     &>/dev/null || PKGS_NEEDED+=("git")
  command -v python3 &>/dev/null || PKGS_NEEDED+=("python3")
  command -v pip3    &>/dev/null || PKGS_NEEDED+=("python3-pip")
  python3 -m venv --help &>/dev/null 2>&1 || PKGS_NEEDED+=("python3-venv")
  command -v node    &>/dev/null || PKGS_NEEDED+=("nodejs")
  command -v npm     &>/dev/null || PKGS_NEEDED+=("npm")
  command -v curl    &>/dev/null || PKGS_NEEDED+=("curl")

  if [[ ${#PKGS_NEEDED[@]} -gt 0 ]]; then
    warn "Faltan paquetes: ${PKGS_NEEDED[*]}"
    ask "ВҝInstalarlos ahora con apt? (requiere sudo) (s/n)" ""
    if [[ "$REPLY" =~ ^[Ss]$ ]]; then
      sudo apt update -qq && sudo apt install -y "${PKGS_NEEDED[@]}"
      ok "Paquetes instalados"
    else
      err "Instala manualmente: sudo apt install ${PKGS_NEEDED[*]}"
    fi
  fi

  if ! command -v gh &>/dev/null; then
    warn "GitHub CLI (gh) no encontrado"
    ask "ВҝInstalar gh CLI automГЎticamente? (s/n)" ""
    if [[ "$REPLY" =~ ^[Ss]$ ]]; then
      curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | sudo dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg
      echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        | sudo tee /etc/apt/sources.list.d/github-cli.list > /dev/null
      sudo apt update -qq && sudo apt install -y gh
      ok "gh CLI instalado"
    else
      err "Instala gh: https://cli.github.com/manual/installation"
    fi
  fi
fi

# в”Җв”Җ 1. Dependencias в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
step "1/6  Verificando dependencias"

MISSING=()
for cmd in git python3 node npm gh; do
  if command -v $cmd &>/dev/null; then
    ok "$cmd вҖ” $(${cmd} --version 2>&1 | head -1)"
  else
    MISSING+=("$cmd")
    echo "${RED}  вң• $cmd вҖ” no encontrado${RST}"
  fi
done

if [[ ${#MISSING[@]} -gt 0 ]]; then
  echo ""
  err "Instala los siguientes programas antes de continuar: ${MISSING[*]}"
fi

# в”Җв”Җ 2. GitHub auth в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
step "2/6  AutenticaciГіn GitHub"

if gh auth status &>/dev/null; then
  _ghuser=$(gh api user --jq .login 2>/dev/null)
  ok "GitHub вҖ” sesiГіn activa como $_ghuser"
else
  info "Necesitas autenticarte en GitHub:"
  echo "  ${DIM}Ejecuta: gh auth login${RST}"
  echo "  ${DIM}Luego vuelve a ejecutar clone-laia${RST}"
  echo ""
  err "No autenticado en GitHub CLI (gh)"
fi

# в”Җв”Җ 3. Clonar repos в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
step "3/6  Clonando repos"

mkdir -p "$LAIA_DIR"

# Repo de cГіdigo вҶ’ LAIA/.laia-arch
if [[ -d "$CODE_DIR/.git" ]]; then
  warn "Ya existe en $CODE_DIR вҖ” actualizando..."
  git -C "$CODE_DIR" pull -q
  ok "laia-arch actualizado"
else
  info "Clonando laia-arch en $CODE_DIR ..."
  git clone "$REPO_CODE" "$CODE_DIR" -q
  ok "laia-arch clonado"
fi

# AГұadir upstream NousResearch si no estГЎ
if ! git -C "$CODE_DIR" remote | grep -q upstream; then
  git -C "$CODE_DIR" remote add upstream https://github.com/NousResearch/hermes-agent.git
  ok "Remote upstream aГұadido (NousResearch/hermes-agent)"
fi

# Repo personal вҶ’ LAIA/ (solo memories, docs, config)
if [[ ! -f "$LAIA_DIR/.git/config" ]]; then
  info "Inicializando repo laia-private en $LAIA_DIR ..."
  git -C "$LAIA_DIR" init -q
  git -C "$LAIA_DIR" remote add origin "$REPO_PRIVATE"
  git -C "$LAIA_DIR" pull origin main -q 2>/dev/null || true
  ok "laia-private configurado"
else
  git -C "$LAIA_DIR" pull origin main -q 2>/dev/null || true
  ok "laia-private actualizado"
fi

# в”Җв”Җ 4. Entorno Python в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
step "4/6  Configurando entorno Python"

if [[ ! -d "$VENV" ]]; then
  info "Creando entorno virtual Python..."
  python3 -m venv "$VENV"
fi

info "Instalando hermes-agent..."
source "$VENV/bin/activate"
pip install -e "$CODE_DIR" -q --disable-pip-version-check
deactivate
ok "hermes-agent instalado en venv"

# в”Җв”Җ 5. Symlinks internos в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
step "5/6  Configurando symlinks"

ln -sf "$CODE_DIR" "$LAIA_DIR/hermes-agent" 2>/dev/null || true
ok "Symlink hermes-agent вҶ’ .laia-arch"

ln -sf "$CODE_DIR/workspace-ui" "$LAIA_DIR/workspace-ui" 2>/dev/null || true
ok "Symlink workspace-ui вҶ’ .laia-arch/workspace-ui"

# в”Җв”Җ 6. ConfiguraciГіn final в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
step "6/6  ConfiguraciГіn final"

# config.yaml desde template si no existe
if [[ ! -f "$LAIA_DIR/config.yaml" && -f "$CODE_DIR/config.template.yaml" ]]; then
  cp "$CODE_DIR/config.template.yaml" "$LAIA_DIR/config.yaml"
  ok "config.yaml creado en ~/LAIA/"
  warn "Edita ~/LAIA/config.yaml para aГұadir tus API keys"
else
  ok "config.yaml ya existe"
fi

# Scripts de ~/bin
if [[ -d "$CODE_DIR/bin" ]]; then
  mkdir -p "$HOME/bin"
  rsync -a "$CODE_DIR/bin/" "$HOME/bin/"
  chmod +x "$HOME/bin/"* 2>/dev/null || true
  ok "Scripts de ~/bin instalados"
fi

# HERMES_HOME en shell
ZSHRC="$HOME/.zshrc"
BASHRC="$HOME/.bashrc"
SHELL_BLOCK='
# LAIA вҖ” aГұadido por clone-laia
export HERMES_HOME="$HOME/LAIA"
export PATH="$HOME/bin:$HOME/.local/bin:$PATH"
'

for rcfile in "$ZSHRC" "$BASHRC"; do
  if [[ -f "$rcfile" ]] && ! grep -q "LAIA вҖ” aГұadido por clone-laia" "$rcfile"; then
    echo "$SHELL_BLOCK" >> "$rcfile"
    ok "HERMES_HOME aГұadido a $(basename $rcfile)"
  fi
done

# в”Җв”Җ Resumen в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo ""
echo "${YEL}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${RST}"
echo "${GRN}${BLD}  вң“ LAIA instalado correctamente${RST}"
echo "${YEL}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${RST}"
echo ""
echo "  ${BLD}Ubicaciones:${RST}"
echo "  ${DIM}  ~/LAIA/              вҶ’ datos personales + runtime${RST}"
echo "  ${DIM}  ~/LAIA/.laia-arch/   вҶ’ cГіdigo (hermes + workspace-ui)${RST}"
echo ""

if [[ -f "$LAIA_DIR/auth.json" ]]; then
  echo "  ${GRN}вң“ auth.json encontrado вҖ” tokens restaurados${RST}"
else
  echo "  ${YEL}вҡ   auth.json no encontrado${RST}"
  echo "  ${DIM}  Restaura desde USB: openssl enc -d -aes-256-cbc -pbkdf2 -iter 100000 \\${RST}"
  echo "  ${DIM}    -in laia-secrets-*.tar.gz | tar -xz -C ~/LAIA/${RST}"
  echo ""
fi

echo "  ${BLD}PrГіximos pasos:${RST}"
echo "  ${DIM}  1. Restaura auth.json y config.yaml desde USB si es necesario${RST}"
echo "  ${DIM}  2. Recarga la shell: source ~/.bashrc${RST}"
echo "  ${DIM}  3. Arranca hermes:   hermes gateway run${RST}"
echo ""
