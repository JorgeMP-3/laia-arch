#!/usr/bin/env bash
set -euo pipefail
# laia-backup: sistema de backups del servidor LAIA (D1, layout v2).
# Alcance del backup nocturno (`all`): agora.db + /srv/laia/users + /srv/laia/arch.
# Destino por defecto: /mnt/data/laia-backups (otro disco físico).

BOLD="\e[1m"; GREEN="\e[32m"; RED="\e[31m"; CYAN="\e[36m"; DIM="\e[2m"; RESET="\e[0m"
if [[ -z "${LAIA_ROOT:-}" ]]; then
  _script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  LAIA_ROOT="$(git -C "$_script_dir" rev-parse --show-toplevel 2>/dev/null || cd "$_script_dir/../.." && pwd)"
  unset _script_dir
fi
BACKUP_DIR="${LAIA_BACKUP_DIR:-/mnt/data/laia-backups}"
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
RETENTION_DEFAULT_DAYS=14

usage() {
    echo "uso: laia-backup <que>"
    echo ""
    echo "que:"
    echo "  agora       datos de AGORA (agora.db)"
    echo "  users       datos de usuarios (/srv/laia/users)"
    echo "  arch        runtime operacional del ARCH (/srv/laia/arch)"
    echo "  all         agora + users + arch (alcance del backup nocturno)"
    echo "  workspaces  todos los workspaces (workspace.db) — opt-in"
    echo "  agents      snapshots LXD de todos los agentes — opt-in (toca LXD)"
    echo "  list        listar backups existentes"
    echo "  clean N     borrar backups de hace mas de N dias (default $RETENTION_DEFAULT_DAYS)"
    exit 1
}

[[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]] && usage

what="$1"; shift
mkdir -p "$BACKUP_DIR"

backup_agora() {
    echo -e "${BOLD}AGORA DB...${RESET}"
    local agora_db="${AGORA_DB:-${LAIA_AGORA_DIR_OVERRIDE:-/srv/laia/agora}/agora.db}"
    if [[ -f "$agora_db" ]]; then
        cp "$agora_db" "$BACKUP_DIR/agora_${TIMESTAMP}.db" && \
            echo -e "  ${GREEN}OK${RESET} agora_${TIMESTAMP}.db ($(du -h "$BACKUP_DIR/agora_${TIMESTAMP}.db" | cut -f1))" || \
            echo -e "  ${RED}FAIL${RESET}"
    else
        echo -e "  ${DIM}no encontrado: $agora_db${RESET}"
    fi
}

# _backup_tree <label> <src_dir> <prefix> — tar.gz a $prefix_<ts>.tar.gz (origen intacto).
_backup_tree() {
    local label="$1" src="$2" prefix="$3"
    echo -e "${BOLD}${label}...${RESET}"
    if [[ -d "$src" ]]; then
        local out="$BACKUP_DIR/${prefix}_${TIMESTAMP}.tar.gz"
        if tar -czf "$out" -C "$(dirname "$src")" "$(basename "$src")" 2>/dev/null; then
            echo -e "  ${GREEN}OK${RESET} ${prefix}_${TIMESTAMP}.tar.gz ($(du -h "$out" | cut -f1))"
        else
            echo -e "  ${RED}FAIL${RESET} $src"
        fi
    else
        echo -e "  ${DIM}no encontrado: $src${RESET}"
    fi
}

backup_users() { _backup_tree "Usuarios"     "${LAIA_USERS_DIR_OVERRIDE:-/srv/laia/users}" "users"; }
backup_arch()  { _backup_tree "ARCH runtime" "${LAIA_ARCH_DIR_OVERRIDE:-/srv/laia/arch}"   "arch";  }

backup_workspaces() {
    echo -e "${BOLD}Workspaces...${RESET}"
    local ws_root="$LAIA_ROOT/workspaces"
    [[ -d "$ws_root" ]] || { echo -e "  ${DIM}no encontrado: $ws_root${RESET}"; return 0; }
    for ws_dir in "$ws_root"/*/; do
        [[ -d "$ws_dir" ]] || continue
        local ws_name; ws_name=$(basename "$ws_dir")
        local db="$ws_dir/workspace.db"
        if [[ -f "$db" ]]; then
            cp "$db" "$BACKUP_DIR/${ws_name}_${TIMESTAMP}.db" && \
                echo -e "  ${GREEN}OK${RESET} $ws_name" || \
                echo -e "  ${RED}FAIL${RESET} $ws_name"
        fi
    done
}

backup_agents() {
    echo -e "${BOLD}Agentes LXD...${RESET}"
    if ! command -v lxc &>/dev/null; then
        echo -e "  ${RED}LXD no disponible${RESET}"; return 0
    fi
    for name in $(lxc list --format csv 2>/dev/null | cut -d',' -f1 | grep '^laia-'); do
        lxc snapshot "$name" "backup-${TIMESTAMP}" 2>/dev/null && \
            echo -e "  ${GREEN}OK${RESET} $name" || \
            echo -e "  ${RED}FAIL${RESET} $name"
    done
}

list_backups() {
    echo -e "${BOLD}Backups en $BACKUP_DIR${RESET}"
    if [[ -d "$BACKUP_DIR" ]]; then
        ls -lh "$BACKUP_DIR" | tail -n +2
    else
        echo -e "  ${DIM}vacio${RESET}"
    fi
}

clean_backups() {
    local days="${1:-$RETENTION_DEFAULT_DAYS}"
    echo -e "${BOLD}Limpiando backups > $days dias...${RESET}"
    find "$BACKUP_DIR" -type f -mtime "+$days" -delete -print 2>/dev/null | while read -r f; do
        echo "  borrado: $(basename "$f")"
    done
    echo -e "  ${GREEN}OK${RESET}"
}

case "$what" in
    agora)      backup_agora ;;
    users)      backup_users ;;
    arch)       backup_arch ;;
    workspaces) backup_workspaces ;;
    agents)     backup_agents ;;
    all)
        echo -e "${BOLD}${CYAN}=== BACKUP ${TIMESTAMP} ===${RESET}"
        backup_agora
        backup_users
        backup_arch
        echo -e "\n${GREEN}Backups en: $BACKUP_DIR${RESET}"
        ;;
    list)       list_backups ;;
    clean)      clean_backups "${1:-$RETENTION_DEFAULT_DAYS}" ;;
    *)          usage ;;
esac
