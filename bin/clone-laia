#!/usr/bin/env zsh
# clone-laia — instala LAIA completo en una máquina nueva (macOS y Linux)
# Uso: clone-laia
# Requiere: git, gh (GitHub CLI), python3, node/npm

set -e

YEL='\033[1;33m'; GRN='\033[1;32m'; RED='\033[1;31m'
CYN='\033[1;36m'; DIM='\033[2m'; RST='\033[0m'; BLD='\033[1m'

ok()    { echo "${GRN}  ✓ $1${RST}" }
info()  { echo "${CYN}  → $1${RST}" }
err()   { echo "${RED}  ✕ $1${RST}"; echo ""; exit 1 }
step()  { echo "\n${YEL}${BLD}── $1 ──────────────────────────────────────${RST}" }
warn()  { echo "${YEL}  ⚠ $1${RST}" }
ask()   { printf "${BLD}  $1 ${DIM}$2${RST} "; read -r REPLY }

REPO="https://github.com/JorgeMP-3/laia-infra.git"
DEST="$HOME/.hermes"

# Detectar sistema operativo
if [[ "$(uname)" == "Darwin" ]]; then
  OS="macos"
elif [[ "$(uname)" == "Linux" ]]; then
  OS="linux"
  # Detectar distro
  if command -v apt &>/dev/null; then
    DISTRO="debian"
  elif command -v dnf &>/dev/null; then
    DISTRO="fedora"
  elif command -v pacman &>/dev/null; then
    DISTRO="arch"
  else
    DISTRO="unknown"
  fi
else
  OS="unknown"
fi

# ── Header ───────────────────────────────────────────────────────────────────
clear
echo ""
echo "${YEL}  ██╗      █████╗ ██╗ █████╗     ███████╗███████╗████████╗██╗   ██╗██████╗ ${RST}"
echo "${YEL}  ██║     ██╔══██╗██║██╔══██╗    ██╔════╝██╔════╝╚══██╔══╝██║   ██║██╔══██╗${RST}"
echo "${YEL}  ██║     ███████║██║███████║    ███████╗█████╗     ██║   ██║   ██║██████╔╝${RST}"
echo "${YEL}  ██║     ██╔══██║██║██╔══██║    ╚════██║██╔══╝     ██║   ██║   ██║██╔═══╝ ${RST}"
echo "${YEL}  ███████╗██║  ██║██║██║  ██║    ███████║███████╗   ██║   ╚██████╔╝██║     ${RST}"
echo "${YEL}  ╚══════╝╚═╝  ╚═╝╚═╝╚═╝  ╚═╝   ╚══════╝╚══════╝   ╚═╝    ╚═════╝ ╚═╝     ${RST}"
echo ""
echo "${DIM}  Instalador de LAIA Arch · github.com/JorgeMP-3/laia-infra${RST}"
_distro_str=""
[[ -n "$DISTRO" ]] && _distro_str=" ($DISTRO)"
echo "${DIM}  Sistema detectado: ${OS}${_distro_str}${RST}"
echo ""
echo "  Esto instalará:"
echo "  ${DIM}  • hermes-agent  (agente CLI con personalización Laia Arch)${RST}"
echo "  ${DIM}  • workspace-ui  (app web de control)${RST}"
echo "  ${DIM}  • SOUL.md y config base${RST}"
echo ""
ask "¿Continuar? (s/n)" ""
[[ "$REPLY" =~ ^[Ss]$ ]] || { info "Cancelado."; exit 0 }

# ── 0. Prereqs de sistema (solo Linux) ────────────────────────────────────────
if [[ "$OS" == "linux" && "$DISTRO" == "debian" ]]; then
  step "0/6  Verificando prereqs del sistema (Linux)"

  PKGS_NEEDED=()
  command -v git     &>/dev/null || PKGS_NEEDED+=("git")
  command -v python3 &>/dev/null || PKGS_NEEDED+=("python3")
  command -v pip3    &>/dev/null || PKGS_NEEDED+=("python3-pip")
  python3 -m venv --help &>/dev/null 2>&1 || PKGS_NEEDED+=("python3-venv")
  command -v node    &>/dev/null || PKGS_NEEDED+=("nodejs")
  command -v npm     &>/dev/null || PKGS_NEEDED+=("npm")
  command -v curl    &>/dev/null || PKGS_NEEDED+=("curl")

  if [[ ${#PKGS_NEEDED[@]} -gt 0 ]]; then
    warn "Faltan paquetes: ${PKGS_NEEDED[*]}"
    ask "¿Instalarlos ahora con apt? (requiere sudo) (s/n)" ""
    if [[ "$REPLY" =~ ^[Ss]$ ]]; then
      sudo apt update -qq && sudo apt install -y "${PKGS_NEEDED[@]}"
      ok "Paquetes instalados"
    else
      err "Instala manualmente: sudo apt install ${PKGS_NEEDED[*]}"
    fi
  fi

  # gh CLI — no está en repos estándar de Ubuntu/Debian
  if ! command -v gh &>/dev/null; then
    warn "GitHub CLI (gh) no encontrado"
    ask "¿Instalar gh CLI automáticamente? (s/n)" ""
    if [[ "$REPLY" =~ ^[Ss]$ ]]; then
      curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | sudo dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg
      echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        | sudo tee /etc/apt/sources.list.d/github-cli.list > /dev/null
      sudo apt update -qq && sudo apt install -y gh
      ok "gh CLI instalado"
    else
      err "Instala gh: https://cli.github.com/manual/installation"
    fi
  fi
fi

# ── 1. Dependencias ───────────────────────────────────────────────────────────
step "1/6  Verificando dependencias"

MISSING=()
for cmd in git python3 node npm gh; do
  if command -v $cmd &>/dev/null; then
    ok "$cmd — $(${cmd} --version 2>&1 | head -1)"
  else
    MISSING+=("$cmd")
    echo "${RED}  ✕ $cmd — no encontrado${RST}"
  fi
done

if [[ ${#MISSING[@]} -gt 0 ]]; then
  echo ""
  err "Instala los siguientes programas antes de continuar: ${MISSING[*]}"
fi

# ── 2. GitHub auth ────────────────────────────────────────────────────────────
step "2/6  Autenticación GitHub"

if gh auth status &>/dev/null; then
  _ghuser=$(gh api user --jq .login 2>/dev/null)
  ok "GitHub — sesión activa como $_ghuser"
else
  info "Necesitas autenticarte en GitHub:"
  echo "  ${DIM}Ejecuta: gh auth login${RST}"
  echo "  ${DIM}Luego vuelve a ejecutar clone-laia${RST}"
  echo ""
  err "No autenticado en GitHub CLI (gh)"
fi

# ── 3. Clonar laia-infra ──────────────────────────────────────────────────────
step "3/6  Clonando laia-infra"

LAIA_DIR="$HOME/laia-arch"

if [[ -d "$LAIA_DIR/.git" ]]; then
  warn "Ya existe en $LAIA_DIR — actualizando..."
  git -C "$LAIA_DIR" pull -q
  git -C "$LAIA_DIR" submodule update --init --recursive -q
  ok "Actualizado"
else
  mkdir -p "$(dirname "$LAIA_DIR")"
  info "Clonando en $LAIA_DIR ..."
  git clone --recurse-submodules "$REPO" "$LAIA_DIR" -q
  ok "Clonado con submodulos"
fi

HERMES_DIR="$LAIA_DIR/hermes-agent"
UI_DIR="$LAIA_DIR/workspace-ui"

# Crear directorio runtime de hermes
mkdir -p "$DEST"

# Copiar hermes-config si no existe runtime ya
if [[ ! -f "$DEST/config.yaml" ]]; then
  # Skills, memories, scripts, hooks desde el backup
  [[ -d "$LAIA_DIR/hermes-config/skills"   ]] && rsync -a "$LAIA_DIR/hermes-config/skills/"   "$DEST/skills/"   --exclude='.hub/' 2>/dev/null
  [[ -d "$LAIA_DIR/hermes-config/memories" ]] && rsync -a "$LAIA_DIR/hermes-config/memories/" "$DEST/memories/" 2>/dev/null
  [[ -d "$LAIA_DIR/hermes-config/scripts"  ]] && rsync -a "$LAIA_DIR/hermes-config/scripts/"  "$DEST/scripts/"  2>/dev/null
  [[ -d "$LAIA_DIR/hermes-config/hooks"    ]] && rsync -a "$LAIA_DIR/hermes-config/hooks/"    "$DEST/hooks/"    2>/dev/null
  [[ -f "$LAIA_DIR/hermes-config/ai-agents.json" ]] && cp "$LAIA_DIR/hermes-config/ai-agents.json" "$DEST/ai-agents.json"
  ok "hermes-config restaurado desde laia-infra"
else
  ok "hermes runtime ya existe — saltando restauración de config"
fi

# ── 4. Configurar hermes-agent ────────────────────────────────────────────────
step "4/6  Configurando hermes-agent"

if [[ ! -d "$HERMES_DIR" ]]; then
  err "hermes-agent no encontrado en $HERMES_DIR"
fi

# Añadir upstream NousResearch si no está
if ! git -C "$HERMES_DIR" remote | grep -q upstream; then
  git -C "$HERMES_DIR" remote add upstream https://github.com/NousResearch/hermes-agent.git
  ok "Remote upstream añadido (NousResearch)"
fi
ok "Remotes: origin=JorgeMP-3/hermes-agent, upstream=NousResearch/hermes-agent"

# Crear venv
if [[ ! -d "$HERMES_DIR/venv" ]]; then
  info "Creando entorno virtual Python..."
  python3 -m venv "$HERMES_DIR/venv"
fi

info "Instalando dependencias Python..."
source "$HERMES_DIR/venv/bin/activate"
pip install -e "$HERMES_DIR" -q --disable-pip-version-check
deactivate
ok "hermes-agent instalado"

# Symlink para que hermes use este directorio como instalación activa
if [[ ! -L "$DEST/hermes-agent" ]]; then
  ln -sf "$HERMES_DIR" "$DEST/hermes-agent"
  ok "Enlace simbólico ~/.hermes/hermes-agent → laia-infra/hermes-agent"
elif [[ "$(readlink "$DEST/hermes-agent")" != "$HERMES_DIR" ]]; then
  warn "~/.hermes/hermes-agent ya existe y apunta a otro lugar"
  info "Si quieres usarlo desde laia-infra: ln -sf $HERMES_DIR $DEST/hermes-agent"
else
  ok "Enlace simbólico ya configurado"
fi

# ── 5. Configurar workspace-ui ────────────────────────────────────────────────
step "5/6  Configurando workspace-ui"

if [[ -f "$UI_DIR/frontend/package.json" ]]; then
  info "Instalando dependencias npm..."
  npm install --prefix "$UI_DIR/frontend" -q
  ok "workspace-ui listo"
  if [[ ! -L "$DEST/workspace-ui" ]]; then
    ln -sf "$UI_DIR" "$DEST/workspace-ui"
    ok "Enlace simbólico ~/.hermes/workspace-ui → laia-infra/workspace-ui"
  fi
else
  warn "workspace-ui/frontend no encontrado, saltando"
fi

# ── 6. Config y SOUL ─────────────────────────────────────────────────────────
step "6/6  Configuración final"

if [[ ! -f "$DEST/SOUL.md" && -f "$LAIA_DIR/SOUL.md" ]]; then
  cp "$LAIA_DIR/SOUL.md" "$DEST/SOUL.md"
  ok "SOUL.md copiado a ~/.hermes/"
fi

if [[ ! -f "$DEST/config.yaml" && -f "$LAIA_DIR/config.template.yaml" ]]; then
  cp "$LAIA_DIR/config.template.yaml" "$DEST/config.yaml"
  ok "config.yaml creado en ~/.hermes/"
  warn "Edita ~/.hermes/config.yaml para añadir tus API keys"
else
  ok "config.yaml ya existe"
fi

# Instalar scripts de ~/bin
if [[ -d "$LAIA_DIR/bin" ]]; then
  mkdir -p "$HOME/bin"
  rsync -a "$LAIA_DIR/bin/" "$HOME/bin/"
  chmod +x "$HOME/bin/"* 2>/dev/null || true
  ok "Scripts de ~/bin instalados"
fi

# ── Configurar shell ──────────────────────────────────────────────────────────
ZSHRC="$HOME/.zshrc"
ZSHRC_BLOCK='
# LAIA — añadido por clone-laia
export PATH="$HOME/bin:$HOME/.local/bin:$PATH"

# Bloquea git init accidental en el home directory
git() {
  if [[ "$1" == "init" ]] && [[ "$PWD" == "$HOME" || "${2:-}" == "$HOME" || "${2:-}" == "~" ]]; then
    echo "⛔  git init bloqueado en el home directory (~)."
    echo "    Navega primero a tu proyecto: cd ~/code/mi-proyecto"
    return 1
  fi
  command git "$@"
}
'

if [[ -f "$ZSHRC" ]] && grep -q "LAIA — añadido por clone-laia" "$ZSHRC"; then
  ok "~/.zshrc ya configurado"
else
  echo "$ZSHRC_BLOCK" >> "$ZSHRC"
  ok "~/.zshrc actualizado con PATH y guard de git"
fi

# ── Resumen ───────────────────────────────────────────────────────────────────
echo ""
echo "${YEL}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RST}"
echo "${GRN}${BLD}  ✓ LAIA instalado correctamente${RST}"
echo "${YEL}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RST}"
echo ""
echo "  ${BLD}Ubicaciones:${RST}"
echo "  ${DIM}  laia-arch    → $LAIA_DIR${RST}"
echo "  ${DIM}  hermes-agent → $DEST/hermes-agent${RST}"
echo "  ${DIM}  workspace-ui → $DEST/workspace-ui${RST}"
echo ""

if [[ -f "$DEST/auth.json" ]]; then
  echo "  ${GRN}✓ auth.json encontrado — tokens restaurados${RST}"
else
  echo "  ${YEL}⚠  auth.json no encontrado${RST}"
  echo "  ${DIM}  Restaura desde USB: openssl enc -d -aes-256-cbc -pbkdf2 -iter 100000 \\${RST}"
  echo "  ${DIM}    -in laia-secrets-*.tar.gz | tar -xz -C ~/.hermes/${RST}"
  echo ""
fi

echo "  ${BLD}Próximos pasos:${RST}"
echo "  ${DIM}  1. Si no lo has hecho, restaura auth.json y config.yaml desde USB${RST}"
echo "  ${DIM}  2. Activa el agente: source $HERMES_DIR/venv/bin/activate && hermes${RST}"
echo "  ${DIM}  3. Inicia la UI:     cd $DEST/workspace-ui && ./start.sh${RST}"
echo "  ${DIM}  4. Recarga la shell: source ~/.zshrc${RST}"
echo ""
