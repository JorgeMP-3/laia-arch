#!/bin/bash
# laia-status — Vista unificada del estado de los servicios LAIA
# Uso: laia-status [--short] [--json] [--watch] [--logs N] [--service SVC]

set -uo pipefail

HERMES_HOME="${HERMES_HOME:-$HOME/LAIA}"
LOG_DIR="$HERMES_HOME/logs"
UI_PORT=8077

# ── colores (solo si stdout es TTY) ──────────────────────────────────────────
if [ -t 1 ]; then
  GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'
  CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'
else
  GREEN=''; YELLOW=''; RED=''; CYAN=''; BOLD=''; DIM=''; NC=''
fi

# ── parsing de argumentos ─────────────────────────────────────────────────────
MODE="full"
LOGS_N=0
SERVICE_FILTER=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --short) MODE="short"; shift ;;
    --json)  MODE="json";  shift ;;
    --watch) MODE="watch"; shift ;;
    --logs)
      shift
      if [[ $# -eq 0 || ! "$1" =~ ^[0-9]+$ ]]; then
        echo "Error: --logs requiere un número entero positivo" >&2; exit 2
      fi
      LOGS_N="$1"; shift ;;
    --service)
      shift
      if [[ $# -eq 0 ]]; then
        echo "Error: --service requiere un nombre de servicio" >&2; exit 2
      fi
      SERVICE_FILTER="$1"; shift ;;
    --help|-h)
      cat <<EOF
Uso: laia-status [OPCIONES]

Opciones:
  (sin args)        Vista completa de todos los servicios
  --short           Una línea por servicio
  --json            Output JSON para Hermes/scripts
  --watch           Actualizar cada 2s (Ctrl+C para salir)
  --logs N          Mostrar últimas N líneas de cada log
  --service SVC     Solo mostrar estado de un servicio

Servicios: hermes, workspace-ui, tui_gateway, claude-secondary, nginx, cloudflared

Ejemplos:
  laia-status
  laia-status --short
  laia-status --json
  laia-status --watch
  laia-status --service gateway --logs 20

Exit codes: 0=todo OK, 1=algún servicio en fallo, 2=uso incorrecto
EOF
      exit 0 ;;
    *)
      echo "Error: argumento desconocido: $1" >&2
      echo "Uso: laia-status [--short] [--json] [--watch] [--logs N] [--service SVC]" >&2
      exit 2 ;;
  esac
done

# ── utilidades ────────────────────────────────────────────────────────────────
format_uptime() {
  local s="${1:-0}"
  if (( s < 60 )); then
    echo "${s}s"
  elif (( s < 3600 )); then
    echo "$(( s / 60 ))m"
  elif (( s < 86400 )); then
    printf "%dh %dm" $(( s / 3600 )) $(( (s % 3600) / 60 ))
  else
    printf "%dd %dh" $(( s / 86400 )) $(( (s % 86400) / 3600 ))
  fi
}

systemd_uptime() {
  local unit="$1"
  local since epoch
  since=$(systemctl show "$unit" --property=ActiveEnterTimestamp --value 2>/dev/null) || return 0
  [[ -z "$since" || "$since" == "n/a" ]] && return 0
  epoch=$(date -d "$since" +%s 2>/dev/null) || return 0
  format_uptime $(( $(date +%s) - epoch ))
}

proc_uptime() {
  local pid="$1"
  [[ -z "$pid" ]] && return 0
  local s
  s=$(ps -o etimes= -p "$pid" 2>/dev/null | tr -d ' ') || return 0
  [[ -n "$s" ]] && format_uptime "$s"
}

log_size() {
  local f="$1"
  [[ -f "$f" ]] && du -sh "$f" 2>/dev/null | cut -f1 || echo "–"
}

json_str() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf '%s' "$s"
}

# ── checks de servicios ───────────────────────────────────────────────────────
# Cada check_* rellena: SVC_NAME SVC_STATUS SVC_DETAIL SVC_EXTRA SVC_PID SVC_UPTIME

check_hermes() {
  SVC_NAME="hermes.service"; SVC_PID=""; SVC_UPTIME=""; SVC_DETAIL=""; SVC_EXTRA=""
  if systemctl is-active --quiet hermes 2>/dev/null; then
    SVC_STATUS="ok"; SVC_DETAIL="activo"
    SVC_PID=$(systemctl show hermes --property=MainPID --value 2>/dev/null || true)
    [[ "$SVC_PID" == "0" ]] && SVC_PID=""
    SVC_UPTIME=$(systemd_uptime hermes)
    SVC_EXTRA="uptime: $SVC_UPTIME"
    [[ -n "$SVC_PID" ]] && SVC_EXTRA="PID $SVC_PID, $SVC_EXTRA"
  else
    SVC_STATUS="fail"; SVC_DETAIL="inactivo"
    SVC_EXTRA="ver: journalctl -u hermes -n 20"
  fi
}

check_workspace_ui() {
  SVC_NAME="workspace-ui"; SVC_PID=""; SVC_UPTIME=""; SVC_DETAIL=""; SVC_EXTRA=""
  SVC_PID=$(lsof -ti:"$UI_PORT" 2>/dev/null | head -1 || true)
  if [[ -n "$SVC_PID" ]]; then
    SVC_STATUS="ok"; SVC_DETAIL=":$UI_PORT"
    SVC_UPTIME=$(proc_uptime "$SVC_PID")
    SVC_EXTRA="PID $SVC_PID"
    [[ -n "$SVC_UPTIME" ]] && SVC_EXTRA="$SVC_EXTRA, uptime: $SVC_UPTIME"
  else
    SVC_STATUS="fail"; SVC_DETAIL="inactivo"
    SVC_EXTRA="no escucha en :$UI_PORT"
  fi
}

check_tui_gateway() {
  SVC_NAME="tui_gateway"; SVC_PID=""; SVC_UPTIME=""; SVC_DETAIL=""; SVC_EXTRA=""
  local count
  count=$(pgrep -c -f "tui_gateway" 2>/dev/null || echo 0)
  if [[ "$count" -gt 0 ]]; then
    SVC_STATUS="ok"; SVC_DETAIL="activo"
    SVC_PID=$(pgrep -f "tui_gateway" 2>/dev/null | head -1 || true)
    SVC_UPTIME=$(proc_uptime "$SVC_PID")
    SVC_EXTRA="${count} proceso(s)"
    [[ -n "$SVC_UPTIME" ]] && SVC_EXTRA="$SVC_EXTRA, uptime: $SVC_UPTIME"
  else
    SVC_STATUS="warn"; SVC_DETAIL="no corriendo"; SVC_EXTRA=""
  fi
}

check_claude_secondary() {
  SVC_NAME="claude-secondary"; SVC_PID=""; SVC_UPTIME=""; SVC_DETAIL=""; SVC_EXTRA=""
  if ! command -v docker >/dev/null 2>&1; then
    SVC_STATUS="warn"; SVC_DETAIL="docker N/A"; SVC_EXTRA="docker no instalado"
    return
  fi
  local cstatus
  cstatus=$(docker ps --filter "name=claude-secondary" --format "{{.Status}}" 2>/dev/null | head -1 || true)
  if [[ -n "$cstatus" ]]; then
    SVC_STATUS="ok"; SVC_DETAIL="Docker activo"; SVC_EXTRA="$cstatus"
  else
    local astatus
    astatus=$(docker ps -a --filter "name=claude-secondary" --format "{{.Status}}" 2>/dev/null | head -1 || true)
    if [[ -n "$astatus" ]]; then
      SVC_STATUS="fail"; SVC_DETAIL="contenedor parado"; SVC_EXTRA="$astatus"
    else
      SVC_STATUS="fail"; SVC_DETAIL="no encontrado"; SVC_EXTRA="contenedor docker no existe"
    fi
  fi
}

check_nginx() {
  SVC_NAME="nginx"; SVC_PID=""; SVC_UPTIME=""; SVC_DETAIL=""; SVC_EXTRA=""
  if systemctl is-active --quiet nginx 2>/dev/null; then
    SVC_STATUS="ok"; SVC_DETAIL="activo"
    SVC_UPTIME=$(systemd_uptime nginx)
    [[ -n "$SVC_UPTIME" ]] && SVC_EXTRA="uptime: $SVC_UPTIME" || SVC_EXTRA=""
  elif pgrep -x nginx >/dev/null 2>&1; then
    SVC_STATUS="ok"; SVC_DETAIL="activo (proc)"
    SVC_PID=$(pgrep -x nginx | head -1)
    SVC_UPTIME=$(proc_uptime "$SVC_PID")
    [[ -n "$SVC_UPTIME" ]] && SVC_EXTRA="uptime: $SVC_UPTIME" || SVC_EXTRA=""
  else
    SVC_STATUS="warn"; SVC_DETAIL="no corriendo"; SVC_EXTRA=""
  fi
}

check_cloudflared() {
  SVC_NAME="cloudflared"; SVC_PID=""; SVC_UPTIME=""; SVC_DETAIL=""; SVC_EXTRA=""
  if systemctl is-active --quiet cloudflared 2>/dev/null; then
    SVC_STATUS="ok"; SVC_DETAIL="activo"
    SVC_UPTIME=$(systemd_uptime cloudflared)
    [[ -n "$SVC_UPTIME" ]] && SVC_EXTRA="uptime: $SVC_UPTIME" || SVC_EXTRA=""
  elif pgrep -x cloudflared >/dev/null 2>&1; then
    SVC_STATUS="ok"; SVC_DETAIL="activo (proc)"
    SVC_PID=$(pgrep -x cloudflared | head -1)
    SVC_UPTIME=$(proc_uptime "$SVC_PID")
    [[ -n "$SVC_UPTIME" ]] && SVC_EXTRA="uptime: $SVC_UPTIME" || SVC_EXTRA=""
  else
    SVC_STATUS="warn"; SVC_DETAIL="no corriendo"; SVC_EXTRA=""
  fi
}

# ── recolección de estado ─────────────────────────────────────────────────────
SVC_IDS=(hermes workspace-ui tui_gateway claude-secondary nginx cloudflared)
SVC_FNS=(check_hermes check_workspace_ui check_tui_gateway check_claude_secondary check_nginx check_cloudflared)

COL_NAME=(); COL_STATUS=(); COL_DETAIL=(); COL_EXTRA=()
OVERALL_OK=true

svc_filter_match() {
  local id="$1" filter="$2"
  [[ -z "$filter" ]] && return 0
  [[ "$id" == *"$filter"* ]] && return 0
  return 1
}

collect_all() {
  COL_NAME=(); COL_STATUS=(); COL_DETAIL=(); COL_EXTRA=()
  OVERALL_OK=true
  local i
  for i in "${!SVC_IDS[@]}"; do
    local id="${SVC_IDS[$i]}"
    svc_filter_match "$id" "$SERVICE_FILTER" || continue
    "${SVC_FNS[$i]}"
    COL_NAME+=("$SVC_NAME")
    COL_STATUS+=("$SVC_STATUS")
    COL_DETAIL+=("$SVC_DETAIL")
    COL_EXTRA+=("$SVC_EXTRA")
    [[ "$SVC_STATUS" == "fail" ]] && OVERALL_OK=false
  done
}

# ── renderizado ───────────────────────────────────────────────────────────────
print_svc_line() {
  local status="$1" name="$2" detail="$3" extra="$4"
  local ic ic_color
  case "$status" in
    ok)   ic="✓"; ic_color="$GREEN" ;;
    warn) ic="─"; ic_color="$YELLOW" ;;
    fail) ic="✗"; ic_color="$RED" ;;
    *)    ic="?"; ic_color="$DIM" ;;
  esac
  printf "  "
  echo -en "${ic_color}${ic}${NC}"
  printf "  %-20s %-14s" "$name" "$detail"
  if [[ -n "$extra" ]]; then
    echo -e "  ${DIM}($extra)${NC}"
  else
    echo ""
  fi
}

render_full() {
  echo ""
  echo -e "${BOLD}LAIA Status — $(date '+%Y-%m-%d %H:%M:%S')${NC}"
  echo -e "${DIM}────────────────────────────────────────${NC}"
  local i
  for i in "${!COL_NAME[@]}"; do
    print_svc_line "${COL_STATUS[$i]}" "${COL_NAME[$i]}" "${COL_DETAIL[$i]}" "${COL_EXTRA[$i]}"
  done
  echo -e "${DIM}  ──${NC}"
  if [[ -d "$LOG_DIR" ]]; then
    local gs us
    gs=$(log_size "$LOG_DIR/gateway.log")
    us=$(log_size "$LOG_DIR/workspace-ui.log")
    echo -e "  ${DIM}Logs: $LOG_DIR/ (gateway: $gs, ui: $us)${NC}"
  fi
  echo ""
}

render_short() {
  local i
  for i in "${!COL_NAME[@]}"; do
    print_svc_line "${COL_STATUS[$i]}" "${COL_NAME[$i]}" "${COL_DETAIL[$i]}" "${COL_EXTRA[$i]}"
  done
}

render_json() {
  local ts overall
  ts=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
  $OVERALL_OK && overall="ok" || overall="degraded"

  printf '{\n'
  printf '  "timestamp": "%s",\n' "$ts"
  printf '  "overall": "%s",\n' "$overall"
  printf '  "services": [\n'

  local i last
  last=$(( ${#COL_NAME[@]} - 1 ))
  for i in "${!COL_NAME[@]}"; do
    local comma=","
    [[ $i -eq $last ]] && comma=""
    printf '    {\n'
    printf '      "name": "%s",\n'   "$(json_str "${COL_NAME[$i]}")"
    printf '      "status": "%s",\n' "$(json_str "${COL_STATUS[$i]}")"
    printf '      "detail": "%s",\n' "$(json_str "${COL_DETAIL[$i]}")"
    printf '      "extra": "%s"\n'   "$(json_str "${COL_EXTRA[$i]}")"
    printf '    }%s\n' "$comma"
  done

  printf '  ]\n'
  printf '}\n'
}

show_logs() {
  [[ "$LOGS_N" -le 0 ]] && return

  local log_entries=(
    "gateway:$LOG_DIR/gateway.log"
    "workspace-ui:$LOG_DIR/workspace-ui.log"
    "agent:$LOG_DIR/agent.log"
    "errors:$LOG_DIR/errors.log"
  )

  for entry in "${log_entries[@]}"; do
    local label="${entry%%:*}"
    local file="${entry#*:}"
    if [[ -n "$SERVICE_FILTER" ]]; then
      svc_filter_match "$label" "$SERVICE_FILTER" || continue
    fi
    if [[ -f "$file" ]]; then
      echo -e "\n${BOLD}${CYAN}── Logs: $label (últimas $LOGS_N líneas) ──${NC}"
      tail -n "$LOGS_N" "$file"
    fi
  done
}

# ── main ──────────────────────────────────────────────────────────────────────
run_once() {
  collect_all
  case "$MODE" in
    full|watch) render_full ;;
    short)      render_short ;;
    json)       render_json; return ;;
  esac
  show_logs
}

if [[ "$MODE" == "watch" ]]; then
  if ! [ -t 1 ]; then
    echo "Error: --watch requiere un terminal interactivo (TTY)" >&2
    exit 2
  fi
  trap 'echo ""; exit 0' INT TERM
  while true; do
    clear
    run_once
    sleep 2
  done
else
  run_once
  $OVERALL_OK && exit 0 || exit 1
fi
