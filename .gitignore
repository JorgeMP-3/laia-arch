# LAIA .gitignore — 2026-05-13

# Secrets (in ~/.laia/, symlinked here)
auth.json
auth.lock
.env
config.yaml
config.yaml*

# Runtime state (moved to ~/.laia/)
state.db*
response_store.db*
gateway.pid
gateway.lock
gateway_state.json
processes.json
channel_directory.json
workspace.db*
workspace-ui-session-areas.json
.laia_history
.skills_prompt_snapshot.json
.update_check
.clean_shutdown

# Runtime dirs (moved to ~/.laia/)
sessions/
logs/
backups/
checkpoints/
pastes/
cron/
memories/
sandboxes/
migration/
orchestrator-runs/
whatsapp/
pairing/

# Caches
cache/
audio_cache/
image_cache/
models_dev_cache.json
ollama_cloud_models_cache.json
context_length_cache.yaml

# Python
__pycache__/
*.py[cod]
*.egg-info/

# macOS
.DS_Store
._*

# Legacy archive (past versions)
archived/
archived-skills/

# Core (submodule or separate repo)
.laia-core/
# Excepción: la librería Atlas y su capa de compat son fuente del repo principal.
# (negar el directorio no re-incluye ficheros, así que se trackean con `git add -f`;
#  esta nota documenta que NO son artefactos generados.)

# UI (separate repo)
laia-ui/

# 3rd party services
mlx-servers/

# Workspace data
workspaces/

# Symlinks
hermes-agent
