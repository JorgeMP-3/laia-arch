<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Atlas v2 — Registry</title>
<style>
/* ─── Tokens ──────────────────────────────────────────────────────────── */
