# Atlas v2 — Registro Universal de Referencias LAIA  (PLANTILLA)
#
# Copia este fichero al home runtime de ARCH (layout v2: /srv/laia/arch) y
# ajústalo a tu host. Ubicación overridable con LAIA_CONFIG_HOME:
#
#     sudo install -d -o "$USER" -m750 /srv/laia/arch
#     cp infra/pathd/atlas.yaml.example /srv/laia/arch/atlas.yaml
#
# Es la fuente de verdad de todas las conexiones del ecosistema.
# Edita AQUÍ cuando algo cambie de sitio — el resto del código lo sigue.
#
# Tipos soportados: path | service | container | socket | env_file
# Interpolación: ${ref.<nombre>} para referenciar otra entrada.
# Override de emergencia: export ATLAS_<NOMBRE>=valor (gana sobre el YAML).
#
version: 2

refs:

  # ── Directorios base ──────────────────────────────────────────────────────

  laia_root:
    type: path
    value: ~/LAIA
    description: "Raíz del código fuente LAIA (desarrollo)"

  laia_home:
    type: path
    value: /srv/laia/arch
    description: "Home runtime de LAIA-ARCH (config.yaml, atlas.yaml, .env.paths, pathd.sock, state/; secrets en secrets/). Layout v2 — antes ~/.laia"

  laia_arch_home:
    type: path
    value: ~/LAIA-ARCH
    description: "Workspace interactivo de Jorge — workspaces, skills, memorias"

  srv_laia:
    type: path
    value: /srv/laia
    description: "Datos operacionales (agora.db, usuarios, estado persistente)"

  opt_laia:
    type: path
    value: /opt/laia
    description: "Código de producto instalado (laia-install, versionado)"

  # ── Subdirectorios del código fuente ─────────────────────────────────────

  laia_core:
    type: path
    value: ${ref.laia_root}/.laia-core
    description: "Motor del agente — 71 herramientas, gateway, CLI base"

  agora_backend:
    type: path
    value: ${ref.laia_root}/services/agora-backend
    description: "Backend LAIA-AGORA (FastAPI, API REST)"

  laia_executor:
    type: path
    value: ${ref.laia_root}/services/laia-executor
    description: "Executor del PA-AGORA (microservicio FastAPI :9091)"

  workspace_store:
    type: path
    value: ${ref.laia_root}/workspace_store
    description: "Librería compartida SQLite+FTS5 para workspaces"

  infra_dir:
    type: path
    value: ${ref.laia_root}/infra
    description: "Infraestructura — LXD, nginx, systemd, pathd"

  skills_dir:
    type: path
    value: ${ref.laia_root}/skills
    description: "Skills bundled con el producto (32 packs)"

  bin_dir:
    type: path
    value: ${ref.laia_root}/bin
    description: "Entry points CLI — laia, laia-install, laia-clone…"

  # ── Subdirectorios operacionales (/srv/laia) ──────────────────────────────

  srv_agora:
    type: path
    value: ${ref.srv_laia}/agora
    description: "Datos del backend AGORA — agora.db, .env, logs"

  srv_users:
    type: path
    value: ${ref.srv_laia}/users
    description: "Home de cada usuario (bind-mounted a sus containers)"

  srv_state:
    type: path
    value: ${ref.srv_laia}/state
    optional: true
    repair_hint: "sudo install -d -m755 /srv/laia/state"
    description: "Estado persistente del orquestador LXD (agents.json — se crea al provisionar el primer agent)"

  # ── Paths del laia-executor (refs nuevas Fase 1) ──────────────────────────
  # Marcadas optional: estos paths viven dentro del container del executor o
  # son parte del producto instalado en /opt/laia. En el host dev no existen.

  executor_token_file:
    type: path
    value: /etc/laia/executor-token
    optional: true
    description: "Bearer token para la API HTTP del executor (mode 0600, montado en el container)"

  executor_profile_file:
    type: path
    value: /etc/laia/agent.json
    optional: true
    description: "Agent profile JSON leído por el executor (slug, identidad — dentro del container)"

  executor_workspace_root:
    type: path
    value: /var/lib/laia/workspace
    optional: true
    description: "Base para workspaces privados por usuario en el executor (dentro del container)"

  executor_plugins_root:
    type: path
    value: ${ref.opt_laia}/plugins
    optional: true
    description: "Plugins root para laia-executor (LAIA_EXECUTOR_PLUGINS_ROOT — dentro del container)"

  workspace_store_lib:
    type: path
    value: ${ref.opt_laia}/lib
    optional: true
    description: "Path producción del paquete workspace_store (solo en /opt/laia instalado)"

  laia_process_log_dir:
    type: path
    value: /var/log/laia-processes
    optional: true
    description: "Logs stdout/stderr de procesos background del executor (dentro del container)"

  # ── Workspace interactivo de LAIA-ARCH ────────────────────────────────────

  arch_workspaces:
    type: path
    value: ${ref.laia_arch_home}/workspaces
    description: "Workspaces personales de Jorge"

  arch_skills:
    type: path
    value: ${ref.laia_arch_home}/skills
    description: "Skills personales de LAIA-ARCH"

  arch_memories:
    type: path
    value: ${ref.laia_arch_home}/memories
    description: "Memorias persistentes de LAIA-ARCH"

  # ── Servicios de red ──────────────────────────────────────────────────────

  agora_api:
    type: service
    host: 127.0.0.1
    port: 8000
    protocol: http
    health_path: /api/health
    optional: true
    repair_hint: "el backend vive DENTRO del container: curl http://$(lxc list laia-agora -c4 --format csv | awk '{print $1}'):8000/api/health"
    description: "API REST de LAIA-AGORA (auth JWT). Escucha en el container laia-agora:8000 — este check host-side solo ve localhost, por eso es optional (el 127.0.0.1:8088 anterior era topología pre-container)"

  executor_api:
    type: service
    host: agent-jorge-dev
    port: 9091
    protocol: http
    health_path: /health
    optional: true
    description: "Executor del PA-AGORA de Jorge (dentro de LXD)"

  # ── Servicios del gateway (.laia-core/gateway/platforms/) ─────────────────

  whatsapp_bridge:
    type: service
    host: 127.0.0.1
    port: 9000
    protocol: http
    optional: true
    description: "Puente Node.js de WhatsApp (port default; override WHATSAPP_BRIDGE_PORT)"

  signal_cli:
    type: service
    host: 127.0.0.1
    port: 8080
    protocol: http
    optional: true
    description: "Daemon signal-cli en modo HTTP"

  gateway_api:
    type: service
    host: 127.0.0.1
    port: 8642
    protocol: http
    optional: true
    description: "API OpenAI-compatible del gateway (.laia-core/gateway/platforms/api_server.py)"

  feishu_webhook:
    type: service
    host: 127.0.0.1
    port: 8765
    protocol: http
    optional: true
    description: "Receptor de webhooks de Feishu (Lark)"

  bluebubbles_webhook:
    type: service
    host: 127.0.0.1
    port: 8645
    protocol: http
    optional: true
    description: "Receptor de webhooks de BlueBubbles (iMessage)"

  # ── Contenedores LXD ─────────────────────────────────────────────────────

  agora_container:
    type: container
    value: laia-agora
    description: "Contenedor del cerebro centralizado (LAIA-AGORA)"

  jorge_container:
    type: container
    value: agent-jorge-dev
    optional: true
    repair_hint: "lxc start agent-jorge-dev"
    description: "Contenedor del PA-AGORA de Jorge (slug real: jorge-dev)"

  # ── Sockets Unix ─────────────────────────────────────────────────────────

  pathd_socket:
    type: socket
    value: ${ref.laia_home}/pathd.sock
    optional: true
    repair_hint: "sudo systemctl restart laia-pathd  (unit de sistema, no --user; tras el cutover v2 el socket converge aquí al reiniciar)"
    description: "Socket JSON-RPC del daemon laia-pathd (target v2; hasta el primer restart post-cutover puede seguir en ~/LAIA-ARCH/pathd.sock)"

  # ── Ficheros de env (secrets) ─────────────────────────────────────────────

  agora_env:
    type: env_file
    path: /srv/laia/agora/.env
    optional: true
    keys:
      - AGORA_DB_PATH
    repair_hint: "sudo install -d -m755 /srv/laia/agora && sudo touch /srv/laia/agora/.env && sudo chmod 600 /srv/laia/agora/.env"
    description: "Env del backend AGORA (dentro del contenedor). AGORA_JWT_SECRET ya NO se exige aquí: el backend lo auto-persiste (env -> fichero -> generar; config.py) — definir el env var solo para rotación controlada"
