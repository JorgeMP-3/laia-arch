#!/bin/bash
# laia-restart — Reinicia todos los servicios del agente LAIA
# Uso: laia-restart [--no-gateway] [--no-ui] [--status]

set -uo pipefail

HERMES_HOME="${HERMES_HOME:-$HOME/LAIA}"
VENV="$HERMES_HOME/.laia-arch/venv"
UI_DIR="$HERMES_HOME/.laia-arch/workspace-ui/backend"
LOG_DIR="$HERMES_HOME/logs"
UI_PORT=8077

# ── colores ────────────────────────────────────────────────────────────────────
if [ -t 1 ]; then
  GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'
  CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'
else
  GREEN=''; YELLOW=''; RED=''; CYAN=''; BOLD=''; DIM=''; NC=''
fi

ok()   { echo -e "  ${GREEN}✓${NC} $*"; }
warn() { echo -e "  ${YELLOW}→${NC} $*"; }
fail() { echo -e "  ${RED}✗${NC} $*"; }
step() { echo -e "\n${BOLD}${CYAN}$*${NC}"; }

# ── argumentos ────────────────────────────────────────────────────────────────
RESTART_GATEWAY=true
RESTART_UI=true
STATUS_ONLY=false

for arg in "$@"; do
  case "$arg" in
    --no-gateway) RESTART_GATEWAY=false ;;
    --no-ui)      RESTART_UI=false ;;
    --status)     STATUS_ONLY=true ;;
    --help|-h)
      echo "Uso: laia-restart [--no-gateway] [--no-ui] [--status]"
      echo "  --no-gateway  No reiniciar hermes.service"
      echo "  --no-ui       No reiniciar workspace-ui"
      echo "  --status      Solo mostrar estado actual, sin reiniciar"
      exit 0
      ;;
  esac
done

mkdir -p "$LOG_DIR"

# ── banner ─────────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}╔══════════════════════════════════════╗${NC}"
echo -e "${BOLD}║        LAIA — Reinicio de sistema    ║${NC}"
echo -e "${BOLD}╚══════════════════════════════════════╝${NC}"
echo -e "  ${DIM}$(date '+%Y-%m-%d %H:%M:%S')${NC}"

# ── modo solo-estado ───────────────────────────────────────────────────────────
if $STATUS_ONLY; then
  step "Estado actual"
  echo "  ─────────────────────────────────────"
  if systemctl is-active --quiet hermes 2>/dev/null; then
    ok "hermes.service: activo (gateway)"
  else
    fail "hermes.service: inactivo"
  fi
  if lsof -ti:$UI_PORT >/dev/null 2>&1; then
    ok "workspace-ui: activo en http://localhost:$UI_PORT"
  else
    warn "workspace-ui: no detectado en :$UI_PORT"
  fi
  if pgrep -f "tui_gateway.entry" >/dev/null 2>&1; then
    ok "tui_gateway: activo ($(pgrep -c -f 'tui_gateway' 2>/dev/null) procesos)"
  else
    warn "tui_gateway: no corriendo"
  fi
  echo ""
  exit 0
fi

# ── 1. hermes.service (gateway Telegram/plataformas) ──────────────────────────
step "1. Hermes Gateway (hermes.service)"
if $RESTART_GATEWAY; then
  _gateway_action="restart"
  systemctl is-active --quiet hermes 2>/dev/null || _gateway_action="start"

  if sudo systemctl "$_gateway_action" hermes 2>/dev/null; then
    sleep 2
    if systemctl is-active --quiet hermes; then
      ok "hermes.service ${_gateway_action}ado correctamente"
    else
      fail "hermes.service no arrancó (ver: sudo journalctl -u hermes -n 20)"
    fi
  else
    # sudo requirió contraseña o falló — instruir al usuario
    warn "Reinicio del gateway requiere contraseña:"
    echo -e "  ${DIM}→ sudo systemctl restart hermes${NC}"
    # El servicio probablemente sigue activo si ya estaba corriendo
    systemctl is-active --quiet hermes 2>/dev/null && warn "hermes.service sigue activo (no se reinició)" || fail "hermes.service no está activo"
  fi
else
  warn "Saltando hermes.service (--no-gateway)"
fi

# ── 2. Workspace UI (FastAPI en :8077) ────────────────────────────────────────
step "2. Workspace UI (http://localhost:$UI_PORT)"
if $RESTART_UI; then
  # Matar proceso existente en el puerto
  OLD_PID=$(lsof -ti:$UI_PORT 2>/dev/null || true)
  if [ -n "$OLD_PID" ]; then
    kill "$OLD_PID" 2>/dev/null || true
    sleep 1
    warn "proceso anterior (PID $OLD_PID) detenido"
  fi

  # Arrancar nuevo proceso
  if [ ! -f "$VENV/bin/uvicorn" ]; then
    fail "venv no encontrado: $VENV"
    warn "Ejecuta: cd $HERMES_HOME/.laia-arch && python -m venv venv && pip install -e ."
  elif [ ! -f "$UI_DIR/main.py" ]; then
    fail "main.py no encontrado: $UI_DIR"
  else
    cd "$UI_DIR"
    HERMES_HOME="$HERMES_HOME" \
    "$VENV/bin/uvicorn" main:app --host 0.0.0.0 --port $UI_PORT \
      > "$LOG_DIR/workspace-ui.log" 2>&1 &
    UI_PID=$!
    # Esperar hasta 6s a que el puerto esté activo
    for i in 1 2 3 4 5 6; do
      sleep 1
      lsof -ti:$UI_PORT >/dev/null 2>&1 && break
    done
    if lsof -ti:$UI_PORT >/dev/null 2>&1; then
      ok "workspace-ui arrancado en http://localhost:$UI_PORT (PID $UI_PID)"
      ok "log: $LOG_DIR/workspace-ui.log"
    else
      fail "workspace-ui no arrancó (PID $UI_PID)"
      warn "Ver: tail $LOG_DIR/workspace-ui.log"
    fi
  fi
else
  warn "Saltando workspace-ui (--no-ui)"
fi

# ── 3. Estado final ────────────────────────────────────────────────────────────
step "Estado final"
echo "  ─────────────────────────────────────"

GATEWAY_OK=false
UI_OK=false

if systemctl is-active --quiet hermes 2>/dev/null; then
  ok "hermes.service: activo"
  GATEWAY_OK=true
else
  fail "hermes.service: inactivo"
fi

if lsof -ti:$UI_PORT >/dev/null 2>&1; then
  ok "workspace-ui: http://localhost:$UI_PORT"
  UI_OK=true
else
  fail "workspace-ui: inactivo"
fi

if pgrep -f "tui_gateway.entry" >/dev/null 2>&1; then
  ok "tui_gateway: activo"
fi

echo ""
if $GATEWAY_OK && $UI_OK; then
  echo -e "  ${GREEN}${BOLD}Sistema LAIA operativo.${NC}"
else
  echo -e "  ${YELLOW}${BOLD}Algunos servicios no arrancaron. Revisa los logs.${NC}"
fi
echo ""
