#!/usr/bin/env bash
set -euo pipefail
# laia-backup: sistema de backups del servidor LAIA (D1, layout v2).
# Alcance del backup nocturno (`all`): agora.db + /srv/laia/users + /srv/laia/arch.
# Destino por defecto: /mnt/data/laia-backups (otro disco físico).
#
# Fail-loud contract: a missing, unreadable or empty artifact makes the command
# exit non-zero so the systemd unit goes red instead of reporting a false green
# (problems.md: backup-timer-runs-as-laia-arch-cannot-read-agora).

BOLD="\e[1m"; GREEN="\e[32m"; RED="\e[31m"; CYAN="\e[36m"; DIM="\e[2m"; RESET="\e[0m"
if [[ -z "${LAIA_ROOT:-}" ]]; then
  _script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  LAIA_ROOT="$(git -C "$_script_dir" rev-parse --show-toplevel 2>/dev/null || cd "$_script_dir/../.." && pwd)"
  unset _script_dir
fi
BACKUP_DIR="${LAIA_BACKUP_DIR:-/mnt/data/laia-backups}"
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
RETENTION_DEFAULT_DAYS=14

# Artifacts can contain production secrets (arch/secrets inside arch_*.tar.gz):
# never world-readable. New files 0600, backup dir kept 0700.
umask 077

# Set to 1 by any failed backup step; the script exits non-zero at the end.
FAILED=0

usage() {
    echo "uso: laia-backup <que>"
    echo ""
    echo "que:"
    echo "  agora       datos de AGORA (agora.db)"
    echo "  users       datos de usuarios (/srv/laia/users)"
    echo "  arch        runtime operacional del ARCH (/srv/laia/arch)"
    echo "  all         agora + users + arch (alcance del backup nocturno)"
    echo "  workspaces  todos los workspaces (workspace.db) — opt-in"
    echo "  agents      snapshots LXD de todos los agentes — opt-in (toca LXD)"
    echo "  list        listar backups existentes"
    echo "  clean N     borrar backups de hace mas de N dias (default $RETENTION_DEFAULT_DAYS)"
    exit 1
}

[[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]] && usage

what="$1"; shift
mkdir -p "$BACKUP_DIR"
# Best effort: read-only subcommands may run as a user that does not own the dir.
chmod 700 "$BACKUP_DIR" 2>/dev/null || true

backup_agora() {
    echo -e "${BOLD}AGORA DB...${RESET}"
    local agora_db="${AGORA_DB:-${LAIA_AGORA_DIR_OVERRIDE:-/srv/laia/agora}/agora.db}"
    local out="$BACKUP_DIR/agora_${TIMESTAMP}.db"
    if [[ ! -f "$agora_db" || ! -r "$agora_db" ]]; then
        echo -e "  ${RED}FAIL${RESET} no encontrado o ilegible: $agora_db"
        FAILED=1; return 0
    fi
    if command -v sqlite3 >/dev/null 2>&1 && head -c 16 "$agora_db" 2>/dev/null | grep -q 'SQLite format 3'; then
        # Live sqlite DB: use the online backup API for a consistent snapshot.
        # A plain cp of a hot DB can yield a torn copy that only fails on restore.
        if ! sqlite3 "$agora_db" ".backup '$out'"; then
            echo -e "  ${RED}FAIL${RESET} sqlite .backup: $agora_db"
            rm -f "$out"; FAILED=1; return 0
        fi
        local ic
        ic="$(sqlite3 "$out" 'PRAGMA integrity_check;' 2>&1 | head -1)"
        if [[ "$ic" != "ok" ]]; then
            echo -e "  ${RED}FAIL${RESET} integrity_check: $ic"
            rm -f "$out"; FAILED=1; return 0
        fi
    else
        # Not a sqlite file (e.g. test fixture) or sqlite3 missing: plain copy.
        echo -e "  ${DIM}copia plana (sqlite3 ausente u origen no-sqlite)${RESET}"
        if ! cp "$agora_db" "$out"; then
            echo -e "  ${RED}FAIL${RESET} cp: $agora_db"
            FAILED=1; return 0
        fi
    fi
    if [[ ! -s "$out" ]]; then
        echo -e "  ${RED}FAIL${RESET} artefacto vacio: $out"
        FAILED=1; return 0
    fi
    echo -e "  ${GREEN}OK${RESET} agora_${TIMESTAMP}.db ($(du -h "$out" | cut -f1))"
}

# _backup_tree <label> <src_dir> <prefix> — tar.gz a $prefix_<ts>.tar.gz (origen intacto).
_backup_tree() {
    local label="$1" src="$2" prefix="$3"
    echo -e "${BOLD}${label}...${RESET}"
    if [[ ! -d "$src" ]]; then
        echo -e "  ${RED}FAIL${RESET} no encontrado: $src"
        FAILED=1; return 0
    fi
    local out="$BACKUP_DIR/${prefix}_${TIMESTAMP}.tar.gz"
    local rc=0
    tar -czf "$out" -C "$(dirname "$src")" "$(basename "$src")" || rc=$?
    # tar exit 1 = "file changed as we read it" (live tree): artifact is still
    # complete enough for a nightly snapshot — warn, don't fail. >=2 is fatal.
    if [[ "$rc" -ge 2 ]]; then
        echo -e "  ${RED}FAIL${RESET} tar (exit $rc): $src"
        rm -f "$out"; FAILED=1; return 0
    elif [[ "$rc" -eq 1 ]]; then
        echo -e "  ${DIM}aviso: ficheros cambiaron durante el tar (arbol vivo)${RESET}"
    fi
    if [[ ! -s "$out" ]]; then
        echo -e "  ${RED}FAIL${RESET} artefacto vacio: $out"
        FAILED=1; return 0
    fi
    echo -e "  ${GREEN}OK${RESET} ${prefix}_${TIMESTAMP}.tar.gz ($(du -h "$out" | cut -f1))"
}

backup_users() { _backup_tree "Usuarios"     "${LAIA_USERS_DIR_OVERRIDE:-/srv/laia/users}" "users"; }
backup_arch()  { _backup_tree "ARCH runtime" "${LAIA_ARCH_DIR_OVERRIDE:-/srv/laia/arch}"   "arch";  }

backup_workspaces() {
    echo -e "${BOLD}Workspaces...${RESET}"
    local ws_root="$LAIA_ROOT/workspaces"
    [[ -d "$ws_root" ]] || { echo -e "  ${DIM}no encontrado: $ws_root${RESET}"; return 0; }
    for ws_dir in "$ws_root"/*/; do
        [[ -d "$ws_dir" ]] || continue
        local ws_name; ws_name=$(basename "$ws_dir")
        local db="$ws_dir/workspace.db"
        if [[ -f "$db" ]]; then
            cp "$db" "$BACKUP_DIR/${ws_name}_${TIMESTAMP}.db" && \
                echo -e "  ${GREEN}OK${RESET} $ws_name" || \
                echo -e "  ${RED}FAIL${RESET} $ws_name"
        fi
    done
}

backup_agents() {
    echo -e "${BOLD}Agentes LXD...${RESET}"
    if ! command -v lxc &>/dev/null; then
        echo -e "  ${RED}LXD no disponible${RESET}"; return 0
    fi
    for name in $(lxc list --format csv 2>/dev/null | cut -d',' -f1 | grep '^laia-'); do
        lxc snapshot "$name" "backup-${TIMESTAMP}" 2>/dev/null && \
            echo -e "  ${GREEN}OK${RESET} $name" || \
            echo -e "  ${RED}FAIL${RESET} $name"
    done
}

list_backups() {
    echo -e "${BOLD}Backups en $BACKUP_DIR${RESET}"
    if [[ -d "$BACKUP_DIR" ]]; then
        ls -lh "$BACKUP_DIR" | tail -n +2
    else
        echo -e "  ${DIM}vacio${RESET}"
    fi
}

clean_backups() {
    local days="${1:-$RETENTION_DEFAULT_DAYS}"
    echo -e "${BOLD}Limpiando backups > $days dias...${RESET}"
    find "$BACKUP_DIR" -type f -mtime "+$days" -delete -print 2>/dev/null | while read -r f; do
        echo "  borrado: $(basename "$f")"
    done
    echo -e "  ${GREEN}OK${RESET}"
}

case "$what" in
    agora)      backup_agora ;;
    users)      backup_users ;;
    arch)       backup_arch ;;
    workspaces) backup_workspaces ;;
    agents)     backup_agents ;;
    all)
        echo -e "${BOLD}${CYAN}=== BACKUP ${TIMESTAMP} ===${RESET}"
        backup_agora
        backup_users
        backup_arch
        if [[ "$FAILED" -ne 0 ]]; then
            echo -e "\n${RED}BACKUP INCOMPLETO${RESET} — revisa los FAIL de arriba"
        else
            echo -e "\n${GREEN}Backups en: $BACKUP_DIR${RESET}"
        fi
        ;;
    list)       list_backups ;;
    clean)      clean_backups "${1:-$RETENTION_DEFAULT_DAYS}" ;;
    *)          usage ;;
esac

# Fail-loud: any failed step above turns the whole run (and the systemd unit) red.
[[ "$FAILED" -eq 0 ]] || exit 1
