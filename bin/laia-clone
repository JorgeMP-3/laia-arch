#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# laia-clone — pull LAIA state from an old server into this new server.
#
# This command runs on the destination and pulls from --source user@old-host.
# It installs LAIA first when /opt/laia is missing, rsyncs portable bind-mount
# data, then rebuilds containers locally for the destination architecture.
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
LAIA_ROOT="$(dirname "$SCRIPT_DIR")"
LIB_DIR="$LAIA_ROOT/infra/installer/lib"

# shellcheck source=../infra/installer/lib/common.sh
source "$LIB_DIR/common.sh"
# shellcheck source=../infra/installer/lib/sudo.sh
source "$LIB_DIR/sudo.sh"
# shellcheck source=../infra/installer/lib/system.sh
source "$LIB_DIR/system.sh"
# shellcheck source=../infra/installer/lib/version.sh
source "$LIB_DIR/version.sh"
# shellcheck source=../infra/installer/lib/install.sh
source "$LIB_DIR/install.sh"
# shellcheck source=../infra/installer/lib/release.sh
source "$LIB_DIR/release.sh"
# shellcheck source=../infra/installer/lib/bootstrap.sh
source "$LIB_DIR/bootstrap.sh"
# shellcheck source=../infra/installer/lib/factory.sh
source "$LIB_DIR/factory.sh"
# shellcheck source=../infra/installer/lib/clone.sh
source "$LIB_DIR/clone.sh"

# ─── Options ────────────────────────────────────────────────────────────────
OPT_SOURCE=""
OPT_SOURCE_DIR=""
OPT_YES=false
OPT_DRY_RUN=false
OPT_WITH_TOOLS=false
OPT_NO_LXD=false
OPT_ONLY_AGENT=""
OPT_KEEP_SESSION=false
OPT_BWLIMIT=""
OPT_BWLIMIT_FILE=""
OPT_SSH_PASS_FILE=""
OPT_PREFLIGHT_ONLY=false
OPT_RESUME=false

# Strict patterns used by validate_options() to reject shell metacharacters
# that could otherwise be injected via the wizard's user input fields.
LAIA_BWLIMIT_RE='^[0-9]+[KMG]?$'
# user@host: user is POSIX-ish, host accepts DNS names, IPv4, and IPv6 in
# brackets. Putting `]` right after `[` makes it a literal `]` in the class;
# `-` at the end is literal too. We deliberately do NOT allow whitespace or
# shell metacharacters like ; | & $ ( ) < > \ ' " etc.
LAIA_SOURCE_RE='^[A-Za-z0-9_.-]+@[]A-Za-z0-9_.:[-]+$'

print_help() {
  cat <<'EOF'
laia-clone — pull LAIA state from an old server

USAGE
    sudo laia-clone --source <user@old-host> [OPTIONS]
    laia-clone --source-dir <path> [OPTIONS]
    sudo laia clone --source <user@old-host> [OPTIONS]

ARGUMENTS
    --source <user@host>  SSH source server to pull from. SSH keys are used
                          first; if they fail, laia-clone asks for password.

OPTIONS
    --source-dir PATH     Use a local directory as the source instead of SSH.
                          Expected layout: <PATH>/{agora,users,arch,home}/
                          Useful for migrations on the same machine and tests.
    --keep-session        Also clone admin-session.json. Default is to require
                          a fresh login on the destination.
    --bwlimit LIMIT       Pass rsync --bwlimit (digits with optional K/M/G
                          suffix, e.g. 50M). Strictly validated; values with
                          shell metacharacters are rejected with exit 2.
    --bwlimit-file PATH   Read the bwlimit value from a file (same format).
                          Useful when invoked from the wizard, to avoid
                          surfacing user input on the command line. The
                          file is consumed (unlinked) after reading.
    --ssh-pass-file PATH  Read the SSH password from a mode-0600 file,
                          unlink it immediately, and use sshpass. Intended
                          for laia-wizard password mode; avoids password argv.
    --with-tools          Also clone personal CLI configs (Claude Code, Codex,
                          OpenCode, .gitconfig, .pm2, .docker)
    --no-lxd              Compatibility no-op; containers are rebuilt locally.
    --only-agent <slug>   Rebuild only this agent container after data import.
    --preflight-only      Stop after source/destination checks.
    --resume              Skip phases whose target already looks complete
                          (agora.db with >= 20 tables → skip rsync agora).
                          Use this when reattempting after a failed run.
    --yes, -y             Non-interactive mode
    --dry-run             Print plan, don't transfer anything
    --json-progress       Emit machine-readable JSON event lines to stdout
                          for laia-wizard to render. Human log is unchanged.
    --help, -h            Show this help

PRE-CONDITIONS
    - Run this on the destination server. If /opt/laia is missing, laia-clone
      invokes laia-install --minimal first.
    - SSH access to <user@host> by key or password (when not using --source-dir)

EXAMPLES
    sudo laia-clone --source laia-hermes@old.example.com --yes
    sudo laia-clone --source jorge@10.0.0.5 --bwlimit=50M
    laia-clone --source-dir /mnt/backup/laia-snapshot-2026-05-20 --with-tools

EXIT CODES
    0   Success
    1   Generic failure
    2   Bad arguments / unsafe values
    3   SSH unreachable / pre-condition violated
    4   Operation timed out
    5   Network failure / rsync mid-transfer error
    6   Post-clone health check failed
EOF
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)       print_help; exit 0 ;;
      --source)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--source requires user@host" 2
        OPT_SOURCE="$2"; shift 2 ;;
      --source-dir)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--source-dir requires PATH" 2
        OPT_SOURCE_DIR="$(readlink -f "$2")"; shift 2 ;;
      --keep-session)  OPT_KEEP_SESSION=true; shift ;;
      --bwlimit)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--bwlimit requires LIMIT" 2
        OPT_BWLIMIT="$2"; shift 2 ;;
      --bwlimit=*)
        OPT_BWLIMIT="${1#--bwlimit=}"; shift ;;
      --bwlimit-file)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--bwlimit-file requires PATH" 2
        OPT_BWLIMIT_FILE="$2"; shift 2 ;;
      --ssh-pass-file)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--ssh-pass-file requires PATH" 2
        OPT_SSH_PASS_FILE="$2"; shift 2 ;;
      --json-progress)
        export LAIA_JSON_PROGRESS=1
        shift ;;
      --with-tools)    OPT_WITH_TOOLS=true; shift ;;
      --no-lxd)        OPT_NO_LXD=true; shift ;;
      --preflight-only) OPT_PREFLIGHT_ONLY=true; shift ;;
      --resume)         OPT_RESUME=true; shift ;;
      --only-agent)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--only-agent requires SLUG" 2
        OPT_ONLY_AGENT="$2"; shift 2 ;;
      -y|--yes)        OPT_YES=true; export LAIA_NONINTERACTIVE=true; shift ;;
      --dry-run)       OPT_DRY_RUN=true; shift ;;
      -*) die "Unknown option: $1 (use --help)" 2 ;;
      *)
        if [[ -z "$OPT_SOURCE" ]]; then
          OPT_SOURCE="$1"; shift
        else
          die "Multiple source hosts given; only one allowed: $OPT_SOURCE vs $1" 2
        fi
        ;;
    esac
  done

  if [[ -z "$OPT_SOURCE" && -z "$OPT_SOURCE_DIR" ]]; then
    print_help
    die "Specify either <user@host> or --source-dir PATH" 2
  fi
  if [[ -n "$OPT_SOURCE" && -n "$OPT_SOURCE_DIR" ]]; then
    die "Cannot combine <user@host> and --source-dir (got: $OPT_SOURCE + $OPT_SOURCE_DIR)" 2
  fi
  if [[ -n "$OPT_SOURCE" && "$OPT_SOURCE" != *@* ]]; then
    die "Source must be user@host (got: $OPT_SOURCE)" 2
  fi
}

# resolve_bwlimit_file — read --bwlimit-file content into OPT_BWLIMIT and
# unlink immediately. Rejected when both --bwlimit and --bwlimit-file are
# given (silent disagreement is worse than an explicit error).
resolve_bwlimit_file() {
  [[ -z "$OPT_BWLIMIT_FILE" ]] && return 0
  if [[ -n "$OPT_BWLIMIT" ]]; then
    die "Cannot combine --bwlimit and --bwlimit-file" 2
  fi
  if [[ ! -f "$OPT_BWLIMIT_FILE" ]]; then
    die "--bwlimit-file not found: $OPT_BWLIMIT_FILE" 2
  fi
  OPT_BWLIMIT="$(< "$OPT_BWLIMIT_FILE")"
  OPT_BWLIMIT="${OPT_BWLIMIT%$'\n'}"
  rm -f "$OPT_BWLIMIT_FILE" 2>/dev/null || true
  OPT_BWLIMIT_FILE=""
}

# resolve_ssh_pass_file — read --ssh-pass-file, move it into a private
# directory under /run, and switch the clone transport into sshpass mode.
#
# Security note: we deliberately do NOT export SSHPASS to the env. The
# previous implementation did, which made the password visible in `ps -e`
# (and any debug log that dumped the environment) for the lifetime of the
# laia-clone process. Instead, we keep the password in a 0600 file owned
# by root and pass `-f <path>` to every sshpass invocation. sshpass reads
# the file directly without exporting it.
#
# The file lives under /run/laia-clone-$$ (tmpfs, root-only) and is
# unlinked + dir-removed in clone_cleanup_sshpass_file (called from the
# EXIT trap installed in main()).
CLONE_SSHPASS_FILE=""
resolve_ssh_pass_file() {
  [[ -z "$OPT_SSH_PASS_FILE" ]] && return 0
  if [[ ! -f "$OPT_SSH_PASS_FILE" ]]; then
    die "--ssh-pass-file not found: $OPT_SSH_PASS_FILE" 2
  fi
  if [[ ! -r "$OPT_SSH_PASS_FILE" ]]; then
    die "--ssh-pass-file not readable: $OPT_SSH_PASS_FILE" 2
  fi

  local content
  content="$(< "$OPT_SSH_PASS_FILE")"
  content="${content%$'\n'}"
  rm -f "$OPT_SSH_PASS_FILE" 2>/dev/null || true
  OPT_SSH_PASS_FILE=""

  if [[ -z "$content" ]]; then
    die "--ssh-pass-file is empty" 2
  fi

  # Relocate the secret into a private root-only dir. /run is tmpfs on
  # systemd hosts; /tmp is the fallback on minimal images. mktemp -p
  # picks the first writable one.
  local secret_dir
  for candidate in /run /var/run /tmp; do
    if [[ -d "$candidate" && -w "$candidate" ]]; then
      secret_dir="$candidate"
      break
    fi
  done
  : "${secret_dir:=/tmp}"

  local dir
  dir="$(mktemp -d "$secret_dir/laia-clone-XXXXXX")"
  chmod 700 "$dir"
  CLONE_SSHPASS_FILE="$dir/sshpass"
  (umask 077 && printf '%s' "$content" > "$CLONE_SSHPASS_FILE")
  chmod 600 "$CLONE_SSHPASS_FILE"
  unset content

  export CLONE_SSHPASS_FILE
  CLONE_SSH_USE_PASSWORD=true

  # Fail here, before source checks, if sshpass cannot be made available.
  clone_ensure_sshpass
}

# Called from EXIT trap to scrub the secret file even on crash.
clone_cleanup_sshpass_file() {
  if [[ -n "${CLONE_SSHPASS_FILE:-}" ]]; then
    rm -f "$CLONE_SSHPASS_FILE" 2>/dev/null || true
    rmdir "$(dirname "$CLONE_SSHPASS_FILE")" 2>/dev/null || true
  fi
}

# validate_options — reject any user-supplied value that has shell
# metacharacters or otherwise fails the strict regex. Runs before any
# command line construction so rsync / ssh never see hostile input.
validate_options() {
  if [[ -n "$OPT_BWLIMIT" && ! "$OPT_BWLIMIT" =~ $LAIA_BWLIMIT_RE ]]; then
    die "Invalid --bwlimit value: '$OPT_BWLIMIT' (expected NUMBER[K|M|G])" 2
  fi
  if [[ -n "$OPT_SOURCE" && ! "$OPT_SOURCE" =~ $LAIA_SOURCE_RE ]]; then
    die "Invalid --source value: '$OPT_SOURCE' (rejected: contains characters that aren't safe for SSH)" 2
  fi
  if [[ -n "$OPT_ONLY_AGENT" && ! "$OPT_ONLY_AGENT" =~ ^[A-Za-z0-9_.-]+$ ]]; then
    die "Invalid --only-agent slug: '$OPT_ONLY_AGENT'" 2
  fi
}

# Copia los wrappers bin/ del repo (rama actual) sobre los binarios
# instalados en /opt/laia-vX.Y.Z/bin/. Idempotente; barato (5 archivos
# pequeños). Útil cuando la instalación ya existe pero el dev tree tiene
# fixes en el dispatcher que queremos surtir efecto sin re-correr release.
_clone_refresh_bin_wrappers() {
  local installed_bin
  local prefix
  prefix="$(inst_install_prefix)"
  installed_bin="$(readlink -f "$prefix" 2>/dev/null)/bin"
  if [[ -z "$installed_bin" || ! -d "$installed_bin" ]]; then
    return 0  # no hay nada que refrescar
  fi
  log_info "  refrescando wrappers bin/ → $installed_bin"
  local f
  for f in laia laia-install laia-clone laia-release laia-rollback; do
    if [[ -f "$LAIA_ROOT/bin/$f" ]]; then
      if inst_is_override_mode; then
        install -m 0755 "$LAIA_ROOT/bin/$f" "$installed_bin/$f"
      else
        sudo install -m 0755 "$LAIA_ROOT/bin/$f" "$installed_bin/$f"
      fi
    fi
  done
}

clone_install_first_if_needed() {
  local prefix root
  prefix="$(inst_install_prefix)"
  root="$(inst_install_root)"

  # Detect a partial / broken install in any of these shapes:
  #   1) $prefix is a regular dir (not a symlink) — corruption.
  #   2) $prefix is a symlink but its target lacks .laia-core.
  #   3) $prefix doesn't exist but versioned `laia-v*` dirs are lying
  #      around from a previous failed attempt → `laia-install` would
  #      then abort with "Version already installed".
  # In any of those cases, wipe the install root so install-first restarts clean.
  local needs_clean=false
  if [[ -e "$prefix" ]]; then
    if [[ ! -L "$prefix" ]]; then
      needs_clean=true
    else
      local target
      target="$(readlink -f "$prefix" 2>/dev/null || true)"
      [[ -z "$target" || ! -d "$target/.laia-core" ]] && needs_clean=true
    fi
  else
    # Symlink missing — check for orphan versioned dirs (laia-v*).
    shopt -s nullglob
    local orphans=( "$root"/laia-v* )
    shopt -u nullglob
    [[ "${#orphans[@]}" -gt 0 ]] && needs_clean=true
  fi

  if [[ "$needs_clean" == true ]]; then
    log_warn "Partial /opt/laia install detected (orphan versioned dirs or broken symlink) — cleaning up"
    if inst_is_override_mode; then
      rm -rf "$prefix" "$root"/laia-v*
    else
      sudo rm -rf "$prefix" "$root"/laia-v*
    fi
  fi

  if inst_is_override_mode && [[ -z "${LAIA_INSTALL_ROOT_OVERRIDE:-}" ]]; then
    log_info "Override mode without install-root override: skipping install-first"
    return 0
  fi

  # Decide what still needs to be done. /opt/laia and the LXD images are
  # independent — a previous attempt may have installed the host files but
  # died before (or during) image builds (e.g. SIGTTIN before we added -T,
  # or a network drop). Each is checked separately so resumes don't skip
  # the missing half.
  local need_host=true
  local need_images=true
  if [[ -e "$prefix" && "$needs_clean" != true ]]; then
    need_host=false
  fi
  if command -v lxc >/dev/null 2>&1 \
       && lxc image info laia-agora >/dev/null 2>&1 \
       && lxc image info laia-agent >/dev/null 2>&1; then
    need_images=false
  fi

  if [[ "$need_host" == false && "$need_images" == false ]]; then
    log_info "Install-first: /opt/laia and LXD images already present — skipping"
    # Aún así refrescamos los wrappers bin/ — son baratos y permiten que
    # bugfixes en el dispatcher (ej: `laia` → chat agente) lleguen sin
    # tener que re-correr `laia-release`. Idempotente.
    _clone_refresh_bin_wrappers
    return 0
  fi

  log_step "Install-first"

  if [[ "$need_host" == true ]]; then
    local version
    version="$(detect_version "$LAIA_ROOT" "" 2>/dev/null || printf 'v0.0.0-clone\n')"

    "$LAIA_ROOT/bin/laia-install" \
      --from-local "$LAIA_ROOT" \
      --version "$version" \
      --minimal \
      --skip-pip \
      --skip-frontend \
      --yes || die "install-first laia-install --minimal failed"
  else
    log_info "  /opt/laia already installed — skipping host install"
    _clone_refresh_bin_wrappers
  fi

  if [[ "$need_images" == true ]]; then
    boot_detect_arch
    boot_check_lxd_installed
    boot_init_defaults
    boot_build_images
  else
    log_info "  LXD images laia-agent + laia-agora present — skipping build"
  fi
}

# ─── Main ───────────────────────────────────────────────────────────────────
main() {
  trap_errors
  install_signal_traps
  # Scrub the SSH password file on ANY exit path (success, die, SIGINT).
  trap 'clone_cleanup_sshpass_file' EXIT
  parse_args "$@"
  resolve_bwlimit_file
  resolve_ssh_pass_file
  validate_options

  emit_json_event step_start clone:start "laia-clone starting"
  log_step "laia-clone"
  log_info "Source:           ${OPT_SOURCE_DIR:-$OPT_SOURCE}"
  log_info "With tools:       $OPT_WITH_TOOLS"
  log_info "LXD containers:   rebuild locally"
  [[ -n "$OPT_ONLY_AGENT" ]] && log_info "Only agent:       $OPT_ONLY_AGENT"
  [[ -n "$OPT_BWLIMIT" ]] && log_info "Rsync bwlimit:    $OPT_BWLIMIT"
  log_info "Dry-run:          $OPT_DRY_RUN"
  log_info "Admin user:       $LAIA_USER ($LAIA_USER_HOME)"

  if [[ "$OPT_DRY_RUN" == true ]]; then
    log_warn "Dry-run mode — stopping before any network calls or mutations."
    exit 0
  fi

  emit_json_event step_start clone:install-first "Install LAIA host if missing"
  clone_install_first_if_needed
  emit_json_event step_done clone:install-first "Host install verified"

  emit_json_event step_start clone:preflight "Preflight SSH + source checks"
  clone_preflight
  clone_detect_paths
  emit_json_event step_done clone:preflight "Preflight OK"

  if [[ "$OPT_PREFLIGHT_ONLY" == true ]]; then
    log_success "Preflight passed"
    exit 0
  fi

  if ! inst_is_override_mode; then
    ensure_sudo_cached
  fi

  rel_capture_active_units
  clone_stop_services

  if clone_is_local_source && [[ -d "$OPT_SOURCE_DIR/LAIA-ARCH" ]]; then
    clone_phase1_laia_home
  fi

  # --resume: each rsync phase is now marker-driven (see clone_phase_state_dir
  # in infra/installer/lib/clone.sh). When a phase completes it writes a
  # .done marker under $LAIA_HOME/.clone-state/; on the next --resume the
  # phase function checks the marker and skips.
  #
  # The legacy heuristic (skip agora if destination DB already has 20+
  # tables) stays as a SAFETY NET for resumes from older clones that
  # predate the marker scheme. When it fires, we pre-write the marker so
  # the phase function picks it up and behavior is consistent thereafter.
  if [[ "$OPT_RESUME" == true ]]; then
    local dest_db tbl_count
    dest_db="$(clone_dest_agora_dir)/agora.db"
    if [[ -f "$dest_db" ]] && command -v sqlite3 >/dev/null 2>&1; then
      tbl_count="$(sqlite3 "$dest_db" "select count(*) from sqlite_master where type='table';" 2>/dev/null || echo 0)"
      if [[ "${tbl_count:-0}" -ge 20 ]] && ! clone_phase_should_skip "rsync-agora"; then
        log_info "--resume: legacy clone has agora.db with $tbl_count tables but no marker — synthesizing rsync-agora marker."
        clone_phase_mark_done "rsync-agora"
      fi
    fi
  fi
  emit_json_event step_start clone:rsync "Rsync data (agora + users + arch)"
  clone_phase_h_rsync_agora_data
  clone_phase_h_rsync_users_data
  clone_phase_h_rsync_arch_data
  clone_phase_h_rsync_arch_creds
  emit_json_event step_done clone:rsync "Rsync phases complete"

  # Reset imported admin password BEFORE rebuilding containers — rebuild-4
  # needs working admin credentials to call /api/login.
  emit_json_event step_start clone:admin-reset "Reset imported admin password"
  fact_reset_imported_admin_password
  emit_json_event step_done clone:admin-reset "Admin password reset"

  emit_json_event step_start clone:rebuild-containers "Rebuild LXD containers locally"
  clone_phase_h_enumerate_slugs
  clone_phase_h_rebuild_agora_container
  clone_phase_h_refresh_admin_after_agora
  if [[ -n "$OPT_ONLY_AGENT" ]]; then
    clone_phase_h_rebuild_agent_container "$OPT_ONLY_AGENT"
  else
    slug_list=("${CLONE_PHASE_H_SLUGS[@]:-}")
    for slug in "${slug_list[@]}"; do
      clone_phase_h_rebuild_agent_container "$slug"
    done
  fi
  clone_phase_h_fix_uid_mapping
  clone_phase4_tools
  emit_json_event step_done clone:rebuild-containers "Containers rebuilt"

  # Start laia-pathd on the host if its unit is installed — keeps Atlas
  # snapshots regenerated as ~/.laia/config.yaml evolves on the destination.
  if ! inst_is_override_mode && command -v systemctl >/dev/null 2>&1; then
    if systemctl list-unit-files laia-pathd.service 2>/dev/null | grep -q laia-pathd.service; then
      log_info "Starting laia-pathd.service on host"
      sudo systemctl enable --now laia-pathd.service 2>/dev/null \
        || log_warn "  enable --now laia-pathd failed (check journalctl -u laia-pathd)"
    fi
  fi

  rel_restart_active

  emit_json_event step_start clone:verify "Verify migration health"
  if ! clone_phase_h_verify; then
    log_warn "Phase H verification reported failures — investigate manually"
    emit_json_event step_error clone:verify "Phase H verification failed"
  fi
  if ! clone_phase5_smoke; then
    log_warn "Smoke test reported failures — investigate manually"
    emit_json_event step_error clone:verify "Smoke test failed"
  else
    emit_json_event step_done clone:verify "All checks green"
  fi

  clone_print_summary
  emit_json_event step_done clone:finish "Clone complete"
}

main "$@"
