#!/bin/bash
# LAIA Server Control Panel - Quick Launcher
# Usage: laia-server

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/serverpanel"

if [ ! -t 0 ]; then
    echo "Error: This script must be run in a terminal"
    exit 1
fi

if [ ! -f "$SCRIPT_DIR/launcher.py" ]; then
    echo "Error: Panel not found at $SCRIPT_DIR"
    exit 1
fi

cd "$SCRIPT_DIR"
exec python3 "$SCRIPT_DIR/launcher.py" "$@"
