                <mxCell id="7DA" value="&lt;b&gt;laia-pathd&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px&#39;&gt;Daemon systemd&lt;br&gt;inotify: cambios en config.yaml&lt;br&gt;watchdog: monitoriza paths&lt;br&gt;auto-regenera .env.paths + symlinks&lt;br&gt;Unix socket: pathd.sock&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fillColor=#5C6BC0;strokeColor=#5C6BC077;fontColor=#FFFFFF;fontSize=10;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="420" y="215" width="270" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="7CL" value="&lt;b&gt;laia-path CLI&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px&#39;&gt;8 subcomandos:&lt;br&gt;list — muestra 32 aliases&lt;br&gt;get &amp;lt;alias&amp;gt; — resuelve path&lt;br&gt;validate — verifica paths&lt;br&gt;history &amp;lt;alias&amp;gt; — cambios&lt;br&gt;resolve &amp;lt;path&amp;gt; — busca alias&lt;br&gt;snapshot — regenera .env.paths&lt;br&gt;watch — monitor en vivo&lt;br&gt;check — estado del daemon&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fillColor=#7986CB;strokeColor=#7986CB77;fontColor=#FFFFFF;fontSize=10;arcSize=8;" parent="1" vertex="1">
