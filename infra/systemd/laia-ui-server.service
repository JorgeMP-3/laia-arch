[Unit]
Description=LAIA UI Server (Admin)
After=laia-gateway.service
Wants=laia-gateway.service

[Service]
Type=simple
User=laia-hermes
Group=laia-hermes
WorkingDirectory=/home/laia-hermes/LAIA/.laia-core/laia-ui-server
Environment=HOME=/home/laia-hermes
Environment=LAIA_HOME=/home/laia-hermes/.laia
ExecStart=/home/laia-hermes/LAIA/.laia-core/laia-ui-server/.venv/bin/uvicorn backend.main:app --host 0.0.0.0 --port 8077
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
