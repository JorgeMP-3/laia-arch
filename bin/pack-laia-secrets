#!/usr/bin/env zsh
# pack-laia-secrets — empaqueta los archivos privados de LAIA para migración
# Uso: pack-laia-secrets [destino]
# Crea un .tar.gz cifrado con contraseña para transferir por USB

YEL='\033[1;33m'; GRN='\033[1;32m'; RED='\033[1;31m'
CYN='\033[1;36m'; DIM='\033[2m'; RST='\033[0m'; BLD='\033[1m'

ok()   { echo "${GRN}  ✓ $1${RST}" }
info() { echo "${CYN}  → $1${RST}" }
err()  { echo "${RED}  ✕ $1${RST}"; exit 1 }
warn() { echo "${YEL}  ⚠ $1${RST}" }

DEST="${1:-$HOME/Desktop}"
OUTFILE="$DEST/laia-secrets-$(date +%Y%m%d-%H%M).tar.gz"
BASE="$HOME/.hermes"

clear
echo ""
echo "${YEL}  ██████╗  █████╗  ██████╗██╗  ██╗${RST}"
echo "${YEL}  ██╔══██╗██╔══██╗██╔════╝██║ ██╔╝${RST}"
echo "${YEL}  ██████╔╝███████║██║     █████╔╝ ${RST}"
echo "${YEL}  ██╔═══╝ ██╔══██║██║     ██╔═██╗ ${RST}"
echo "${YEL}  ██║     ██║  ██║╚██████╗██║  ██╗${RST}"
echo "${YEL}  ╚═╝     ╚═╝  ╚═╝ ╚═════╝╚═╝  ╚═╝${RST}"
echo ""
echo "${BLD}  Empaquetador de secretos LAIA para migración${RST}"
echo "${DIM}  Destino: $OUTFILE${RST}"
echo ""

# Verificar que existen los archivos clave
[[ -f "$BASE/auth.json" ]] || { warn "auth.json no encontrado — se saltará"; }
[[ -f "$BASE/config.yaml" ]] || { warn "config.yaml no encontrado — se saltará"; }

echo "  ${BLD}Archivos que se incluirán:${RST}"
echo "  ${DIM}  auth.json          (tokens API)${RST}"
echo "  ${DIM}  config.yaml        (configuración con API keys)${RST}"
echo "  ${DIM}  state.db           (historial y estado de Hermes — 152MB)${RST}"
echo "  ${DIM}  memories/          (MEMORY.md, USER.md)${RST}"
echo "  ${DIM}  workspaces/        (proyectos guardados)${RST}"
echo "  ${DIM}  sessions/          (sesiones recientes)${RST}"
echo ""
echo "  ${YEL}⚠  El archivo resultante contiene tus tokens y API keys.${RST}"
echo "  ${YEL}   Transfiérelo solo por USB/red local. Bórralo después.${RST}"
echo ""
printf "  ${BLD}¿Crear el paquete cifrado? (s/n)${RST} "
read -r REPLY
[[ "$REPLY" =~ ^[Ss]$ ]] || { info "Cancelado."; exit 0 }

echo ""
info "Empaquetando..."

# Lista de archivos/dirs a incluir
ITEMS=()
[[ -f "$BASE/auth.json"   ]] && ITEMS+=("auth.json")
[[ -f "$BASE/config.yaml" ]] && ITEMS+=("config.yaml")
[[ -f "$BASE/state.db"    ]] && ITEMS+=("state.db")
[[ -d "$BASE/memories"    ]] && ITEMS+=("memories/")
[[ -d "$BASE/workspaces"  ]] && ITEMS+=("workspaces/")
[[ -d "$BASE/sessions"    ]] && ITEMS+=("sessions/")

# Crear tar cifrado con openssl (disponible en macOS y Linux)
cd "$BASE" || err "No se puede acceder a $BASE"

tar -czf - "${ITEMS[@]}" 2>/dev/null | \
  openssl enc -aes-256-cbc -pbkdf2 -iter 100000 -out "$OUTFILE"

if [[ $? -eq 0 && -f "$OUTFILE" ]]; then
  SIZE=$(du -sh "$OUTFILE" | cut -f1)
  echo ""
  ok "Paquete creado: $OUTFILE ($SIZE)"
  echo ""
  echo "  ${BLD}Para desencriptar en Linux:${RST}"
  echo "  ${DIM}  openssl enc -d -aes-256-cbc -pbkdf2 -iter 100000 -in laia-secrets-*.tar.gz | tar -xz -C ~/.hermes/${RST}"
  echo ""
  echo "  ${YEL}⚠  Recuerda borrar el archivo después de transferirlo.${RST}"
else
  err "Falló la creación del paquete."
fi

echo ""
