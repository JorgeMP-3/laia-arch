{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LAIA",
  "version": "0.1.0",
  "identifier": "com.hermes.laia",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self' tauri: asset: http: https: ws: wss: data: blob: 'unsafe-inline' 'unsafe-eval'"
    },
    "windows": [
      {
        "label": "main",
        "title": "LAIA",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "visible": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
