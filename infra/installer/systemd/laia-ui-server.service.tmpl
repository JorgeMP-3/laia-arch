[Unit]
Description=LAIA UI Server (ARCH Admin)
After=laia-gateway.service
Wants=laia-gateway.service
X-LaiaPathDeps=ui_server,ui_backend,laia_venv

[Service]
Type=simple
User=${LAIA_USER}
Group=${LAIA_USER}
# Path registry — defines LAIA_UI_SERVER, LAIA_UI_BACKEND, LAIA_VENV, etc.
EnvironmentFile=-${LAIA_HOME}/.env.paths
WorkingDirectory=${LAIA_INSTALL_PREFIX}/.laia-core/laia-ui-server/backend
Environment=HOME=${LAIA_USER_HOME}
Environment=LAIA_HOME=${LAIA_HOME}
ExecStart=${LAIA_INSTALL_PREFIX}/.laia-core/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8077
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
