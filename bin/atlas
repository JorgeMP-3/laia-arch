</div>
<script>
const NODES = __NODES__;
const EDGES = __EDGES__;

mermaid.initialize({ startOnLoad: true, theme: 'dark',
  themeVariables: { primaryColor: '#3B82F6', primaryTextColor: '#F1F5F9',
    primaryBorderColor: '#60A5FA', lineColor: '#475569',
    secondaryColor: '#1E293B', tertiaryColor: '#0F172A' } });

const byType = {};
NODES.forEach(n => { (byType[n.type] = byType[n.type]||[]).push(n); });
document.getElementById('stats').innerHTML =
  Object.entries(byType).map(([t,ns]) =>
    `<span class="badge" style="background:${ns[0].bg};color:white">${t}: ${ns.length}</span>`).join(' ');

let graph = 'graph TD;\\n';
const nodeIds = new Set(NODES.map(n=>n.id));
const subgraphs = {};
NODES.forEach(n => {
  if (!subgraphs[n.type]) subgraphs[n.type] = [];
  subgraphs[n.type].push(n.id);
});
Object.entries(subgraphs).forEach(([type, ids]) => {
  const color = NODES.find(n=>n.id===ids[0])?.bg || '#9CA3AF';
  graph += `  subgraph ${type} ["${type}"]\\n`;
  ids.forEach(id => graph += `    ${id}\\n`);
  graph += `  end\\n`;
});
EDGES.forEach(e => {
  if (nodeIds.has(e.from) && nodeIds.has(e.to))
    graph += `  ${e.from} --> ${e.to}\\n`;
});
document.getElementById('mermaid-graph').textContent = graph;

const tbody = document.querySelector('#ref-table tbody');
NODES.sort((a,b)=>a.type.localeCompare(b.type)||a.id.localeCompare(b.id))
.forEach(n => {
  const tr = document.createElement('tr');
  tr.innerHTML = `<td>${n.label}</td><td>${n.type}</td>
    <td style="color:#94A3B8;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
        title="${n.description}">${n.description || '—'}</td>
    <td class="${n.color==='#16A34A'?'status-ok':'status-dead'}">
      ${n.color==='#16A34A'?'✓ alive':'✗ dead'}</td>`;
  tbody.appendChild(tr);
});

function showTab(tab) {
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('[id$="-section"]').forEach(s=>s.classList.remove('active'));
  document.getElementById(tab+'-section').classList.add('active');
  event.target.classList.add('active');
}
</script>
</body>
</html>"""


def cmd_watch(args: argparse.Namespace) -> int:
    interval = getattr(args, "interval", 5.0)
    atlas = _import_atlas()
    try:
        while True:
            # ANSI: move cursor to top-left and clear screen
            sys.stdout.write("\033[H\033[2J")
            sys.stdout.flush()
            ts = time.strftime("%H:%M:%S")
            print(
                f"{_C.BOLD}{_C.CYN}Atlas monitor{_C.RST}  "
                f"{_C.DIM}{ts}  (Ctrl+C to quit, updates every {interval:.0f}s){_C.RST}\n"
            )
            results = atlas.doctor()
            n_ok  = sum(1 for r in results.values() if r.alive)
            n_bad = len(results) - n_ok
            bar_color = _C.GRN if n_bad == 0 else _C.RED
            print(
                f"  {_C.GRN}OK {n_ok}{_C.RST}   "
                f"{bar_color}DEAD {n_bad}{_C.RST}   "
                f"{_C.DIM}total {len(results)}{_C.RST}\n"
            )
            by_type: dict[str, list] = {}
            for r in results.values():
                by_type.setdefault(r.ref_type, []).append(r)
            for ref_type in ["path", "service", "container", "socket", "env_file"]:
                group = by_type.get(ref_type)
                if not group:
                    continue
                print(f"  {_C.BOLD}{ref_type}{_C.RST}")
                for r in sorted(group, key=lambda x: x.name):
                    dot = f"{_C.GRN}●{_C.RST}" if r.alive else f"{_C.RED}●{_C.RST}"
                    lat = f" {_C.DIM}{r.latency_ms:.0f}ms{_C.RST}" if r.latency_ms else ""
                    dead = f" {_C.RED}← {r.detail}{_C.RST}" if not r.alive else ""
                    print(f"    {dot} {r.name:<26}{lat}{dead}")
                print()
            time.sleep(interval)
    except KeyboardInterrupt:
        print("\nMonitor stopped.")
        return 0


def cmd_status(_args: argparse.Namespace) -> int:
    import json as _json
    home    = _laia_config_home()
    atlas_f = home / "atlas.yaml"
    cfg_f   = home / "config.yaml"
    sock    = home / "pathd.sock"

    def _exists(p: Path) -> str:
        return f"{_C.GRN}exists{_C.RST}" if p.exists() else f"{_C.RED}missing{_C.RST}"

    print(f"\n{_C.BOLD}Atlas v{_VERSION} — status{_C.RST}\n")
    print(f"  config home : {home}")
    print(f"  atlas.yaml  : {_exists(atlas_f)}")
    print(f"  config.yaml : {_exists(cfg_f)}")

    if sock.exists():
        import socket as _s
        req = (_json.dumps({"id": 1, "method": "status", "params": {}}) + "\n").encode()
        try:
            s = _s.socket(_s.AF_UNIX, _s.SOCK_STREAM)
            s.settimeout(0.5)
            s.connect(str(sock))
            s.sendall(req)
            buf = b""
            while b"\n" not in buf:
                chunk = s.recv(4096)
                if not chunk:
                    break
                buf += chunk
            s.close()
            resp = _json.loads(buf.decode().splitlines()[0])
            info = resp.get("result", {})
            print(f"  daemon      : {_C.GRN}running{_C.RST}")
            print(f"  uptime      : {info.get('uptime_s', 0):.0f}s")
            print(f"  paths count : {info.get('paths_count', 0)}")
        except Exception as exc:
            print(f"  daemon      : {_C.YEL}socket exists but not responding{_C.RST} ({exc})")
    else:
        print(f"  daemon      : {_C.DIM}not running{_C.RST}")
    print()
    return 0


def cmd_reload(_args: argparse.Namespace) -> int:
    import json as _json
    home = _laia_config_home()
    sock = home / "pathd.sock"

    if sock.exists():
        import socket as _s
        req = (_json.dumps({"id": 1, "method": "reload", "params": {}}) + "\n").encode()
        try:
            s = _s.socket(_s.AF_UNIX, _s.SOCK_STREAM)
            s.settimeout(1)
            s.connect(str(sock))
            s.sendall(req)
            buf = b""
            while b"\n" not in buf:
                chunk = s.recv(4096)
                if not chunk:
                    break
                buf += chunk
            s.close()
            resp  = _json.loads(buf.decode().splitlines()[0])
            changed = resp.get("result", {}).get("changed", False)
            print(f"{_C.GRN}✓{_C.RST} daemon reloaded (changed={changed})")
            return 0
        except Exception as exc:
            _warn(f"daemon not responding: {exc}")

    # Daemon not available — regenerate .env.paths directly
    try:
        from laia_paths import regenerate_env_file  # noqa: PLC0415
        out = regenerate_env_file()
        print(f"daemon not running — regenerated {out}")
        # Also invalidate atlas cache
        _import_atlas().invalidate_cache()
        return 0
    except Exception as exc:
        _die(str(exc))
    return 1


def _scan_consumers(refs: dict, atlas, only_ref: str | None) -> dict:
    """Static scan of the source tree for usages of each reference.

    Detects two classes of usage per ref:
      logical  — atlas.get("X") / get_path("X") / ATLAS_X env var.
      hardcode — the ref's resolved literal coordinate appears verbatim in code
                 (path, host:port, or container name) — a migration candidate.

    Returns {ref_name: {"logical": [str], "hardcode": [str]}} with "file:line".
    """
    import re as _re

    skip_dirs = {".laia-core", ".git", "node_modules", "archived",
                 "archived-skills", "laia-ui", "__pycache__", ".venv", "venv",
                 "workspaces", "mlx-servers"}
    exts = {".py", ".sh", ".bash", ".yaml", ".yml", ".toml", ".service", ".env"}

    names = [only_ref] if only_ref else list(refs)
    if only_ref and only_ref not in refs:
        _die(f"reference {only_ref!r} not in registry")

    # Precompute literal coordinate per ref (best-effort; skip on error).
    literal: dict[str, str] = {}
    for name in names:
        entry = refs.get(name)
        if not isinstance(entry, dict):
            continue
        try:
            val = atlas.get(name)
        except atlas.AtlasError:
            continue
        if entry.get("type") == "service":
            host = str(entry.get("host", "")); port = entry.get("port", "")
            literal[name] = f"{host}:{port}" if host else ""
        else:
            literal[name] = val

    logical_pat = {
        name: _re.compile(
            r'(?:get|get_path|resolve_service)\(\s*["\']' + _re.escape(name) + r'["\']'
            r'|ATLAS_' + _re.escape(name.upper()) + r'\b'
        )
        for name in names
    }

    found: dict[str, dict[str, list]] = {n: {"logical": [], "hardcode": []} for n in names}

    for root, dirs, files in os.walk(_LAIA_ROOT):
        dirs[:] = [d for d in dirs if d not in skip_dirs]
        for fname in files:
            fp = Path(root) / fname
            if fp.suffix not in exts:
                continue
            try:
                lines = fp.read_text(errors="replace").splitlines()
            except OSError:
                continue
            rel = fp.relative_to(_LAIA_ROOT)
            for i, line in enumerate(lines, 1):
                for name in names:
                    if logical_pat[name].search(line):
                        found[name]["logical"].append(f"{rel}:{i}")
                    lit = literal.get(name)
                    if lit and len(lit) > 4 and lit in line:
                        found[name]["hardcode"].append(f"{rel}:{i}")
    return found


def cmd_consumers(args: argparse.Namespace) -> int:
    import json as _json
    atlas = _import_atlas()
    refs  = atlas.all_refs()
    only  = getattr(args, "ref", None)
    data  = _scan_consumers(refs, atlas, only)

    if getattr(args, "json", False):
        print(_json.dumps(data, indent=2))
        return 0

    any_hardcode = False
    print(f"\n{_C.BOLD}Atlas consumers{_C.RST}  {_C.DIM}(inverse graph){_C.RST}")
    for name in sorted(data):
        logical  = data[name]["logical"]
        hardcode = data[name]["hardcode"]
        if not logical and not hardcode:
            continue
        print(f"\n  {_C.CYN}{name}{_C.RST}")
        for loc in logical:
            print(f"    {_C.GRN}✓ atlas{_C.RST}  {loc}")
        for loc in hardcode:
            any_hardcode = True
            print(f"    {_C.YEL}⚠ hardcode{_C.RST}  {loc}")
    used = sum(1 for n in data if data[n]["logical"] or data[n]["hardcode"])
    print(f"\n{_C.DIM}{used}/{len(data)} refs referenced in source.{_C.RST}")
    if any_hardcode:
        print(f"{_C.YEL}⚠ hardcoded coordinates above are migration candidates "
              f"(replace with atlas.get).{_C.RST}")
    print()
    return 0


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="atlas",
        description="Atlas v2 — LAIA reference registry control centre.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="cmd", required=True, metavar="<command>")

    p = sub.add_parser("version", help="Show version")
    p.set_defaults(func=cmd_version)

    p = sub.add_parser("init", help="Bootstrap ~/.laia/atlas.yaml from the template")
    p.add_argument("--force", action="store_true", help="Overwrite an existing registry")
    p.set_defaults(func=cmd_init)

    p = sub.add_parser("get", help="Resolve a reference by name")
    p.add_argument("name")
    p.set_defaults(func=cmd_get)

    p = sub.add_parser("check", help="Health check a single reference")
    p.add_argument("name")
    p.set_defaults(func=cmd_check)

    p = sub.add_parser("validate", help="Validate atlas.yaml schema (no disk checks)")
    p.set_defaults(func=cmd_validate)

    p = sub.add_parser("list", help="List all references")
    p.add_argument("--type", dest="type", default=None,
                   metavar="TYPE",
                   help="Filter by type: path|service|container|socket|env_file")
    p.add_argument("--json", action="store_true", help="JSON output")
    p.set_defaults(func=cmd_list)

    p = sub.add_parser("doctor", help="Health-check all references")
    p.add_argument("--type", dest="type", default=None, metavar="TYPE",
                   help="Only check refs of this type")
    p.add_argument("--fix", action="store_true",
                   help="Offer a guided repair for each broken reference")
    p.add_argument("--yes", action="store_true",
                   help="With --fix: auto-confirm every repair (non-interactive)")
    p.add_argument("--dry-run", dest="dry_run", action="store_true",
                   help="With --fix: print repair actions without running them")
    p.add_argument("--include-optional", dest="include_optional", action="store_true",
                   help="With --fix: also repair optional references")
    p.set_defaults(func=cmd_doctor)

    p = sub.add_parser("env", help="Print bash-sourceable ATLAS_* exports")
    p.set_defaults(func=cmd_env)

    p = sub.add_parser("graph", help="Show reference dependency graph")
    p.add_argument("--from", dest="from_ref", default=None, metavar="REF",
                   help="Start from this reference (show subtree only)")
    p.set_defaults(func=cmd_graph)

    p = sub.add_parser("visualize", help="Generate self-contained HTML visualization with Mermaid")
    p.add_argument("--output", dest="output", default=None, metavar="FILE",
                   help="Write HTML to FILE instead of opening browser")
    p.add_argument("--no-open", dest="open", action="store_false", default=True,
                   help="Don't open browser automatically")
    p.set_defaults(func=cmd_visualize)

    p = sub.add_parser("watch", help="Live health monitor")
    p.add_argument("--interval", type=float, default=5.0, metavar="SEC")
    p.set_defaults(func=cmd_watch)

    p = sub.add_parser("consumers", help="Show which source files use each reference")
    p.add_argument("--ref", dest="ref", default=None, metavar="REF",
                   help="Only scan for this reference")
    p.add_argument("--json", action="store_true", help="JSON output")
    p.set_defaults(func=cmd_consumers)

    p = sub.add_parser("status", help="Daemon and config file status")
    p.set_defaults(func=cmd_status)

    p = sub.add_parser("reload", help="Reload config (signal daemon or regenerate)")
    p.set_defaults(func=cmd_reload)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = _build_parser()
    args   = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
