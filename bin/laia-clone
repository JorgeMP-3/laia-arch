#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# laia-clone — pull LAIA state from an old server into this new server.
#
# This command runs on the destination and pulls from --source user@old-host.
# It installs LAIA first when /opt/laia is missing, rsyncs portable bind-mount
# data, then rebuilds containers locally for the destination architecture.
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
LAIA_ROOT="$(dirname "$SCRIPT_DIR")"
LIB_DIR="$LAIA_ROOT/infra/installer/lib"

# shellcheck source=../infra/installer/lib/common.sh
source "$LIB_DIR/common.sh"
# shellcheck source=../infra/installer/lib/sudo.sh
source "$LIB_DIR/sudo.sh"
# shellcheck source=../infra/installer/lib/system.sh
source "$LIB_DIR/system.sh"
# shellcheck source=../infra/installer/lib/version.sh
source "$LIB_DIR/version.sh"
# shellcheck source=../infra/installer/lib/install.sh
source "$LIB_DIR/install.sh"
# shellcheck source=../infra/installer/lib/release.sh
source "$LIB_DIR/release.sh"
# shellcheck source=../infra/installer/lib/bootstrap.sh
source "$LIB_DIR/bootstrap.sh"
# shellcheck source=../infra/installer/lib/clone.sh
source "$LIB_DIR/clone.sh"

# ─── Options ────────────────────────────────────────────────────────────────
OPT_SOURCE=""
OPT_SOURCE_DIR=""
OPT_YES=false
OPT_DRY_RUN=false
OPT_WITH_TOOLS=false
OPT_WITH_MLX_MODELS=false
OPT_NO_LXD=false
OPT_ONLY_AGENT=""
OPT_KEEP_SESSION=false
OPT_BWLIMIT=""
OPT_PREFLIGHT_ONLY=false

print_help() {
  cat <<'EOF'
laia-clone — pull LAIA state from an old server

USAGE
    sudo laia-clone --source <user@old-host> [OPTIONS]
    laia-clone --source-dir <path> [OPTIONS]
    sudo laia clone --source <user@old-host> [OPTIONS]

ARGUMENTS
    --source <user@host>  SSH source server to pull from (passwordless required)

OPTIONS
    --source-dir PATH     Use a local directory as the source instead of SSH.
                          Expected layout: <PATH>/{agora,users,arch,home}/
                          Useful for migrations on the same machine and tests.
    --keep-session        Also clone admin-session.json. Default is to require
                          a fresh login on the destination.
    --bwlimit LIMIT       Pass rsync --bwlimit, e.g. 50M for WAN migrations.
    --with-tools          Also clone personal CLI configs (Claude Code, Codex,
                          OpenCode, .gitconfig, .pm2, .docker)
    --with-mlx-models     Also clone heavy local models (LAIA-ARCH/mlx-servers/)
    --no-lxd              Compatibility no-op; containers are rebuilt locally.
    --only-agent <slug>   Rebuild only this agent container after data import.
    --preflight-only      Stop after source/destination checks.
    --yes, -y             Non-interactive mode
    --dry-run             Print plan, don't transfer anything
    --help, -h            Show this help

PRE-CONDITIONS
    - Run this on the destination server. If /opt/laia is missing, laia-clone
      invokes laia-install --minimal first.
    - Passwordless SSH to <user@host>  (when not using --source-dir)

EXAMPLES
    sudo laia-clone --source laia-hermes@old.example.com --yes
    sudo laia-clone --source jorge@10.0.0.5 --bwlimit=50M
    laia-clone --source-dir /mnt/backup/laia-snapshot-2026-05-20 --with-tools

EXIT CODES
    0   Success
    1   Generic failure
    2   Bad arguments
    3   SSH unreachable / pre-condition violated
EOF
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)       print_help; exit 0 ;;
      --source)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--source requires user@host" 2
        OPT_SOURCE="$2"; shift 2 ;;
      --source-dir)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--source-dir requires PATH" 2
        OPT_SOURCE_DIR="$(readlink -f "$2")"; shift 2 ;;
      --keep-session)  OPT_KEEP_SESSION=true; shift ;;
      --bwlimit)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--bwlimit requires LIMIT" 2
        OPT_BWLIMIT="$2"; shift 2 ;;
      --bwlimit=*)
        OPT_BWLIMIT="${1#--bwlimit=}"; shift ;;
      --with-tools)    OPT_WITH_TOOLS=true; shift ;;
      --with-mlx-models) OPT_WITH_MLX_MODELS=true; shift ;;
      --no-lxd)        OPT_NO_LXD=true; shift ;;
      --preflight-only) OPT_PREFLIGHT_ONLY=true; shift ;;
      --only-agent)
        [[ $# -ge 2 && -n "${2:-}" ]] || die "--only-agent requires SLUG" 2
        OPT_ONLY_AGENT="$2"; shift 2 ;;
      -y|--yes)        OPT_YES=true; export LAIA_NONINTERACTIVE=true; shift ;;
      --dry-run)       OPT_DRY_RUN=true; shift ;;
      -*) die "Unknown option: $1 (use --help)" 2 ;;
      *)
        if [[ -z "$OPT_SOURCE" ]]; then
          OPT_SOURCE="$1"; shift
        else
          die "Multiple source hosts given; only one allowed: $OPT_SOURCE vs $1" 2
        fi
        ;;
    esac
  done

  if [[ -z "$OPT_SOURCE" && -z "$OPT_SOURCE_DIR" ]]; then
    print_help
    die "Specify either <user@host> or --source-dir PATH" 2
  fi
  if [[ -n "$OPT_SOURCE" && -n "$OPT_SOURCE_DIR" ]]; then
    die "Cannot combine <user@host> and --source-dir (got: $OPT_SOURCE + $OPT_SOURCE_DIR)" 2
  fi
  if [[ -n "$OPT_SOURCE" && "$OPT_SOURCE" != *@* ]]; then
    die "Source must be user@host (got: $OPT_SOURCE)" 2
  fi
}

clone_install_first_if_needed() {
  local prefix
  prefix="$(inst_install_prefix)"
  [[ -e "$prefix" ]] && return 0

  if inst_is_override_mode && [[ -z "${LAIA_INSTALL_ROOT_OVERRIDE:-}" ]]; then
    log_info "Override mode without install-root override: skipping install-first"
    return 0
  fi

  log_step "Install-first"
  local version
  version="$(detect_version "$LAIA_ROOT" "" 2>/dev/null || printf 'v0.0.0-clone\n')"

  "$LAIA_ROOT/bin/laia-install" \
    --from-local "$LAIA_ROOT" \
    --version "$version" \
    --minimal \
    --skip-pip \
    --skip-frontend \
    --yes || die "install-first laia-install --minimal failed"

  boot_init_defaults
  boot_build_images
}

# ─── Main ───────────────────────────────────────────────────────────────────
main() {
  parse_args "$@"

  log_step "laia-clone"
  log_info "Source:           ${OPT_SOURCE_DIR:-$OPT_SOURCE}"
  log_info "With tools:       $OPT_WITH_TOOLS"
  log_info "With MLX models:  $OPT_WITH_MLX_MODELS"
  log_info "LXD containers:   rebuild locally"
  [[ -n "$OPT_ONLY_AGENT" ]] && log_info "Only agent:       $OPT_ONLY_AGENT"
  [[ -n "$OPT_BWLIMIT" ]] && log_info "Rsync bwlimit:    $OPT_BWLIMIT"
  log_info "Dry-run:          $OPT_DRY_RUN"
  log_info "Admin user:       $LAIA_USER ($LAIA_USER_HOME)"

  if [[ "$OPT_DRY_RUN" == true ]]; then
    log_warn "Dry-run mode — stopping before any network calls or mutations."
    exit 0
  fi

  clone_install_first_if_needed

  clone_preflight
  clone_detect_paths

  if [[ "$OPT_PREFLIGHT_ONLY" == true ]]; then
    log_success "Preflight passed"
    exit 0
  fi

  if ! inst_is_override_mode; then
    ensure_sudo_cached
  fi

  rel_capture_active_units
  clone_stop_services

  if clone_is_local_source && [[ -d "$OPT_SOURCE_DIR/LAIA-ARCH" ]]; then
    clone_phase1_laia_home
  fi
  clone_phase_h_rsync_agora_data
  clone_phase_h_rsync_users_data
  clone_phase_h_rsync_arch_data
  clone_phase_h_rsync_arch_creds
  clone_phase_h_enumerate_slugs
  clone_phase_h_rebuild_agora_container
  if [[ -n "$OPT_ONLY_AGENT" ]]; then
    clone_phase_h_rebuild_agent_container "$OPT_ONLY_AGENT"
  else
    slug_list=("${CLONE_PHASE_H_SLUGS[@]:-}")
    for slug in "${slug_list[@]}"; do
      clone_phase_h_rebuild_agent_container "$slug"
    done
  fi
  clone_phase_h_fix_uid_mapping
  clone_phase4_tools

  rel_restart_active

  if ! clone_phase_h_verify; then
    log_warn "Phase H verification reported failures — investigate manually"
  fi
  if ! clone_phase5_smoke; then
    log_warn "Smoke test reported failures — investigate manually"
  fi

  clone_print_summary
}

main "$@"
