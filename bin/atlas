<script>
"use strict";

// ── Data injected by Python at build time ─────────────────────────────────
const DATA = __ATLAS_DATA__;

// ── Type → CSS color var ──────────────────────────────────────────────────
const TYPE_VAR = {
  path: "--type-path",
  service: "--type-service",
  container: "--type-container",
  socket: "--type-socket",
  env_file: "--type-env_file",
};
const typeColor = t => getComputedStyle(document.documentElement)
                          .getPropertyValue(TYPE_VAR[t] || "--fg-muted").trim();
const STATE_VAR = { ok: "--ok", warn: "--warn", bad: "--bad" };
const stateColor = s => getComputedStyle(document.documentElement)
                            .getPropertyValue(STATE_VAR[s] || "--fg-muted").trim();

// ── App state ─────────────────────────────────────────────────────────────
const state = {
  view: "graph",
  search: "",
  types: new Set(Object.keys(DATA.stats.by_type)),
  states: new Set(["ok", "warn", "bad"]),
  selected: null,   // node id
  sort: { col: "id", dir: 1 },
  zoom: 1,
  pan: { x: 0, y: 0 },
};

const nodeById = new Map(DATA.nodes.map(n => [n.id, n]));

// ── Topbar values ─────────────────────────────────────────────────────────
document.getElementById("ver").textContent = "v" + DATA.version;
document.getElementById("m-path").textContent = DATA.registry_path;
document.getElementById("m-time").textContent = DATA.generated_at;
document.getElementById("s-ok").textContent = DATA.stats.by_state.ok || 0;
document.getElementById("s-warn").textContent = DATA.stats.by_state.warn || 0;
document.getElementById("s-bad").textContent = DATA.stats.by_state.bad || 0;

// ── Sidebar filters ───────────────────────────────────────────────────────
function buildTypeFilters() {
  const container = document.getElementById("type-filters");
  const entries = Object.entries(DATA.stats.by_type).sort();
  container.innerHTML = "";
  const all = document.createElement("button");
  all.className = "filter-btn active";
  all.dataset.type = "__all__";
  all.innerHTML = `<span class="left">All types</span><span class="count">${DATA.stats.total}</span>`;
  container.appendChild(all);
  for (const [t, n] of entries) {
    const btn = document.createElement("button");
    btn.className = "filter-btn active";
    btn.dataset.type = t;
    btn.innerHTML =
      `<span class="left"><span class="swatch" style="background:${typeColor(t)}"></span>${t}</span>` +
      `<span class="count">${n}</span>`;
    container.appendChild(btn);
  }
  container.addEventListener("click", e => {
    const btn = e.target.closest(".filter-btn");
    if (!btn) return;
    const t = btn.dataset.type;
    if (t === "__all__") {
      const allOn = state.types.size === Object.keys(DATA.stats.by_type).length;
      state.types = new Set(allOn ? [] : Object.keys(DATA.stats.by_type));
    } else if (state.types.has(t)) {
      state.types.delete(t);
    } else {
      state.types.add(t);
    }
    refreshFilters();
    render();
  });
}
function buildStateFilters() {
  const container = document.getElementById("state-filters");
  const labels = { ok: "Alive", warn: "Optional offline", bad: "Dead" };
  container.innerHTML = "";
  for (const s of ["ok", "warn", "bad"]) {
    const btn = document.createElement("button");
    btn.className = "filter-btn active";
    btn.dataset.state = s;
    btn.innerHTML =
      `<span class="left"><span class="swatch" style="background:${stateColor(s)};border-radius:50%"></span>${labels[s]}</span>` +
      `<span class="count">${DATA.stats.by_state[s] || 0}</span>`;
    container.appendChild(btn);
  }
  container.addEventListener("click", e => {
    const btn = e.target.closest(".filter-btn");
    if (!btn) return;
    const s = btn.dataset.state;
    if (state.states.has(s)) state.states.delete(s); else state.states.add(s);
    refreshFilters();
    render();
  });
}
function refreshFilters() {
  document.querySelectorAll("#type-filters .filter-btn").forEach(b => {
    const t = b.dataset.type;
    const active = t === "__all__"
      ? state.types.size === Object.keys(DATA.stats.by_type).length
      : state.types.has(t);
    b.classList.toggle("active", active);
  });
  document.querySelectorAll("#state-filters .filter-btn").forEach(b => {
    b.classList.toggle("active", state.states.has(b.dataset.state));
  });
}

// ── Search ────────────────────────────────────────────────────────────────
const searchInput = document.getElementById("search");
let searchTimer = null;
searchInput.addEventListener("input", () => {
  clearTimeout(searchTimer);
  searchTimer = setTimeout(() => {
    state.search = searchInput.value.trim().toLowerCase();
    render();
  }, 100);
});
document.addEventListener("keydown", e => {
  if (e.key === "/" && document.activeElement !== searchInput) {
    e.preventDefault();
    searchInput.focus();
    searchInput.select();
  } else if (e.key === "Escape") {
    if (document.activeElement === searchInput) {
      searchInput.blur();
      searchInput.value = "";
      state.search = "";
      render();
    } else if (state.selected) {
      selectNode(null);
    }
  }
});

// ── View switch ───────────────────────────────────────────────────────────
document.querySelector(".view-switch").addEventListener("click", e => {
  const btn = e.target.closest("button");
  if (!btn) return;
  state.view = btn.dataset.view;
  document.querySelectorAll(".view-switch button").forEach(b =>
    b.classList.toggle("active", b === btn));
  document.getElementById("view-graph").classList.toggle("hidden", state.view !== "graph");
  document.getElementById("view-table").classList.toggle("hidden", state.view !== "table");
  render();
});

// ── Theme ─────────────────────────────────────────────────────────────────
document.getElementById("theme-toggle").addEventListener("click", () => {
  const html = document.documentElement;
  html.dataset.theme = html.dataset.theme === "dark" ? "light" : "dark";
  render();   // colors are CSS-var driven; nodes need re-paint for new vars
});

// ── Filter logic ──────────────────────────────────────────────────────────
function visibleNodes() {
  const q = state.search;
  return DATA.nodes.filter(n => {
    if (!state.types.has(n.type)) return false;
    if (!state.states.has(n.state)) return false;
    if (q && !n.id.toLowerCase().includes(q)
          && !n.value.toLowerCase().includes(q)
          && !n.description.toLowerCase().includes(q)) return false;
    return true;
  });
}

// ── Graph layout (deterministic, grouped by type) ─────────────────────────
// We lay out nodes in vertical columns, one per type. Each column is sized
// to its contents. This avoids force-simulation overhead, gives a stable
// reading order, and keeps related refs near each other.
function layout(nodes) {
  const order = ["path", "service", "container", "socket", "env_file"];
  const byType = {};
  for (const n of nodes) (byType[n.type] = byType[n.type] || []).push(n);
  const COL_GAP = 60;
  const COL_W = 200;
  const NODE_H = 28;
  const NODE_GAP = 8;
  const PAD_TOP = 48;
  const PAD_BOTTOM = 24;
  const TITLE_GAP = 12;

  const cols = order.filter(t => byType[t] && byType[t].length);
  const layout = { nodes: [], groups: [], width: 0, height: 0 };
  let x = 24;
  let maxH = 0;
  for (const t of cols) {
    const list = byType[t].slice().sort((a, b) => a.id.localeCompare(b.id));
    const h = PAD_TOP + list.length * NODE_H + (list.length - 1) * NODE_GAP + PAD_BOTTOM;
    layout.groups.push({ type: t, x, y: 12, width: COL_W, height: h, count: list.length });
    let y = 12 + PAD_TOP - TITLE_GAP;
    for (const n of list) {
      layout.nodes.push({
        ...n,
        x: x + COL_W / 2,
        y: y + NODE_H / 2,
        boxX: x + 10,
        boxY: y,
        boxW: COL_W - 20,
        boxH: NODE_H,
      });
      y += NODE_H + NODE_GAP;
    }
    if (h > maxH) maxH = h;
    x += COL_W + COL_GAP;
  }
  layout.width = x;
  layout.height = maxH + 24;
  return layout;
}

// ── Graph render ──────────────────────────────────────────────────────────
const svg = document.getElementById("graph-svg");
const SVG_NS = "http://www.w3.org/2000/svg";
function el(tag, attrs = {}, parent = null) {
  const e = document.createElementNS(SVG_NS, tag);
  for (const k in attrs) e.setAttribute(k, attrs[k]);
  if (parent) parent.appendChild(e);
  return e;
}

function renderGraph() {
  svg.innerHTML = "";
  const visible = visibleNodes();
  const visibleIds = new Set(visible.map(n => n.id));
  document.getElementById("graph-empty").classList.toggle("show", visible.length === 0);
  if (visible.length === 0) return;

  const L = layout(visible);
  const root = el("g", { id: "viewport" }, svg);
  applyTransform();

  // Arrow marker
  const defs = el("defs", {}, root);
  const marker = el("marker", {
    id: "arrow", viewBox: "0 0 10 10", refX: "9", refY: "5",
    markerWidth: "6", markerHeight: "6", orient: "auto-start-reverse",
  }, defs);
  el("path", { d: "M 0 0 L 10 5 L 0 10 z", fill: "var(--border-strong)" }, marker);

  // Group backgrounds + labels
  for (const g of L.groups) {
    el("rect", {
      class: "group-bg", x: g.x, y: g.y, width: g.width, height: g.height, rx: 8,
    }, root);
    el("text", {
      class: "group-label", x: g.x + 14, y: g.y + 22,
    }, root).textContent = `${g.type} · ${g.count}`;
  }

  // Edges (curved between columns; straight within)
  const edgeLayer = el("g", { id: "edges" }, root);
  const nodePos = new Map(L.nodes.map(n => [n.id, n]));
  for (const e of DATA.edges) {
    if (!visibleIds.has(e.from) || !visibleIds.has(e.to)) continue;
    const src = nodePos.get(e.from);
    const dst = nodePos.get(e.to);
    if (!src || !dst) continue;
    const x1 = src.boxX + (dst.x > src.x ? src.boxW : 0);
    const y1 = src.y;
    const x2 = dst.boxX + (src.x > dst.x ? dst.boxW : 0);
    const y2 = dst.y;
    const dx = Math.abs(x2 - x1);
    const cx1 = x1 + (x2 > x1 ? dx * 0.4 : -dx * 0.4);
    const cx2 = x2 + (x2 > x1 ? -dx * 0.4 : dx * 0.4);
    el("path", {
      class: "edge",
      d: `M ${x1} ${y1} C ${cx1} ${y1} ${cx2} ${y2} ${x2} ${y2}`,
      "marker-end": "url(#arrow)",
      "data-from": e.from, "data-to": e.to,
    }, edgeLayer);
  }

  // Nodes
  const nodeLayer = el("g", { id: "nodes" }, root);
  for (const n of L.nodes) {
    const g = el("g", { class: "node", "data-id": n.id }, nodeLayer);
    el("rect", {
      class: "node-shape",
      x: n.boxX, y: n.boxY, width: n.boxW, height: n.boxH, rx: 6,
      stroke: typeColor(n.type),
      fill: "var(--bg-elev)",
    }, g);
    // State indicator dot on the left edge of the box
    el("circle", {
      cx: n.boxX + 10, cy: n.y, r: 3.5,
      fill: stateColor(n.state),
    }, g);
    const label = el("text", {
      class: "node-label",
      x: n.boxX + 20, y: n.y + 4,
    }, g);
    label.textContent = n.id;
    g.addEventListener("click", ev => { ev.stopPropagation(); selectNode(n.id); });
    g.addEventListener("mouseenter", () => highlightConnected(n.id, true));
    g.addEventListener("mouseleave", () => highlightConnected(n.id, false));
  }

  if (state.selected) markSelected();
}

function highlightConnected(id, on) {
  const connected = new Set([id]);
  for (const e of DATA.edges) {
    if (e.from === id) connected.add(e.to);
    if (e.to === id) connected.add(e.from);
  }
  svg.querySelectorAll(".node").forEach(n => {
    n.classList.toggle("dim", on && !connected.has(n.dataset.id));
  });
  svg.querySelectorAll(".edge").forEach(p => {
    const hit = p.dataset.from === id || p.dataset.to === id;
    p.classList.toggle("highlight", on && hit);
    p.classList.toggle("dim", on && !hit);
  });
}

function markSelected() {
  svg.querySelectorAll(".node").forEach(n => {
    n.classList.toggle("selected", n.dataset.id === state.selected);
  });
}

// ── Pan + zoom on the SVG ─────────────────────────────────────────────────
function applyTransform() {
  const vp = svg.querySelector("#viewport");
  if (vp) vp.setAttribute("transform",
    `translate(${state.pan.x} ${state.pan.y}) scale(${state.zoom})`);
}
{
  let dragging = false, sx = 0, sy = 0, px = 0, py = 0;
  svg.addEventListener("mousedown", e => {
    if (e.target.closest(".node")) return;
    dragging = true; sx = e.clientX; sy = e.clientY;
    px = state.pan.x; py = state.pan.y;
    svg.classList.add("dragging");
  });
  window.addEventListener("mousemove", e => {
    if (!dragging) return;
    state.pan.x = px + (e.clientX - sx);
    state.pan.y = py + (e.clientY - sy);
    applyTransform();
  });
  window.addEventListener("mouseup", () => { dragging = false; svg.classList.remove("dragging"); });
  svg.addEventListener("wheel", e => {
    e.preventDefault();
    const factor = e.deltaY < 0 ? 1.1 : 0.9;
    state.zoom = Math.min(3, Math.max(0.3, state.zoom * factor));
    applyTransform();
  }, { passive: false });
}
document.getElementById("zoom-in").addEventListener("click", () => {
  state.zoom = Math.min(3, state.zoom * 1.2); applyTransform();
});
document.getElementById("zoom-out").addEventListener("click", () => {
  state.zoom = Math.max(0.3, state.zoom / 1.2); applyTransform();
});
document.getElementById("zoom-reset").addEventListener("click", () => {
  state.zoom = 1; state.pan = { x: 0, y: 0 }; applyTransform();
});

// ── Table render ──────────────────────────────────────────────────────────
const COLUMNS = [
  { key: "id", label: "Name", cls: "col-name" },
  { key: "type", label: "Type", cls: "col-type" },
  { key: "value", label: "Resolved value", cls: "col-value" },
  { key: "state", label: "Status", cls: "col-status" },
  { key: "optional", label: "Optional", cls: "col-opt" },
];
function buildTableHead() {
  const tr = document.getElementById("table-head");
  tr.innerHTML = "";
  for (const c of COLUMNS) {
    const th = document.createElement("th");
    th.textContent = c.label;
    th.dataset.col = c.key;
    th.addEventListener("click", () => {
      if (state.sort.col === c.key) state.sort.dir *= -1;
      else { state.sort.col = c.key; state.sort.dir = 1; }
      renderTable();
    });
    tr.appendChild(th);
  }
}
function renderTable() {
  const head = document.getElementById("table-head");
  head.querySelectorAll("th").forEach(th => {
    th.classList.toggle("sorted", th.dataset.col === state.sort.col);
    const arrow = state.sort.col === th.dataset.col
      ? (state.sort.dir > 0 ? "↑" : "↓") : "";
    th.innerHTML = `${COLUMNS.find(c => c.key === th.dataset.col).label}` +
                   ` <span class="arrow">${arrow}</span>`;
  });
  const rows = visibleNodes().slice().sort((a, b) => {
    const k = state.sort.col;
    const va = a[k] == null ? "" : a[k];
    const vb = b[k] == null ? "" : b[k];
    if (va < vb) return -1 * state.sort.dir;
    if (va > vb) return  1 * state.sort.dir;
    return 0;
  });
  const tbody = document.getElementById("table-body");
  tbody.innerHTML = "";
  for (const n of rows) {
    const tr = document.createElement("tr");
    tr.dataset.id = n.id;
    if (n.id === state.selected) tr.classList.add("selected");
    tr.innerHTML =
      `<td class="col-name">${escape(n.id)}</td>` +
      `<td><span class="type-pill" style="color:${typeColor(n.type)}">${n.type}</span></td>` +
      `<td class="col-value" title="${escape(n.value)}">${escape(n.value)}</td>` +
      `<td class="col-status">${statusPill(n)}</td>` +
      `<td>${n.optional ? "yes" : ""}</td>`;
    tr.addEventListener("click", () => selectNode(n.id));
    tbody.appendChild(tr);
  }
}
function statusPill(n) {
  if (n.state === "ok") return `<span class="pill ok"><span class="dot"></span>alive</span>`;
  if (n.state === "warn") return `<span class="pill warn"><span class="dot"></span>offline</span>`;
  return `<span class="pill bad"><span class="dot"></span>dead</span>`;
}
function escape(s) {
  return String(s).replace(/[&<>"']/g, c =>
    ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c]);
}

// ── Detail panel ──────────────────────────────────────────────────────────
function selectNode(id) {
  state.selected = id;
  const body = document.getElementById("body");
  body.classList.toggle("with-detail", !!id);
  if (id) renderDetail(nodeById.get(id));
  markSelected();
  document.querySelectorAll("#table-body tr").forEach(tr =>
    tr.classList.toggle("selected", tr.dataset.id === id));
}
function renderDetail(n) {
  const deps = DATA.edges.filter(e => e.from === n.id).map(e => e.to);
  const consumers = DATA.edges.filter(e => e.to === n.id).map(e => e.from);
  const el = document.getElementById("detail-content");
  const stateText = n.state === "ok" ? "Alive"
                  : n.state === "warn" ? "Offline (optional)" : "Dead";
  const detailLine = n.detail ? `<div class="desc" style="margin-top:6px;color:var(--fg-soft)">${escape(n.detail)}</div>` : "";
  const repairLine = n.repair_hint
    ? `<pre class="value" style="white-space:pre-wrap;margin-top:6px">${escape(n.repair_hint)}</pre>` : "";
  const descLine = n.description
    ? `<p class="desc">${escape(n.description)}</p>` : `<p class="desc" style="color:var(--fg-muted)">No description.</p>`;
  el.innerHTML = `
    <div class="detail-header">
      <div class="title">${escape(n.id)}</div>
      <span class="type-pill" style="color:${typeColor(n.type)}">${n.type}</span>
      <button class="icon-btn" id="detail-close" title="Close (Esc)">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
      </button>
    </div>
    <div class="detail-section">
      <h3>Status</h3>
      ${statusPill(n)} <span style="font-size:12px;color:var(--fg-muted);margin-left:6px">${stateText}${n.optional ? " · optional" : ""}</span>
      ${detailLine}
      ${repairLine}
    </div>
    <div class="detail-section">
      <h3>Resolved value</h3>
      <div class="value">${escape(n.value)}</div>
    </div>
    <div class="detail-section">
      <h3>Description</h3>
      ${descLine}
    </div>
    <div class="detail-section">
      <h3>Depends on (${deps.length})</h3>
      <div class="dep-list">${
        deps.length
          ? deps.map(d => `<button class="dep-link" data-jump="${escape(d)}">${escape(d)}<span class="arrow">↗</span></button>`).join("")
          : `<span style="font-size:12px;color:var(--fg-muted)">No dependencies.</span>`
      }</div>
    </div>
    <div class="detail-section">
      <h3>Used by (${consumers.length})</h3>
      <div class="dep-list">${
        consumers.length
          ? consumers.map(d => `<button class="dep-link" data-jump="${escape(d)}">${escape(d)}<span class="arrow">↗</span></button>`).join("")
          : `<span style="font-size:12px;color:var(--fg-muted)">No consumers in registry.</span>`
      }</div>
    </div>
  `;
  document.getElementById("detail-close").addEventListener("click", () => selectNode(null));
  el.querySelectorAll(".dep-link").forEach(b =>
    b.addEventListener("click", () => selectNode(b.dataset.jump)));
}

// ── Main render ───────────────────────────────────────────────────────────
function render() {
  if (state.view === "graph") renderGraph();
  else renderTable();
}

// ── Click outside any node clears selection ──────────────────────────────
svg.addEventListener("click", () => selectNode(null));

// ── Initial paint ─────────────────────────────────────────────────────────
buildTypeFilters();
buildStateFilters();
buildTableHead();
render();
</script>
</body>
</html>"""


def cmd_watch(args: argparse.Namespace) -> int:
    interval = getattr(args, "interval", 5.0)
    atlas = _import_atlas()
    try:
        while True:
            # ANSI: move cursor to top-left and clear screen
            sys.stdout.write("\033[H\033[2J")
            sys.stdout.flush()
            ts = time.strftime("%H:%M:%S")
            print(
                f"{_C.BOLD}{_C.CYN}Atlas monitor{_C.RST}  "
                f"{_C.DIM}{ts}  (Ctrl+C to quit, updates every {interval:.0f}s){_C.RST}\n"
            )
            results = atlas.doctor()
            n_ok  = sum(1 for r in results.values() if r.alive)
            n_bad = len(results) - n_ok
            bar_color = _C.GRN if n_bad == 0 else _C.RED
            print(
                f"  {_C.GRN}OK {n_ok}{_C.RST}   "
                f"{bar_color}DEAD {n_bad}{_C.RST}   "
                f"{_C.DIM}total {len(results)}{_C.RST}\n"
            )
            by_type: dict[str, list] = {}
            for r in results.values():
                by_type.setdefault(r.ref_type, []).append(r)
            for ref_type in ["path", "service", "container", "socket", "env_file"]:
                group = by_type.get(ref_type)
                if not group:
                    continue
                print(f"  {_C.BOLD}{ref_type}{_C.RST}")
                for r in sorted(group, key=lambda x: x.name):
                    dot = f"{_C.GRN}●{_C.RST}" if r.alive else f"{_C.RED}●{_C.RST}"
                    lat = f" {_C.DIM}{r.latency_ms:.0f}ms{_C.RST}" if r.latency_ms else ""
                    dead = f" {_C.RED}← {r.detail}{_C.RST}" if not r.alive else ""
                    print(f"    {dot} {r.name:<26}{lat}{dead}")
                print()
            time.sleep(interval)
    except KeyboardInterrupt:
        print("\nMonitor stopped.")
        return 0


def cmd_status(_args: argparse.Namespace) -> int:
    import json as _json
    home    = _laia_config_home()
    atlas_f = home / "atlas.yaml"
    cfg_f   = home / "config.yaml"
    sock    = home / "pathd.sock"

    def _exists(p: Path) -> str:
        return f"{_C.GRN}exists{_C.RST}" if p.exists() else f"{_C.RED}missing{_C.RST}"

    print(f"\n{_C.BOLD}Atlas v{_VERSION} — status{_C.RST}\n")
    print(f"  config home : {home}")
    print(f"  atlas.yaml  : {_exists(atlas_f)}")
    print(f"  config.yaml : {_exists(cfg_f)}")

    if sock.exists():
        import socket as _s
        req = (_json.dumps({"id": 1, "method": "status", "params": {}}) + "\n").encode()
        try:
            s = _s.socket(_s.AF_UNIX, _s.SOCK_STREAM)
            s.settimeout(0.5)
            s.connect(str(sock))
            s.sendall(req)
            buf = b""
            while b"\n" not in buf:
                chunk = s.recv(4096)
                if not chunk:
                    break
                buf += chunk
            s.close()
            resp = _json.loads(buf.decode().splitlines()[0])
            info = resp.get("result", {})
            print(f"  daemon      : {_C.GRN}running{_C.RST}")
            print(f"  uptime      : {info.get('uptime_s', 0):.0f}s")
            print(f"  paths count : {info.get('paths_count', 0)}")
        except Exception as exc:
            print(f"  daemon      : {_C.YEL}socket exists but not responding{_C.RST} ({exc})")
    else:
        print(f"  daemon      : {_C.DIM}not running{_C.RST}")
    print()
    return 0


def cmd_reload(_args: argparse.Namespace) -> int:
    import json as _json
    home = _laia_config_home()
    sock = home / "pathd.sock"

    if sock.exists():
        import socket as _s
        req = (_json.dumps({"id": 1, "method": "reload", "params": {}}) + "\n").encode()
        try:
            s = _s.socket(_s.AF_UNIX, _s.SOCK_STREAM)
            s.settimeout(1)
            s.connect(str(sock))
            s.sendall(req)
            buf = b""
            while b"\n" not in buf:
                chunk = s.recv(4096)
                if not chunk:
                    break
                buf += chunk
            s.close()
            resp  = _json.loads(buf.decode().splitlines()[0])
            changed = resp.get("result", {}).get("changed", False)
            print(f"{_C.GRN}✓{_C.RST} daemon reloaded (changed={changed})")
            return 0
        except Exception as exc:
            _warn(f"daemon not responding: {exc}")

    # Daemon not available — regenerate .env.paths directly
    try:
        from laia_paths import regenerate_env_file  # noqa: PLC0415
        out = regenerate_env_file()
        print(f"daemon not running — regenerated {out}")
        # Also invalidate atlas cache
        _import_atlas().invalidate_cache()
        return 0
    except Exception as exc:
        _die(str(exc))
    return 1


def _scan_consumers(refs: dict, atlas, only_ref: str | None) -> dict:
    """Static scan of the source tree for usages of each reference.

    Detects two classes of usage per ref:
      logical  — atlas.get("X") / get_path("X") / ATLAS_X env var.
      hardcode — the ref's resolved literal coordinate appears verbatim in code
                 (path, host:port, or container name) — a migration candidate.

    Returns {ref_name: {"logical": [str], "hardcode": [str]}} with "file:line".
    """
    import re as _re

    skip_dirs = {".laia-core", ".git", "node_modules", "archived",
                 "archived-skills", "laia-ui", "__pycache__", ".venv", "venv",
                 "workspaces", "mlx-servers"}
    exts = {".py", ".sh", ".bash", ".yaml", ".yml", ".toml", ".service", ".env"}

    names = [only_ref] if only_ref else list(refs)
    if only_ref and only_ref not in refs:
        _die(f"reference {only_ref!r} not in registry")

    # Precompute literal coordinate per ref (best-effort; skip on error).
    literal: dict[str, str] = {}
    for name in names:
        entry = refs.get(name)
        if not isinstance(entry, dict):
            continue
        try:
            val = atlas.get(name)
        except atlas.AtlasError:
            continue
        if entry.get("type") == "service":
            host = str(entry.get("host", "")); port = entry.get("port", "")
            literal[name] = f"{host}:{port}" if host else ""
        else:
            literal[name] = val

    logical_pat = {
        name: _re.compile(
            r'(?:get|get_path|resolve_service)\(\s*["\']' + _re.escape(name) + r'["\']'
            r'|ATLAS_' + _re.escape(name.upper()) + r'\b'
        )
        for name in names
    }

    found: dict[str, dict[str, list]] = {n: {"logical": [], "hardcode": []} for n in names}

    for root, dirs, files in os.walk(_LAIA_ROOT):
        dirs[:] = [d for d in dirs if d not in skip_dirs]
        for fname in files:
            fp = Path(root) / fname
            if fp.suffix not in exts:
                continue
            try:
                lines = fp.read_text(errors="replace").splitlines()
            except OSError:
                continue
            rel = fp.relative_to(_LAIA_ROOT)
            for i, line in enumerate(lines, 1):
                for name in names:
                    if logical_pat[name].search(line):
                        found[name]["logical"].append(f"{rel}:{i}")
                    lit = literal.get(name)
                    if lit and len(lit) > 4 and lit in line:
                        found[name]["hardcode"].append(f"{rel}:{i}")
    return found


def cmd_consumers(args: argparse.Namespace) -> int:
    import json as _json
    atlas = _import_atlas()
    refs  = atlas.all_refs()
    only  = getattr(args, "ref", None)
    data  = _scan_consumers(refs, atlas, only)

    if getattr(args, "json", False):
        print(_json.dumps(data, indent=2))
        return 0

    any_hardcode = False
    print(f"\n{_C.BOLD}Atlas consumers{_C.RST}  {_C.DIM}(inverse graph){_C.RST}")
    for name in sorted(data):
        logical  = data[name]["logical"]
        hardcode = data[name]["hardcode"]
        if not logical and not hardcode:
            continue
        print(f"\n  {_C.CYN}{name}{_C.RST}")
        for loc in logical:
            print(f"    {_C.GRN}✓ atlas{_C.RST}  {loc}")
        for loc in hardcode:
            any_hardcode = True
            print(f"    {_C.YEL}⚠ hardcode{_C.RST}  {loc}")
    used = sum(1 for n in data if data[n]["logical"] or data[n]["hardcode"])
    print(f"\n{_C.DIM}{used}/{len(data)} refs referenced in source.{_C.RST}")
    if any_hardcode:
        print(f"{_C.YEL}⚠ hardcoded coordinates above are migration candidates "
              f"(replace with atlas.get).{_C.RST}")
    print()
    return 0


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="atlas",
        description="Atlas v2 — LAIA reference registry control centre.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="cmd", required=True, metavar="<command>")

    p = sub.add_parser("version", help="Show version")
    p.set_defaults(func=cmd_version)

    p = sub.add_parser("init", help="Bootstrap ~/.laia/atlas.yaml from the template")
    p.add_argument("--force", action="store_true", help="Overwrite an existing registry")
    p.set_defaults(func=cmd_init)

    p = sub.add_parser("get", help="Resolve a reference by name")
    p.add_argument("name")
    p.set_defaults(func=cmd_get)

    p = sub.add_parser("check", help="Health check a single reference")
    p.add_argument("name")
    p.set_defaults(func=cmd_check)

    p = sub.add_parser("validate", help="Validate atlas.yaml schema (no disk checks)")
    p.set_defaults(func=cmd_validate)

    p = sub.add_parser("list", help="List all references")
    p.add_argument("--type", dest="type", default=None,
                   metavar="TYPE",
                   help="Filter by type: path|service|container|socket|env_file")
    p.add_argument("--json", action="store_true", help="JSON output")
    p.set_defaults(func=cmd_list)

    p = sub.add_parser("doctor", help="Health-check all references")
    p.add_argument("--type", dest="type", default=None, metavar="TYPE",
                   help="Only check refs of this type")
    p.add_argument("--fix", action="store_true",
                   help="Offer a guided repair for each broken reference")
    p.add_argument("--yes", action="store_true",
                   help="With --fix: auto-confirm every repair (non-interactive)")
    p.add_argument("--dry-run", dest="dry_run", action="store_true",
                   help="With --fix: print repair actions without running them")
    p.add_argument("--include-optional", dest="include_optional", action="store_true",
                   help="With --fix: also repair optional references")
    p.set_defaults(func=cmd_doctor)

    p = sub.add_parser("env", help="Print bash-sourceable ATLAS_* exports")
    p.set_defaults(func=cmd_env)

    p = sub.add_parser("graph", help="Show reference dependency graph")
    p.add_argument("--from", dest="from_ref", default=None, metavar="REF",
                   help="Start from this reference (show subtree only)")
    p.set_defaults(func=cmd_graph)

    p = sub.add_parser("visualize", help="Generate self-contained HTML webapp of the registry")
    p.add_argument("--output", dest="output", default=None, metavar="FILE",
                   help="Write HTML to FILE instead of opening browser")
    p.add_argument("--no-open", dest="open", action="store_false", default=True,
                   help="Don't open browser automatically")
    p.set_defaults(func=cmd_visualize)

    p = sub.add_parser("watch", help="Live health monitor")
    p.add_argument("--interval", type=float, default=5.0, metavar="SEC")
    p.set_defaults(func=cmd_watch)

    p = sub.add_parser("consumers", help="Show which source files use each reference")
    p.add_argument("--ref", dest="ref", default=None, metavar="REF",
                   help="Only scan for this reference")
    p.add_argument("--json", action="store_true", help="JSON output")
    p.set_defaults(func=cmd_consumers)

    p = sub.add_parser("status", help="Daemon and config file status")
    p.set_defaults(func=cmd_status)

    p = sub.add_parser("reload", help="Reload config (signal daemon or regenerate)")
    p.set_defaults(func=cmd_reload)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = _build_parser()
    args   = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
