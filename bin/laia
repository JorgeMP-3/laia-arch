#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# laia — top-level delegator for the LAIA host-side CLI
#
# Usage:
#   laia <subcommand> [args...]
#
# Subcommands:
#   install    Install LAIA on a clean host           (sudo required)
#   clone      Clone state from another LAIA server   (sudo required for LXD)
#   release    Promote a dev tree to /opt versioned   (sudo required)
#   rollback   Switch /opt symlink back to a prior version (sudo required)
#   init       Bootstrap LAIA-AGORA (LXD images + first user)
#   status     Show host-side LAIA status
#   --help     Show this help
#   --version  Show installed LAIA version
#
# laia is a thin dispatcher: it locates the matching `laia-<subcommand>` binary
# in the same directory and execs it, so subcommands behave identically whether
# they are called as `laia clone` or `laia-clone` directly.
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

# Resolve real path of this script (handles /usr/local/bin/laia symlink).
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
LAIA_ROOT="$(dirname "$SCRIPT_DIR")"
LIB_DIR="$LAIA_ROOT/infra/installer/lib"

# shellcheck source=../infra/installer/lib/common.sh
source "$LIB_DIR/common.sh"
# shellcheck source=../infra/installer/lib/version.sh
source "$LIB_DIR/version.sh"

print_help() {
  cat <<'EOF'
laia — unified CLI for the LAIA ecosystem

USAGE
    laia                       Drop into interactive agent chat (default)
    laia <subcommand> [args]   Run a specific subcommand

INSTALLER / HOST-OPS SUBCOMMANDS (handled by this bash dispatcher)
    install     Install LAIA on a clean host
    clone       Clone state from another LAIA server (data + LXD containers)
    wizard      Interactive wizard (install or clone, menu-driven)
    diagnose    Health check the existing install (read-only)
    reset       Wipe LAIA from this host (DANGEROUS — double confirmation)
    release     Promote a dev tree to /opt/laia-vX.Y.Z and restart
    rollback    Switch /opt/laia symlink back to a previous version
    init        Bootstrap LAIA-AGORA (LXD images + AGORA backend + first user)

AGENT SUBCOMMANDS (forwarded to .laia-core Python CLI)
    chat        Interactive chat with your agent (same as `laia` no-args)
    setup       Interactive setup wizard for credentials/providers
    login/logout/auth   Manage provider credentials
    model       Select default model and provider
    skills      Search, install, configure skills
    plugins     Manage plugins
    gateway     Messaging gateway (Telegram, WhatsApp, Slack, …)
    cron        Cron job management
    doctor      Check configuration and dependencies
    status      Show agent component status
    sessions    Session management
    ...         (anything not matching an installer subcommand)

OPTIONS
    --help, -h        Show this help (installer help)
    --version, -v     Show installed LAIA version

EXAMPLES
    laia                               # open agent chat
    laia setup                         # configure providers/credentials
    laia skills install <slug>         # install a skill
    sudo laia install --version v0.1.0
    laia clone laia-hermes@server.example.com --with-tools
    sudo laia wizard                   # menu-driven install/clone

ENVIRONMENT
    LAIA_UI=textual|rich   Wizard UI. Default textual (since Fase 4).
                           'rich' falls back to a minimal stdin/stdout UI.
EOF
}

print_version() {
  local v
  if v="$(detect_version "$LAIA_ROOT" "" 2>/dev/null)"; then
    printf 'laia %s\n' "$v"
  else
    printf 'laia (unversioned dev tree at %s)\n' "$LAIA_ROOT"
  fi
}

# exec_agent_cli — hand off to the .laia-core Python CLI (interactive chat,
# auth, skills, gateway, etc.). Used when the user invokes `laia` with no
# args or with a non-installer subcommand (chat, setup, auth, login, model,
# skills, …). The Python CLI is installed by `laia-install` into
# /opt/laia/.laia-core/venv/bin/laia; on a dev tree it lives at
# $LAIA_ROOT/.laia-core/venv/bin/laia.
exec_agent_cli() {
  local candidates=(
    "/opt/laia/.laia-core/venv/bin/laia"
    "$LAIA_ROOT/.laia-core/venv/bin/laia"
  )
  local agent_bin=""
  local c
  for c in "${candidates[@]}"; do
    if [[ -x "$c" ]]; then agent_bin="$c"; break; fi
  done
  if [[ -z "$agent_bin" ]]; then
    log_error "Agent CLI not found. Looked in:"
    printf '  %s\n' "${candidates[@]}" >&2
    log_error "Re-run 'sudo laia install' (or 'sudo laia release') to recreate the venv."
    exit 4
  fi
  exec "$agent_bin" "$@"
}

main() {
  if [[ $# -eq 0 ]]; then
    # No args → drop into agent CLI (interactive chat by default).
    # `laia --help` still shows installer help; `laia -h` too. Anything else
    # without a recognized installer subcommand goes to the Python CLI.
    exec_agent_cli
  fi

  case "$1" in
    -h|--help)    print_help; exit 0 ;;
    -v|--version) print_version; exit 0 ;;
    install|clone|release|rollback)
      local sub="$1"; shift
      local target="$SCRIPT_DIR/laia-$sub"
      [[ -x "$target" ]] || die "Subcommand binary not found or not executable: $target"
      exec "$target" "$@"
      ;;
    init)
      # init lives in infra/dev/laia-init.sh — that wizard handles AGORA bootstrap.
      local init_script="$LAIA_ROOT/infra/dev/laia-init.sh"
      [[ -x "$init_script" ]] || die "AGORA init script not found: $init_script"
      shift
      exec bash "$init_script" "$@"
      ;;
    wizard|diagnose|reset)
      # The interactive wizard and its single-screen utilities all share
      # the same Python entry point (laia_cli.install_wizard). bin/laia-wizard
      # used to be a separate shim — Fase 4 of the wizard remake collapsed
      # it into this dispatcher so there's only one public entry.
      local sub="$1"; shift
      local core_dir="$LAIA_ROOT/.laia-core"
      if [[ ! -d "$core_dir/laia_cli/install_wizard" ]]; then
        die "install_wizard package not found at $core_dir/laia_cli/install_wizard"
      fi
      # python3 is hard-required; if missing, try apt as root.
      if ! command -v python3 >/dev/null 2>&1; then
        if [[ "${EUID:-$(id -u)}" -eq 0 ]] && command -v apt-get >/dev/null 2>&1; then
          log_info "Installing python3"
          DEBIAN_FRONTEND=noninteractive apt-get update -qq
          DEBIAN_FRONTEND=noninteractive apt-get install -y python3
        else
          die "python3 not found. Install it manually or re-run as root."
        fi
      fi
      # Prefer the .laia-core install venv (where Textual lives); else system python.
      local py="python3"
      if [[ -x "$core_dir/venv/bin/python" ]]; then
        py="$core_dir/venv/bin/python"
      elif [[ -x "/opt/laia/.laia-core/venv/bin/python" ]]; then
        py="/opt/laia/.laia-core/venv/bin/python"
      fi
      export LAIA_ROOT
      export PYTHONPATH="$core_dir${PYTHONPATH:+:$PYTHONPATH}"
      local log_dir="${XDG_CACHE_HOME:-$HOME/.cache}"
      mkdir -p "$log_dir" 2>/dev/null || true
      printf '[%s] laia %s %s\n' "$(date -Iseconds)" "$sub" "$*" \
        >>"$log_dir/laia-wizard.log" 2>/dev/null || true
      # TTY reattach is owned by install.sh (curl|bash hand-off) plus
      # __main__._reattach_tty() (last line of defense). NEVER add another
      # /dev/tty redirect here — see workflow/problems.md::wizard-clone-tty.
      if [[ "$sub" == "wizard" ]]; then
        exec "$py" -m laia_cli.install_wizard "$@"
      else
        exec "$py" -m laia_cli.install_wizard --mode "$sub" "$@"
      fi
      ;;
    *)
      # Not an installer subcommand → assume it's for the agent CLI
      # (status, chat, setup, auth, login, model, skills, plugins, gateway,
      # cron, doctor, sessions, …). Hand off verbatim.
      exec_agent_cli "$@"
      ;;
  esac
}

main "$@"
