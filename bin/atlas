#!/usr/bin/env python3
"""atlas — LAIA reference registry control center.

Usage:
  atlas init [--force]            Bootstrap ~/.laia/atlas.yaml from template
  atlas get <name>                 Resolve a reference
  atlas check <name>              Health check a single reference
  atlas list [--type T] [--json]  List all references
  atlas doctor [--type T] [--fix] Verify health (--fix repairs what's broken)
  atlas consumers [--ref R]       Which files use each reference
  atlas validate                  Validate atlas.yaml structure
  atlas env                       Export variables (bash-sourceable)
  atlas graph [--from REF]        Show dependency graph
  atlas visualize [--output F]    Generate self-contained HTML webapp of the registry
  atlas watch [--interval N]      Live monitor
  atlas status                    Daemon and file status
  atlas reload                    Reload config
  atlas version                   Show version
"""
from __future__ import annotations

import argparse
import os
import sys
import time
from pathlib import Path

_VERSION = "2.0.0"

# Make .laia-core importable from any working directory
_LAIA_ROOT = Path(__file__).resolve().parents[1]
_CORE = _LAIA_ROOT / ".laia-core"
if str(_CORE) not in sys.path:
    sys.path.insert(0, str(_CORE))


def _import_atlas():
    try:
        import atlas as _atlas
        return _atlas
    except ImportError as exc:
        _die(f"cannot import atlas module from {_CORE}: {exc}")


# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------

class _C:
    """ANSI color codes. Disabled when stdout is not a tty or NO_COLOR is set."""
    _on = sys.stdout.isatty() and not os.environ.get("NO_COLOR")
    RED  = "\033[1;31m" if _on else ""
    GRN  = "\033[1;32m" if _on else ""
    YEL  = "\033[1;33m" if _on else ""
    CYN  = "\033[1;36m" if _on else ""
    DIM  = "\033[2m"    if _on else ""
    RST  = "\033[0m"    if _on else ""
    BOLD = "\033[1m"    if _on else ""


def _die(msg: str, code: int = 1) -> None:
    print(f"atlas: error: {msg}", file=sys.stderr)
    sys.exit(code)


def _warn(msg: str) -> None:
    print(f"atlas: warning: {msg}", file=sys.stderr)


def _laia_config_home() -> Path:
    # Single source of truth for the ARCH runtime/config home (layout v2:
    # /srv/laia/arch, override LAIA_CONFIG_HOME). laia_paths is importable —
    # .laia-core is on sys.path (see _CORE insert above).
    from laia_paths import laia_config_home
    return laia_config_home()


def _confirm(prompt: str, assume_yes: bool = False) -> bool:
    """Ask a y/N question. EOF/non-interactive → no, unless assume_yes."""
    if assume_yes:
        return True
    try:
        reply = input(f"{prompt} [y/N] ").strip().lower()
    except EOFError:
        return False
    return reply in ("y", "yes")


def _run_repair(cmd: str, *, dry_run: bool) -> bool:
    """Run a repair command via the shell. Returns True on success.

    Resilient: never raises — a failed repair is reported and the caller continues.
    """
    import subprocess
    if dry_run:
        print(f"      {_C.DIM}(dry-run) would run:{_C.RST} {cmd}")
        return True
    try:
        proc = subprocess.run(cmd, shell=True)
    except Exception as exc:  # noqa: BLE001 — repair must never crash the loop
        print(f"      {_C.RED}repair failed to launch: {exc}{_C.RST}")
        return False
    if proc.returncode == 0:
        print(f"      {_C.GRN}✓ repair ran{_C.RST}")
        return True
    print(f"      {_C.RED}✗ repair exited {proc.returncode}{_C.RST}")
    return False


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

def cmd_version(_args: argparse.Namespace) -> int:
    print(f"atlas {_VERSION}")
    return 0


def _template_path() -> Path:
    return _LAIA_ROOT / "infra" / "pathd" / "atlas.yaml.example"


def cmd_init(args: argparse.Namespace) -> int:
    """Bootstrap ~/.laia/atlas.yaml from the versioned template (idempotent)."""
    import shutil
    dest = _laia_config_home() / "atlas.yaml"
    src  = _template_path()

    if not src.exists():
        _die(f"template not found at {src}")

    if dest.exists() and not getattr(args, "force", False):
        print(f"{_C.GRN}✓{_C.RST} registry already present: {dest}")
        print(f"  {_C.DIM}use --force to overwrite from template{_C.RST}")
        return 0

    dest.parent.mkdir(parents=True, exist_ok=True)
    shutil.copyfile(src, dest)
    verb = "overwrote" if (dest.exists() and getattr(args, "force", False)) else "created"
    print(f"{_C.GRN}✓{_C.RST} {verb} {dest}")
    print(f"  {_C.DIM}from {src}{_C.RST}")
    print(f"  next: {_C.CYN}atlas doctor{_C.RST}")
    return 0


def cmd_get(args: argparse.Namespace) -> int:
    atlas = _import_atlas()
    try:
        print(atlas.get(args.name))
        return 0
    except atlas.AtlasKeyError as exc:
        _die(str(exc))
    except atlas.AtlasConfigError as exc:
        _die(str(exc))
    return 1  # unreachable but satisfies type checkers


def cmd_check(args: argparse.Namespace) -> int:
    """Health check a single reference and report result."""
    atlas = _import_atlas()
    r = atlas.health(args.name)
    mark = f"{_C.GRN}✓{_C.RST}" if r.alive else f"{_C.RED}✗{_C.RST}"
    lat  = f" {_C.DIM}{r.latency_ms:.0f}ms{_C.RST}" if r.latency_ms is not None else ""
    print(f"{mark} {r.name} [{r.ref_type}] = {_C.DIM}{r.value}{_C.RST}{lat}")
    print(f"  {r.detail}")
    if not r.alive and r.repair_hint:
        print(f"  {_C.DIM}fix: {r.repair_hint}{_C.RST}")
    return 0 if r.alive else 1


def cmd_validate(args: argparse.Namespace) -> int:
    """Validate atlas.yaml schema — reports errors without checking disk."""
    atlas = _import_atlas()
    errors = atlas.validate_registry()
    if not errors:
        print(f"{_C.GRN}✓{_C.RST} atlas.yaml is valid ({len(atlas.all_refs())} refs)")
        return 0
    print(f"{_C.RED}✗{_C.RST} atlas.yaml has {len(errors)} error(s):\n")
    for err in errors:
        print(f"  {_C.RED}•{_C.RST} {err}")
    return 1


def cmd_list(args: argparse.Namespace) -> int:
    import json as _json
    atlas = _import_atlas()
    refs = atlas.all_refs()

    filter_type: str | None = getattr(args, "type", None)
    if filter_type:
        refs = {k: v for k, v in refs.items()
                if isinstance(v, dict) and v.get("type") == filter_type}

    if not refs:
        print("(no references" + (f" of type {filter_type!r}" if filter_type else "") + ")")
        return 0

    if getattr(args, "json", False):
        out: dict = {}
        for name, entry in refs.items():
            try:
                out[name] = {
                    "type":        entry.get("type", "path"),
                    "value":       atlas.get(name),
                    "description": entry.get("description", ""),
                }
            except atlas.AtlasError as exc:
                out[name] = {"type": entry.get("type"), "error": str(exc)}
        print(_json.dumps(out, indent=2))
        return 0

    # Group by type for human output
    by_type: dict[str, list[tuple[str, dict]]] = {}
    for name, entry in refs.items():
        t = entry.get("type", "path") if isinstance(entry, dict) else "?"
        by_type.setdefault(t, []).append((name, entry))

    type_order = ["path", "service", "container", "socket", "env_file"]
    all_types  = type_order + [t for t in by_type if t not in type_order]

    for ref_type in all_types:
        entries = by_type.get(ref_type)
        if not entries:
            continue
        print(f"\n{_C.BOLD}{_C.CYN}{ref_type.upper()}S{_C.RST}")
        for name, entry in sorted(entries):
            try:
                value = atlas.get(name)
                desc  = entry.get("description", "") if isinstance(entry, dict) else ""
                desc_str = f"  {_C.DIM}{desc}{_C.RST}" if desc else ""
                print(f"  {_C.GRN}{name:<28}{_C.RST}{value}{desc_str}")
            except atlas.AtlasError as exc:
                print(f"  {_C.RED}{name:<28}{_C.RST}{_C.RED}<{exc}>{_C.RST}")
    print()
    return 0


def _doctor_fix(results: dict, args: argparse.Namespace) -> None:
    """Walk broken references and offer a repair action for each.

    Resilient: a failed/declined repair is reported and the loop continues.
    """
    assume_yes      = getattr(args, "yes", False)
    dry_run         = getattr(args, "dry_run", False)
    include_optional = getattr(args, "include_optional", False)

    # Registry missing entirely → suggest init and stop.
    if "__config__" in results:
        print(f"\n{_C.BOLD}Repair{_C.RST}")
        print(f"  registry unreadable — run {_C.CYN}atlas init{_C.RST} to bootstrap it")
        return

    broken = [r for r in results.values()
              if not r.alive and (include_optional or not r.optional)]
    if not broken:
        return

    print(f"\n{_C.BOLD}Repair{_C.RST}  {_C.DIM}({len(broken)} reference(s)"
          f"{' — dry-run' if dry_run else ''}){_C.RST}")
    for r in broken:
        tag = f"{_C.YEL}~{_C.RST}" if r.optional else f"{_C.RED}✗{_C.RST}"
        print(f"\n  {tag} {r.name} [{r.ref_type}] — {r.detail}")

        # 1. Missing path → offer mkdir -p
        if r.ref_type == "path" and "does not exist" in r.detail:
            cmd = f"mkdir -p {r.value!r}"
            if dry_run or _confirm(f"      create directory {r.value}?", assume_yes):
                _run_repair(cmd, dry_run=dry_run)
            continue

        # 2. Declared repair_hint → offer to run it
        if r.repair_hint:
            print(f"      hint: {_C.CYN}{r.repair_hint}{_C.RST}")
            if dry_run or _confirm("      run this command?", assume_yes):
                _run_repair(r.repair_hint, dry_run=dry_run)
            continue

        # 3. No automated fix available
        print(f"      {_C.DIM}no automated repair — edit ~/.laia/atlas.yaml "
              f"or add a repair_hint{_C.RST}")


def cmd_doctor(args: argparse.Namespace) -> int:
    atlas = _import_atlas()
    filter_type: str | None = getattr(args, "type", None)
    results = atlas.doctor()

    if filter_type:
        results = {k: v for k, v in results.items() if v.ref_type == filter_type}

    if not results:
        print("(no references to check)")
        return 0

    # Group by type
    by_type: dict[str, list] = {}
    for r in results.values():
        by_type.setdefault(r.ref_type, []).append(r)

    type_order = ["path", "service", "container", "socket", "env_file"]
    all_types  = type_order + [t for t in by_type if t not in type_order]

    bad: list[str] = []
    warn: list[str] = []
    for ref_type in all_types:
        group = by_type.get(ref_type)
        if not group:
            continue
        print(f"\n{_C.BOLD}{_C.CYN}{ref_type.upper()}S{_C.RST}")
        for r in sorted(group, key=lambda x: x.name):
            if r.alive:
                mark = f"{_C.GRN}✓{_C.RST}"
            elif r.optional:
                mark = f"{_C.YEL}~{_C.RST}"
                warn.append(r.name)
            else:
                mark = f"{_C.RED}✗{_C.RST}"
                bad.append(r.name)
            lat = f" {_C.DIM}{r.latency_ms:.0f}ms{_C.RST}" if r.latency_ms is not None else ""
            print(f"  {mark} {r.name:<28}{_C.DIM}{r.value}{_C.RST}{lat}")
            if not r.alive and not r.optional:
                print(f"      {_C.RED}→ {r.detail}{_C.RST}")
            elif not r.alive and r.optional:
                print(f"      {_C.YEL}→ {r.detail}{_C.RST}")
            if not r.alive and r.repair_hint:
                print(f"      {_C.DIM}fix: {r.repair_hint}{_C.RST}")

    # ── Guided repair (--fix) ────────────────────────────────────────────
    if getattr(args, "fix", False):
        _doctor_fix(results, args)

    total = len(results)
    n_bad = len(bad)
    n_warn = len(warn)
    print()
    if n_bad == 0 and n_warn == 0:
        print(f"{_C.GRN}{_C.BOLD}All {total} references OK{_C.RST}")
        return 0
    if n_bad == 0:
        print(f"{_C.YEL}{_C.BOLD}{n_warn} optional reference(s) offline{_C.RST}  ({', '.join(warn)})")
        return 0
    parts = [f"{_C.RED}{_C.BOLD}{n_bad} of {total} reference(s) DEAD{_C.RST}  ({', '.join(bad)})"]
    if n_warn:
        parts.append(f"{_C.YEL}{n_warn} optional offline{_C.RST}  ({', '.join(warn)})")
    print("\n".join(parts))
    print(f"{_C.DIM}  Edit ~/.laia/atlas.yaml to fix values.{_C.RST}")
    return 1


def cmd_env(_args: argparse.Namespace) -> int:
    atlas = _import_atlas()
    refs  = atlas.all_refs()
    lines = ["# Atlas v2 — auto-generated, do not edit"]
    for name, entry in sorted(refs.items()):
        if not isinstance(entry, dict):
            continue
        ref_type = entry.get("type", "path")
        if ref_type not in ("path", "service", "socket"):
            continue
        try:
            value = atlas.get(name)
            print(f'export ATLAS_{name.upper()}="{value}"')
        except atlas.AtlasError:
            pass
    return 0


def cmd_graph(args: argparse.Namespace) -> int:
    import re as _re
    atlas = _import_atlas()
    refs  = atlas.all_refs()

    # Build dependency map from ${ref.X} occurrences
    deps: dict[str, list[str]] = {}
    for name, entry in refs.items():
        if not isinstance(entry, dict):
            deps[name] = []
            continue
        text = " ".join(str(v) for v in entry.values() if isinstance(v, str))
        found = _re.findall(r"\$\{ref\.([^}]+)\}", text)
        # Deduplicate while preserving order
        seen: list[str] = []
        for k in found:
            if k not in seen:
                seen.append(k)
        deps[name] = seen

    from_ref: str | None = getattr(args, "from_ref", None)
    if from_ref:
        if from_ref not in refs:
            _die(f"reference {from_ref!r} not in registry")
        reachable: set[str] = set()
        queue = [from_ref]
        while queue:
            n = queue.pop()
            if n in reachable:
                continue
            reachable.add(n)
            queue.extend(deps.get(n, []))
        items = {k: v for k, v in deps.items() if k in reachable}
    else:
        items = deps

    # Topological order (roots first)
    ordered: list[str] = []
    visiting: set[str] = set()
    visited:  set[str] = set()

    def _visit(n: str) -> None:
        if n in visited:
            return
        if n in visiting:
            return  # cycle — skip gracefully
        visiting.add(n)
        for dep in deps.get(n, []):
            _visit(dep)
        visiting.discard(n)
        visited.add(n)
        ordered.append(n)

    for n in items:
        _visit(n)

    print(f"\n{_C.BOLD}Atlas dependency graph{_C.RST}\n")
    for name in reversed(ordered):
        dep_list = items.get(name, [])
        ref_type = refs.get(name, {}).get("type", "?") if isinstance(refs.get(name), dict) else "?"
        prefix = f"  {_C.CYN}{name}{_C.RST} {_C.DIM}[{ref_type}]{_C.RST}"
        if dep_list:
            dep_str = f" ← {', '.join(_C.YEL + d + _C.RST for d in dep_list)}"
        else:
            dep_str = f" {_C.DIM}(root){_C.RST}"
        print(f"{prefix}{dep_str}")
    print()
    return 0


def cmd_visualize(args: argparse.Namespace) -> int:
    """Generate a self-contained HTML visualization of the Atlas registry.

    Renders a force-directed graph + sortable table using plain SVG and
    vanilla JS — no external libraries, no network at runtime, no install
    step beyond the existing CLI. The HTML opens directly from ``file://``.
    """
    import json as _json
    import re as _re

    atlas = _import_atlas()
    refs = atlas.all_refs()

    # ── Build node + edge dataset ───────────────────────────────────────────
    # One node per ref. One edge per ``${ref.X}`` dependency found in any
    # string value of the entry. Health and resolved value are computed eagerly
    # so the HTML stays self-contained (no callbacks to runtime atlas).
    nodes: list[dict] = []
    edges: list[dict] = []
    seen_edges: set[tuple[str, str]] = set()

    for name, entry in refs.items():
        if not isinstance(entry, dict):
            continue
        ref_type = entry.get("type", "path")
        optional = bool(entry.get("optional", False))
        description = entry.get("description", "") or ""
        repair_hint = entry.get("repair_hint", "") or ""

        try:
            resolved = atlas.get(name)
        except atlas.AtlasError as exc:  # noqa: BLE001 — surface error to UI
            resolved = f"<error: {exc}>"

        try:
            health = atlas.health(name)
            alive = bool(health.alive)
            detail = health.detail or ""
            latency_ms = float(health.latency_ms) if health.latency_ms else 0.0
        except Exception as exc:  # noqa: BLE001
            alive = True
            detail = f"health check raised: {exc}"
            latency_ms = 0.0

        # State trichotomy: alive → ok ; dead+optional → warn ; dead → bad
        if alive:
            state = "ok"
        elif optional:
            state = "warn"
        else:
            state = "bad"

        nodes.append({
            "id": name,
            "type": ref_type,
            "value": str(resolved),
            "description": description,
            "optional": optional,
            "state": state,
            "alive": alive,
            "detail": detail,
            "latency_ms": latency_ms,
            "repair_hint": repair_hint,
        })

        # Dependencies: order-preserving deduplication of ${ref.X} mentions.
        text = " ".join(str(v) for v in entry.values() if isinstance(v, str))
        for dep in _re.findall(r"\$\{ref\.([^}]+)\}", text):
            pair = (name, dep)
            if pair in seen_edges:
                continue
            seen_edges.add(pair)
            edges.append({"from": name, "to": dep})

    node_ids = {n["id"] for n in nodes}
    edges = [e for e in edges if e["to"] in node_ids]

    # ── Aggregate stats for the header strip ────────────────────────────────
    by_type: dict[str, int] = {}
    by_state = {"ok": 0, "warn": 0, "bad": 0}
    for n in nodes:
        by_type[n["type"]] = by_type.get(n["type"], 0) + 1
        by_state[n["state"]] = by_state.get(n["state"], 0) + 1

    payload = {
        "generated_at": time.strftime("%Y-%m-%d %H:%M:%S %z").strip(),
        "registry_path": str(atlas._atlas_config_path()),
        "version": _VERSION,
        "nodes": nodes,
        "edges": edges,
        "stats": {
            "total": len(nodes),
            "by_type": by_type,
            "by_state": by_state,
            "edges": len(edges),
        },
    }

    html = _HTML_TEMPLATE.replace(
        "__ATLAS_DATA__",
        _json.dumps(payload, indent=None, separators=(",", ":")),
    )

    output = getattr(args, "output", None)
    open_browser = bool(getattr(args, "open", True))

    if output:
        Path(output).write_text(html, encoding="utf-8")
        print(f"{_C.GRN}✓{_C.RST} wrote {output}")
        if open_browser:
            _open_in_browser(output)
        return 0

    import tempfile
    with tempfile.NamedTemporaryFile("w", suffix=".html", delete=False, encoding="utf-8") as f:
        f.write(html)
        path = f.name
    print(f"{_C.GRN}✓{_C.RST} wrote {path}")
    if open_browser:
        _open_in_browser(path)
    return 0


def _open_in_browser(path: str) -> None:
    """Open a local file in the default browser via ``file://`` URL."""
    import webbrowser
    import urllib.parse
    url = "file://" + urllib.parse.quote(path)
    print(f"  opening {url}")
    webbrowser.open(url)


