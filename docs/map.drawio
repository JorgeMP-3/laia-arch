                <mxCell id="3SB" value="Ciclo de vida de tarea:&lt;br&gt;1. POST /api/tasks → 2. send_task() → inbox/{id}.json&lt;br&gt;3. process_once() → execute_task() → 16 tipos + plugins&lt;br&gt;4. done/{id}.json (ok) o failed/{id}.json (error)&lt;br&gt;5. read_task_result() → lxc exec cat done/{id}.json" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontSize=10;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="850" y="100" width="500" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="3TP" value="16 Task Types: ping · write_file · read_file · delete_file · list_dir · workspace_* (6 ops) · profile_* (3 ops) · skill_enable/disable · + plugins via PluginRegistry" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontSize=10;arcSize=8;" parent="1" vertex="1">
