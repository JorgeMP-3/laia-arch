    <diagram id="p5" name="5. laia-runtime">
        <mxGraphModel dx="726" dy="555" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="780" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="5T" value="laia-runtime v0.1.0 — Task Processor del Agente Hijo" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;fontColor=#2E7D32;" parent="1" vertex="1">
                    <mxGeometry x="200" y="5" width="900" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="5C" value="&lt;b&gt;config.py — AgentConfig&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px&#39;&gt;Lee /opt/laia/agent.json&lt;br&gt;employee · container · root&lt;br&gt;workspace_db · heartbeat (5s)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fillColor=#43A047;strokeColor=#43A04788;fontColor=#FFFFFF;fontSize=10;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="55" width="220" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="5D" value="&lt;b&gt;daemon.py ★ MAIN ★&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px&#39;&gt;Bucle infinito (5s heartbeat)&lt;br&gt;signal handlers (TERM/INT)&lt;br&gt;1. write_status() → status.json&lt;br&gt;2. process_once() → lee inbox&lt;br&gt;3. sleep(heartbeat)&lt;br&gt;Llama: config · health · plugins · profile · tasks&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fillColor=#2E7D32;strokeColor=#2E7D3288;fontColor=#FFFFFF;fontSize=10;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="290" y="55" width="280" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="5P" value="&lt;b&gt;profile.py&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px&#39;&gt;persona.md · instructions.md&lt;br&gt;skills.json · preferences.json&lt;br&gt;ensure_profile() · get_profile()&lt;br&gt;update_profile() · set_skill()&lt;br&gt;Lock: fcntl.flock()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fillColor=#388E3C;strokeColor=#388E3C88;fontColor=#FFFFFF;fontSize=10;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="160" width="220" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="5W" value="&lt;b&gt;workspace.py&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px&#39;&gt;WorkspaceStore vendored&lt;br&gt;SQLite workspace.db (aislado)&lt;br&gt;init_workspace() · status()&lt;br&gt;upsert_node() · get_node()&lt;br&gt;list_nodes() · search_nodes()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fillColor=#388E3C;strokeColor=#388E3C88;fontColor=#FFFFFF;fontSize=10;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="290" width="220" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="5T2" value="&lt;b&gt;tasks.py — 16 tipos&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px&#39;&gt;process_once() · execute_task()&lt;br&gt;ping · write_file · read_file&lt;br&gt;delete_file · list_dir&lt;br&gt;workspace_* (6 ops)&lt;br&gt;profile_* (3 ops)&lt;br&gt;skill_enable/disable&lt;br&gt;+ PluginRegistry dispatch&lt;br&gt;_safe_workspace_path() sandbox&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fillColor=#2E7D32;strokeColor=#2E7D3288;fontColor=#FFFFFF;fontSize=10;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="290" y="195" width="280" height="165" as="geometry"/>
                </mxCell>
                <mxCell id="5H" value="&lt;b&gt;health.py&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px&#39;&gt;HTTP server :9090/health&lt;br&gt;JSON response · Thread daemon&lt;br&gt;stdlib http.server&lt;br&gt;set_healthcheck() fn&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fillColor=#81C784;strokeColor=#81C78488;fontColor=#1B5E20;fontSize=10;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="650" y="55" width="230" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="5PL" value="&lt;b&gt;plugins.py&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px&#39;&gt;PluginRegistry class&lt;br&gt;.register(task_type, handler)&lt;br&gt;.dispatch(task_type) → handler&lt;br&gt;load_plugins() from *.py files&lt;br&gt;Patterns: register() or TASKS dict&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fillColor=#81C784;strokeColor=#81C78488;fontColor=#1B5E20;fontSize=10;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="650" y="165" width="230" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="5CM" value="&lt;b&gt;Como AGORA habla con el daemon&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px&#39;&gt;1. Escribe inbox JSON (orchestrator.send_task → lxc exec)&lt;br&gt;2. Lee done/failed JSON (orchestrator.read_task_result → lxc exec)&lt;br&gt;3. Ejecuta Python inline (orchestrator._exec_python → lxc exec python -c)&lt;br&gt;4. Healthcheck (orchestrator.get_agent_status → lxc exec healthcheck.sh)&lt;br&gt;5. Service status (lxc exec systemctl is-active laia-agent)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fillColor=#E8F5E9;strokeColor=#E8F5E988;fontColor=#1B5E20;fontSize=10;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="420" width="700" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="5SY" value="&lt;b&gt;systemd/laia-agent.service&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px&#39;&gt;Type=simple · User=laia-agent&lt;br&gt;ExecStart=python -m laia_agent&lt;br&gt;PYTHONPATH=/opt/laia/agent/src&lt;br&gt;Restart=always (3s)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fillColor=#C8E6C9;strokeColor=#C8E6C988;fontColor=#1B5E20;fontSize=10;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="530" width="250" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="5LY" value="&lt;b&gt;Layout del contenedor&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px&#39;&gt;/opt/laia/: agent.json · agent/src/laia_agent/ · runtime/venv/ | workspaces/personal/workspace.db&lt;br&gt;data/tasks/: inbox/ · done/ · failed/ | data/profile/: persona.md · instructions.md · skills.json · preferences.json&lt;br&gt;plugins/ · logs/agent.log · data/status.json&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fillColor=#E8F5E9;strokeColor=#E8F5E988;fontColor=#1B5E20;fontSize=10;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="645" width="650" height="72" as="geometry"/>
