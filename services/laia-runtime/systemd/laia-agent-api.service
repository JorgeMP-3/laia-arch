[Unit]
Description=LAIA personal agent HTTP API (AGORA bridge)
After=network-online.target laia-agent.service
Wants=network-online.target
Requires=laia-agent.service

[Service]
Type=simple
User=laia-agent
Group=laia-agent
WorkingDirectory=/opt/laia/agent
Environment=PYTHONPATH=/opt/laia/agent/src
Environment=PYTHONDONTWRITEBYTECODE=1
ExecStart=/opt/laia/runtime/venv/bin/python -m uvicorn laia_agent.api:app --host 0.0.0.0 --port 9090
Restart=always
RestartSec=3

# Security hardening: child agents must not escalate or touch host paths.
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/laia/data /opt/laia/logs
ProtectHome=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
