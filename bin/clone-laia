#!/usr/bin/env bash
# ══════════════════════════════════════════════════════════════════════════════
# install-laia — Instalador Definitivo del Ecosistema LAIA
# ══════════════════════════════════════════════════════════════════════════════
# LAIA = Local AI Agent — Ecosistema multi-agente empresarial
# Medios: ARCH (admin) | AGORA (colectivo, pendiente)
# Núcleo: Hermes Agent (fork de NousResearch) + Workspace UI (FastAPI + React)
#
# Uso:
#   clone-laia [opciones]
#
# Opciones:
#   --restore USER@HOST    Restaura estado completo (workspaces, memories, config,
#                          auth, sessions, skills, .codex, .opencode, cc1, cc2)
#   --setup-server         Wizard interactivo para configurar el servidor completo
#                          (Claude cc1+cc2, Codex, OpenCode, NVM, PM2, Tailscale,
#                          Docker, Nginx, Samba, UFW, Git)
#   --no-services          No instalar servicios systemd
#   --nginx DOMINIO        Configurar nginx para el dominio
#   --no-deps              Omitir instalación de paquetes del sistema
#   --dir RUTA             Directorio base (default: ~/LAIA)
#   --yes, -y              Modo no interactivo
#   --help, -h             Mostrar ayuda
#   --version, -v          Mostrar versión
#
# Instalación rápida (repo privado — requiere gh CLI autenticado):
#
#   # 1) requisitos mínimos
#   sudo apt update && sudo apt install -y git curl gh
#
#   # 2) autenticar GitHub (abre navegador o pega token)
#   gh auth login
#
#   # 3) bootstrap del wizard (descarga clone-laia y lo ejecuta)
#   bash <(gh api -H "Accept: application/vnd.github.v3.raw" \
#            repos/JorgeMP-3/laia-arch/contents/bin/clone-laia)
#
#   # alternativa equivalente con token explícito:
#   curl -fsSL -H "Authorization: Bearer $(gh auth token)" \
#     https://raw.githubusercontent.com/JorgeMP-3/laia-arch/main/bin/clone-laia | bash
# ══════════════════════════════════════════════════════════════════════════════
set -euo pipefail

# ── Metadata ─────────────────────────────────────────────────────────────────
readonly INSTALLER_VERSION="2.7.1"
readonly INSTALLER_DATE="2026-05-11"

# ── Colores ──────────────────────────────────────────────────────────────────
if [[ -n "${NO_COLOR:-}" ]]; then
  YEL=''; GRN=''; RED=''; CYN=''; DIM=''; RST=''; BLD=''
else
  YEL='\033[1;33m'; GRN='\033[1;32m'; RED='\033[1;31m'
  CYN='\033[1;36m'; DIM='\033[2m'; RST='\033[0m'; BLD='\033[1m'
fi

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_DIR="${XDG_CACHE_HOME:-$HOME/.cache}"
LOG_FILE="$LOG_DIR/laia-install.log"
mkdir -p "$LOG_DIR"
: >"$LOG_FILE"
exec > >(tee -a "$LOG_FILE") 2>&1

# ── Helpers ──────────────────────────────────────────────────────────────────
ok()    { echo -e "${GRN}  ✓ $1${RST}"; }
info()  { echo -e "${CYN}  → $1${RST}"; }
err()   { echo -e "${RED}  ✕ $1${RST}\n" >&2; exit 1; }
warn()  { echo -e "${YEL}  ⚠ $1${RST}"; }
fail()  { echo -e "${RED}  ✕ $1${RST}"; }

# step: numeración dinámica — solo cuenta los pasos realmente ejecutados.
STEP_NUM=0
step()  {
  STEP_NUM=$((STEP_NUM + 1))
  echo -e "\n${YEL}${BLD}═══ ${STEP_NUM}  $1 ═══════════════════════════════════════════════════${RST}"
}

ask()   {
  printf "${BLD}  %s ${DIM}%s${RST} " "$1" "${2:-}"
  if ! read -r REPLY </dev/tty 2>/dev/null; then
    REPLY=""
    if [[ "${OPT_YES:-false}" == false ]]; then
      echo ""
      warn "No hay terminal interactiva. Usa --yes para modo no interactivo."
      exit 1
    fi
  fi
}
log()   { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"; }

# run_step: ejecuta un comando y solo imprime ok si REALMENTE tuvo éxito.
#   uso: run_step "etiqueta éxito" "etiqueta fallo" -- comando args...
run_step() {
  local ok_msg="$1" fail_msg="$2"; shift 2
  [[ "${1:-}" == "--" ]] && shift
  if "$@"; then ok "$ok_msg"; return 0; fi
  warn "$fail_msg"; return 1
}

# npm_global_install: instala paquetes globales sin pedir sudo.
#
# Estrategia:
#  1. Si NVM está instalado (~/.nvm/nvm.sh existe) usar SU prefix — fijar uno
#     custom en ~/.npmrc rompe `nvm install/use` con error 11.
#  2. Si /usr/lib/node_modules es escribible, usarlo directo.
#  3. Si nada, configurar ~/.npm-global como prefix por usuario.
NPM_PREFIX_CONFIGURED=false
_setup_npm_prefix() {
  [[ "$NPM_PREFIX_CONFIGURED" == true ]] && return 0
  command -v npm &>/dev/null || return 1

  # 1) NVM disponible — cárgalo y usa su entorno (sin tocar ~/.npmrc).
  if [[ -s "$HOME/.nvm/nvm.sh" ]]; then
    export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
    # shellcheck source=/dev/null
    . "$HOME/.nvm/nvm.sh" 2>/dev/null || true
    if command -v nvm &>/dev/null; then
      # Si ~/.npmrc tiene prefix= dejado por una versión vieja del script,
      # quitarlo — interfiere con NVM.
      if [[ -f "$HOME/.npmrc" ]] && grep -qE '^(prefix|globalconfig)=' "$HOME/.npmrc"; then
        sed -i.bak -E '/^(prefix|globalconfig)=/d' "$HOME/.npmrc"
        info "Limpiado prefix/globalconfig de ~/.npmrc (incompatible con NVM)"
      fi
      NPM_PREFIX_CONFIGURED=true
      return 0
    fi
  fi

  # 2) ¿npm prefix del sistema escribible?
  local sys_prefix; sys_prefix="$(npm config get prefix 2>/dev/null || echo)"
  if [[ -n "$sys_prefix" && -d "$sys_prefix/lib/node_modules" && -w "$sys_prefix/lib/node_modules" ]]; then
    NPM_PREFIX_CONFIGURED=true
    return 0
  fi
  if [[ -n "$sys_prefix" && ! -e "$sys_prefix/lib/node_modules" && -w "$sys_prefix" ]]; then
    NPM_PREFIX_CONFIGURED=true
    return 0
  fi

  # 3) Fallback: prefix por usuario.
  local user_prefix="$HOME/.npm-global"
  mkdir -p "$user_prefix/bin" "$user_prefix/lib/node_modules"
  npm config set prefix "$user_prefix" >/dev/null 2>&1 || true
  case ":$PATH:" in *":$user_prefix/bin:"*) ;; *) export PATH="$user_prefix/bin:$PATH" ;; esac
  for rc in "$HOME/.bashrc" "$HOME/.zshrc"; do
    [[ -f "$rc" ]] || continue
    grep -q 'npm-global/bin' "$rc" 2>/dev/null || \
      echo 'export PATH="$HOME/.npm-global/bin:$PATH"  # LAIA: npm globals sin sudo' >> "$rc"
  done
  info "npm prefix → ${user_prefix} (globals sin sudo)"
  NPM_PREFIX_CONFIGURED=true
  return 0
}

npm_global_install() {
  _setup_npm_prefix || { warn "npm no disponible"; return 1; }
  npm install -g "$@" 2>&1 | tail -3
  local rc="${PIPESTATUS[0]}"
  # Refrescar hash table de bash para que el comando recién instalado
  # esté disponible en esta misma sesión sin reabrir shell.
  hash -r 2>/dev/null || true
  return "$rc"
}

# _bin_version: imprime la versión de un comando aunque acabe de instalarse
# y no esté en la hash table. Busca en PATH y en ~/.npm-global/bin.
_bin_version() {
  local cmd="$1"
  local exe
  exe="$(command -v "$cmd" 2>/dev/null)"
  [[ -z "$exe" && -x "$HOME/.npm-global/bin/$cmd" ]] && exe="$HOME/.npm-global/bin/$cmd"
  [[ -z "$exe" ]] && { echo "no encontrado"; return 1; }
  "$exe" --version 2>/dev/null | head -1 || echo "?"
}

# _docker_setup: deja $DOCKER apuntando al binario correcto (docker / "sudo docker" / "").
DOCKER=""
_docker_setup() {
  if ! command -v docker &>/dev/null; then
    DOCKER=""
    return 1
  fi
  if docker info &>/dev/null; then
    DOCKER="docker"; return 0
  fi
  if ! groups "$CURRENT_USER" 2>/dev/null | grep -qw docker; then
    info "Añadiendo ${CURRENT_USER} al grupo docker (necesita re-login para aplicar)..."
    sudo usermod -aG docker "$CURRENT_USER" 2>/dev/null || true
  fi
  if sudo -n docker info &>/dev/null; then
    warn "Usando 'sudo docker' (re-login para usar docker sin sudo)."
    DOCKER="sudo docker"; return 0
  fi
  warn "Docker sin permisos — re-login o ejecuta 'newgrp docker' antes."
  DOCKER=""
  return 1
}

# ── Rollback ─────────────────────────────────────────────────────────────────
ROLLBACK_ITEMS=()
register_rollback() { ROLLBACK_ITEMS+=("$1"); }

cleanup_on_error() {
  local code=$?
  if [[ $code -ne 0 ]]; then
    echo "" >&2
    echo -e "${RED}${BLD}  ✕ Instalación interrumpida (código $code)${RST}" >&2
    if [[ ${#ROLLBACK_ITEMS[@]} -gt 0 ]]; then
      echo -e "${DIM}  Revirtiendo cambios...${RST}" >&2
      for item in "${ROLLBACK_ITEMS[@]}"; do eval "$item" 2>/dev/null || true; done
    fi
    echo -e "${DIM}  Log: $LOG_FILE${RST}" >&2
  fi
}
trap cleanup_on_error EXIT

# ── Parseo de argumentos ─────────────────────────────────────────────────────
OPT_RESTORE=""
OPT_SERVICES=true
OPT_NGINX=""
OPT_DEPS=true
OPT_YES=false
OPT_BACKUP_LOCAL=false
OPT_SETUP_SERVER=false
LAIA_DIR="${LAIA_INSTALL_DIR:-$HOME/LAIA}"

while [[ $# -gt 0 ]]; do
  case $1 in
    --restore)
      [[ $# -ge 2 && -n "$2" ]] || err "--restore requiere USER@HOST"
      OPT_RESTORE="$2"; shift 2 ;;
    --setup-server) OPT_SETUP_SERVER=true; shift ;;
    --no-services) OPT_SERVICES=false; shift ;;
    --nginx)
      [[ $# -ge 2 && -n "$2" ]] || err "--nginx requiere DOMINIO"
      OPT_NGINX="$2"; shift 2 ;;
    --no-deps) OPT_DEPS=false; shift ;;
    --dir)
      [[ $# -ge 2 && -n "$2" ]] || err "--dir requiere RUTA"
      LAIA_DIR="$2"; shift 2 ;;
    --backup-local) OPT_BACKUP_LOCAL=true; shift ;;
    --yes|-y) OPT_YES=true; shift ;;
    --help|-h)
      sed -n '/^# ══/,/^# ══/p;/^# Uso:/,/^# ══/p' "$0" | sed 's/^# //;s/^#//'
      exit 0 ;;
    --version|-v)
      echo "install-laia $INSTALLER_VERSION ($INSTALLER_DATE)"
      exit 0 ;;
    *) err "Opción desconocida: $1\n  Usa --help para ver opciones." ;;
  esac
done

# ── Variables principales ────────────────────────────────────────────────────
REPO_CODE="https://github.com/JorgeMP-3/laia-arch.git"
REPO_PRIVATE="https://github.com/JorgeMP-3/laia-private.git"
REPO_LAIA_UI="https://github.com/JorgeMP-3/laia-ui.git"

CODE_DIR="$LAIA_DIR/.laia-arch"
VENV="$CODE_DIR/venv"
WS_BACKEND="$CODE_DIR/workspace-ui/backend"
WS_FRONTEND="$CODE_DIR/workspace-ui/frontend"

RUNTIME_DIR="$HOME/.hermes"
BIN_DIR="$HOME/bin"
SERVER_DIR="$HOME/servidor"

CURRENT_USER="$(id -un)"
CURRENT_UID="$(id -u)"

# ── Detectar OS ──────────────────────────────────────────────────────────────
if [[ "$(uname)" == "Darwin" ]]; then
  OS="macos"; DISTRO=""
elif [[ "$(uname)" == "Linux" ]]; then
  OS="linux"
  if   command -v apt-get &>/dev/null; then DISTRO="debian"
  elif command -v dnf    &>/dev/null; then DISTRO="fedora"
  elif command -v pacman &>/dev/null; then DISTRO="arch"
  else DISTRO="unknown"; fi
else
  OS="unknown"; DISTRO=""
fi

# ── Header ───────────────────────────────────────────────────────────────────
clear 2>/dev/null || true
echo ""
echo -e "${YEL}  ██╗      █████╗ ██╗ █████╗     ███████╗███████╗████████╗██╗   ██╗██████╗ ${RST}"
echo -e "${YEL}  ██║     ██╔══██╗██║██╔══██╗    ██╔════╝██╔════╝╚══██╔══╝██║   ██║██╔══██╗${RST}"
echo -e "${YEL}  ██║     ███████║██║███████║    ███████╗█████╗     ██║   ██║   ██║██████╔╝${RST}"
echo -e "${YEL}  ██║     ██╔══██║██║██╔══██║    ╚════██║██╔══╝     ██║   ██║   ██║██╔═══╝ ${RST}"
echo -e "${YEL}  ███████╗██║  ██║██║██║  ██║    ███████║███████╗   ██║   ╚██████╔╝██║     ${RST}"
echo -e "${YEL}  ╚══════╝╚═╝  ╚═╝╚═╝╚═╝  ╚═╝   ╚══════╝╚══════╝   ╚═╝    ╚═════╝ ╚═╝     ${RST}"
echo ""
echo -e "${DIM}  Instalador de LAIA · Ecosistema Multi-Agente · v${INSTALLER_VERSION}${RST}"
echo -e "${DIM}  Sistema: ${OS}${DISTRO:+ ($DISTRO)}  ·  Usuario: ${CURRENT_USER}  ·  Destino: ${LAIA_DIR}${RST}"
echo ""

# ── Detección de estado de cada componente ──────────────────────────────────
_check_state() {
  # Imprime "✓" si OK, "⚠" si parcial/desactualizado, "?" si no detectado.
  case "$1" in
    deps)
      command -v git &>/dev/null && command -v python3 &>/dev/null \
        && command -v node &>/dev/null && command -v gh &>/dev/null \
        && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    code)
      [[ -d "$CODE_DIR/.git" ]] && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    venv)
      [[ -x "$VENV/bin/hermes" ]] && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    frontend)
      [[ -d "$WS_FRONTEND/dist" ]] && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    runtime)
      [[ -L "$LAIA_DIR/hermes-agent" ]] && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    bin)
      [[ -d "$BIN_DIR" && -n "$(ls -A "$BIN_DIR" 2>/dev/null)" ]] \
        && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    env)
      grep -q 'HERMES_HOME' "$HOME/.bashrc" 2>/dev/null \
        && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    systemd)
      [[ -f /etc/systemd/system/hermes.service ]] \
        && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    nginx)    command -v nginx &>/dev/null && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    tailscale) command -v tailscale &>/dev/null && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    cc1)      command -v claude    &>/dev/null && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    cc2)      [[ -e "$HOME/.claude-cuenta2/.credentials.json" ]] && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    codex)    command -v codex     &>/dev/null && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    opencode) [[ -x "$HOME/.opencode/bin/opencode" ]] && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    nvm)      [[ -d "$HOME/.nvm" ]] && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    pm2)      command -v pm2       &>/dev/null && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    docker)   command -v docker    &>/dev/null && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    samba)    command -v smbd      &>/dev/null && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    ufw)      command -v ufw       &>/dev/null && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    gitcfg)   [[ -n "$(git config --global user.email 2>/dev/null)" ]] && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    laia_ui)  [[ -d "$LAIA_DIR/laia-ui/.git" ]] && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    pnpm)     command -v pnpm      &>/dev/null && echo "${GRN}✓${RST}" || echo "${YEL}?${RST}" ;;
    *)        echo "${YEL}?${RST}" ;;
  esac
}

# Flags WANT_*: qué bloques se ejecutarán. Default: nada activado;
# se pinta el menú y el usuario decide. --yes activa los que faltan.
WANT_DEPS=false; WANT_CODE=false; WANT_VENV=false; WANT_FRONTEND=false
WANT_RUNTIME=false; WANT_BIN=false; WANT_ENV=false
WANT_SYSTEMD=false; WANT_NGINX_STEP=false; WANT_TAILSCALE=false; WANT_SSH=false
WANT_RESTORE=false; WANT_START=false
WANT_CC1=false; WANT_CC2=false; WANT_CODEX=false; WANT_OPENCODE=false
WANT_NVM=false; WANT_PM2=false; WANT_DOCKER=false; WANT_SAMBA=false
WANT_UFW=false; WANT_GITCFG=false
WANT_LAIA_UI=false

_print_menu() {
  echo -e "  ${BLD}Estado actual y componentes:${RST}"
  echo ""
  echo -e "  ${BLD}Núcleo LAIA${RST}"
  printf "   %b  1) Dependencias del sistema   %b\n" "$(_check_state deps)"     "${DIM}git/python3/node v22/gh${RST}"
  printf "   %b  2) Clonar/actualizar repos    %b\n" "$(_check_state code)"     "${DIM}laia-arch + laia-private${RST}"
  printf "   %b  3) Entorno Python (venv)      %b\n" "$(_check_state venv)"     "${DIM}venv + hermes-agent + deps backend${RST}"
  printf "   %b  4) Workspace UI frontend      %b\n" "$(_check_state frontend)" "${DIM}legacy — Vite/React, vite build${RST}"
  printf "   %b  5) Symlinks runtime + bin     %b\n" "$(_check_state runtime)"  "${DIM}LAIA/, ~/.hermes/, wrappers hermes/laia-arch${RST}"
  printf "   %b  6) Scripts ~/bin              %b\n" "$(_check_state bin)"      "${DIM}clone-laia, gsave, sclaude, wrappers${RST}"
  printf "   %b  7) Variables de entorno       %b\n" "$(_check_state env)"      "${DIM}.bashrc + .zshrc${RST}"
  echo ""
  echo -e "  ${BLD}Servidor${RST}"
  printf "   %b  8) Servicios systemd          %b\n" "$(_check_state systemd)"   "${DIM}hermes + workspace-ui${RST}"
  printf "   %b  9) Nginx proxy reverso        %b\n" "$(_check_state nginx)"     "${DIM}requiere --nginx DOMINIO${RST}"
  printf "   %b 10) Tailscale                  %b\n" "$(_check_state tailscale)" "${DIM}red privada${RST}"
  printf "   %b 11) SSH + Restore              %b\n" "$([[ -f "$HOME/.ssh/id_ed25519" ]] && echo -n "${GRN}✓${RST}" || echo -n "${YEL}?${RST}")" "${DIM}requiere --restore USER@HOST${RST}"
  printf "   %b 12) Arrancar servicios         %b\n" "$([[ -f /etc/systemd/system/hermes.service ]] && systemctl is-active --quiet hermes 2>/dev/null && echo -n "${GRN}✓${RST}" || echo -n "${YEL}?${RST}")" "${DIM}systemctl start hermes + workspace-ui${RST}"
  echo ""
  echo -e "  ${BLD}CLI tools${RST}"
  printf "   %b 13) Claude Code cc1            %b\n" "$(_check_state cc1)"      "${DIM}cuenta principal${RST}"
  printf "   %b 14) Claude Code cc2 (Docker)   %b\n" "$(_check_state cc2)"      "${DIM}cuenta secundaria${RST}"
  printf "   %b 15) Codex CLI                  %b\n" "$(_check_state codex)"    "${DIM}OpenAI/GPT${RST}"
  printf "   %b 16) OpenCode CLI               %b\n" "$(_check_state opencode)" "${DIM}Minimax${RST}"
  printf "   %b 17) NVM + Node v22             %b\n" "$(_check_state nvm)"      "${DIM}gestor de Node${RST}"
  printf "   %b 18) PM2                        %b\n" "$(_check_state pm2)"      "${DIM}process manager${RST}"
  printf "   %b 19) Docker                     %b\n" "$(_check_state docker)"   "${DIM}engine + grupo del usuario${RST}"
  printf "   %b 20) Samba                      %b\n" "$(_check_state samba)"    "${DIM}compartir con Mac${RST}"
  printf "   %b 21) UFW Firewall               %b\n" "$(_check_state ufw)"      "${DIM}22/80/443/8077${RST}"
  printf "   %b 22) Git config global          %b\n" "$(_check_state gitcfg)"   "${DIM}user.name + user.email${RST}"
  echo ""
  echo -e "  ${BLD}Nueva UI${RST}"
  printf "   %b 23) laia-ui (nueva UI)         %b\n" "$(_check_state laia_ui)"  "${DIM}monorepo pnpm+turbo (arch + agora)${RST}"
  printf "   %b      └─ pnpm                   %b\n" "$(_check_state pnpm)"     "${DIM}requerido para 23${RST}"
  echo ""
  echo -e "  ${DIM}  ${BLD}todo${RST}${DIM}  = todos los pasos que falten   ·   ${BLD}nada${RST}${DIM} = cancelar${RST}"
  echo -e "  ${DIM}  ${BLD}base${RST}${DIM}  = solo núcleo LAIA (1-7) + symlinks${RST}"
  echo -e "  ${DIM}  ${BLD}servidor${RST}${DIM} = núcleo + systemd + arrancar (1-8, 12)${RST}"
  echo ""
}

_apply_choice() {
  case "$1" in
    1)  WANT_DEPS=true ;;
    2)  WANT_CODE=true ;;
    3)  WANT_VENV=true ;;
    4)  WANT_FRONTEND=true ;;
    5)  WANT_RUNTIME=true ;;
    6)  WANT_BIN=true ;;
    7)  WANT_ENV=true ;;
    8)  WANT_SYSTEMD=true ;;
    9)  WANT_NGINX_STEP=true ;;
    10) WANT_TAILSCALE=true ;;
    11) WANT_SSH=true; WANT_RESTORE=true ;;
    12) WANT_START=true ;;
    13) WANT_CC1=true ;;
    14) WANT_CC2=true ;;
    15) WANT_CODEX=true ;;
    16) WANT_OPENCODE=true ;;
    17) WANT_NVM=true ;;
    18) WANT_PM2=true ;;
    19) WANT_DOCKER=true ;;
    20) WANT_SAMBA=true ;;
    21) WANT_UFW=true ;;
    22) WANT_GITCFG=true ;;
    23) WANT_LAIA_UI=true ;;
  esac
  return 0
}

_select_missing() {
  # Selecciona los pasos cuyo estado es "?" (no detectado).
  command -v git     &>/dev/null && command -v python3 &>/dev/null \
    && command -v node &>/dev/null && command -v gh &>/dev/null \
    || WANT_DEPS=true
  [[ -d "$CODE_DIR/.git" ]]           || WANT_CODE=true
  [[ -x "$VENV/bin/hermes" ]]         || WANT_VENV=true
  [[ -d "$WS_FRONTEND/dist" ]]        || WANT_FRONTEND=true
  [[ -L "$LAIA_DIR/hermes-agent" ]]   || WANT_RUNTIME=true
  WANT_BIN=true; WANT_ENV=true
  [[ -f /etc/systemd/system/hermes.service ]] || WANT_SYSTEMD=true
  [[ -d "$LAIA_DIR/laia-ui/.git" ]]   || WANT_LAIA_UI=true
  WANT_START=true
}

_apply_set() {
  # "todo" = núcleo + servidor + opcionales detectables + laia-ui
  case "$1" in
    todo)
      for n in 1 2 3 4 5 6 7 8 10 12 13 14 15 16 17 18 19 23; do _apply_choice "$n"; done
      [[ -n "$OPT_NGINX"   ]] && WANT_NGINX_STEP=true
      [[ -n "$OPT_RESTORE" ]] && _apply_choice 11
      ;;
    base)
      for n in 1 2 3 4 5 6 7; do _apply_choice "$n"; done ;;
    servidor)
      for n in 1 2 3 4 5 6 7 8 12; do _apply_choice "$n"; done ;;
  esac
  return 0
}

# Activaciones forzadas por flags CLI
if [[ -n "$OPT_NGINX"   ]]; then WANT_NGINX_STEP=true; fi
if [[ -n "$OPT_RESTORE" ]]; then WANT_TAILSCALE=true; WANT_SSH=true; WANT_RESTORE=true; fi
if [[ "$OPT_SERVICES" == false ]]; then WANT_SYSTEMD=false; WANT_START=false; fi

if [[ "$OPT_YES" == true ]]; then
  # Modo no interactivo: instala lo que falte + lo pedido por flags
  _select_missing
  if [[ -n "$OPT_NGINX"   ]]; then WANT_NGINX_STEP=true; fi
  if [[ -n "$OPT_RESTORE" ]]; then WANT_TAILSCALE=true; WANT_SSH=true; WANT_RESTORE=true; fi
  if [[ "$OPT_SETUP_SERVER" == true ]]; then
    command -v claude    &>/dev/null || WANT_CC1=true
    [[ -e "$HOME/.claude-cuenta2/.credentials.json" ]] || WANT_CC2=true
    command -v codex     &>/dev/null || WANT_CODEX=true
    [[ -x "$HOME/.opencode/bin/opencode" ]] || WANT_OPENCODE=true
    command -v node      &>/dev/null || WANT_NVM=true
    command -v pm2       &>/dev/null || WANT_PM2=true
    command -v tailscale &>/dev/null || WANT_TAILSCALE=true
    command -v docker    &>/dev/null || WANT_DOCKER=true
  fi
  [[ -d "$LAIA_DIR/laia-ui/.git" ]] || WANT_LAIA_UI=true
  if [[ "$OPT_SERVICES" == false ]]; then WANT_SYSTEMD=false; WANT_START=false; fi
else
  _print_menu
  ask "Selección (números, 'todo', 'base', 'servidor', 'nada'):" ""
  REPLY_LOWER="$(echo "$REPLY" | tr '[:upper:]' '[:lower:]' | xargs)"
  case "$REPLY_LOWER" in
    nada|n|"")
      info "Cancelado."; exit 0 ;;
    todo|base|servidor)
      _apply_set "$REPLY_LOWER" ;;
    *)
      # Lista de números separados por espacios o comas
      IFS=' ,' read -ra _CHOICES <<< "$REPLY_LOWER"
      for c in "${_CHOICES[@]}"; do
        [[ "$c" =~ ^[0-9]+$ ]] && _apply_choice "$c"
      done
      ;;
  esac
fi

# Resumen de lo que se va a hacer
_pending=()
$WANT_DEPS      && _pending+=("deps")
$WANT_CODE      && _pending+=("clonar-repos")
$WANT_VENV      && _pending+=("python-venv")
$WANT_FRONTEND  && _pending+=("frontend-build")
$WANT_RUNTIME   && _pending+=("symlinks")
$WANT_BIN       && _pending+=("scripts-bin")
$WANT_ENV       && _pending+=("env-rc")
$WANT_SYSTEMD   && _pending+=("systemd")
$WANT_NGINX_STEP && _pending+=("nginx")
$WANT_TAILSCALE && _pending+=("tailscale")
$WANT_SSH       && _pending+=("ssh-keys")
$WANT_RESTORE   && _pending+=("restore")
$WANT_START     && _pending+=("start-services")
$WANT_CC1       && _pending+=("cc1")
$WANT_CC2       && _pending+=("cc2")
$WANT_CODEX     && _pending+=("codex")
$WANT_OPENCODE  && _pending+=("opencode")
$WANT_NVM       && _pending+=("nvm")
$WANT_PM2       && _pending+=("pm2")
$WANT_DOCKER    && _pending+=("docker")
$WANT_SAMBA     && _pending+=("samba")
$WANT_UFW       && _pending+=("ufw")
$WANT_GITCFG    && _pending+=("git-config")
$WANT_LAIA_UI   && _pending+=("laia-ui")

if [[ ${#_pending[@]} -eq 0 ]]; then
  info "Nada seleccionado. Salgo."
  exit 0
fi

echo ""
echo -e "  ${BLD}Se ejecutará:${RST} ${DIM}${_pending[*]}${RST}"
if [[ "$OPT_YES" == false ]]; then
  ask "¿Confirmar y continuar? (s/n)" ""
  [[ "$REPLY" =~ ^[SsYy]$ ]] || { info "Cancelado."; exit 0; }
fi

# ══════════════════════════════════════════════════════════════════════════════
# Dependencias del sistema
# ══════════════════════════════════════════════════════════════════════════════
if [[ "$WANT_DEPS" == true && "$OPT_DEPS" == true && "$OS" == "linux" && "$DISTRO" == "debian" ]]; then
  step "Dependencias del sistema"

  PKGS=()
  command -v git     &>/dev/null || PKGS+=("git")
  command -v python3 &>/dev/null || PKGS+=("python3")
  command -v curl    &>/dev/null || PKGS+=("curl")
  command -v rsync   &>/dev/null || PKGS+=("rsync")

  # python3-venv específico de la versión actual
  if ! python3 -c "import ensurepip" &>/dev/null 2>&1; then
    PY_VER=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null || echo "")
    if [[ -n "$PY_VER" ]]; then PKGS+=("python${PY_VER}-venv" "python3-pip")
    else PKGS+=("python3-venv" "python3-pip"); fi
  fi

  if [[ ${#PKGS[@]} -gt 0 ]]; then
    warn "Faltan: ${PKGS[*]}"
    sudo apt-get update -qq || true
    sudo apt-get install -y --no-install-recommends "${PKGS[@]}"
    ok "Paquetes instalados"
  else
    ok "Dependencias base OK"
  fi

  # Node.js v22 LTS
  NODE_MAJOR=0
  if command -v node &>/dev/null; then
    NODE_MAJOR=$(node --version 2>/dev/null | sed -n 's/^v\([0-9]*\).*/\1/p') || NODE_MAJOR=0
  fi
  if [[ "$NODE_MAJOR" -lt 18 ]]; then
    warn "Node.js ${NODE_MAJOR:-no} → instalando v22..."
    curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash - || err "NodeSource falló"
    sudo apt-get install -y --no-install-recommends nodejs
    ok "Node.js $(node --version)"
  else
    ok "Node.js $(node --version)"
  fi

  # GitHub CLI
  if ! command -v gh &>/dev/null; then
    warn "gh CLI → instalando..."
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | sudo dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg 2>/dev/null
    printf 'deb [arch=%s signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main\n' \
      "$(dpkg --print-architecture)" | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null
    sudo apt-get update -qq && sudo apt-get install -y --no-install-recommends gh
    ok "gh CLI $(gh --version | head -1 | awk '{print $3}')"
  else
    ok "gh CLI $(gh --version | head -1 | awk '{print $3}')"
  fi
fi

# ══════════════════════════════════════════════════════════════════════════════
# Verificación de dependencias (siempre se ejecuta, ligero)
# ══════════════════════════════════════════════════════════════════════════════
if $WANT_DEPS || $WANT_CODE || $WANT_VENV || $WANT_FRONTEND; then
  step "Verificando dependencias"

  MISSING=()
  for cmd in git python3 node npm gh; do
    if command -v "$cmd" &>/dev/null; then
      ver=$("$cmd" --version 2>&1 | head -1)
      ok "$cmd — ${ver:-desconocido}"
    else
      MISSING+=("$cmd")
      echo -e "${RED}  ✕ $cmd — no encontrado${RST}"
    fi
  done
  [[ ${#MISSING[@]} -eq 0 ]] || err "Instala antes (selecciona 1 en el menú): ${MISSING[*]}"
fi

# ══════════════════════════════════════════════════════════════════════════════
# Autenticación GitHub (solo si vamos a clonar)
# ══════════════════════════════════════════════════════════════════════════════
if $WANT_CODE; then
  step "Autenticación GitHub"

  if gh auth status &>/dev/null; then
    _ghuser=$(gh api user --jq .login 2>/dev/null || echo "?")
    ok "GitHub — $_ghuser"
  else
    err "No autenticado. Ejecuta 'gh auth login' primero."
  fi
fi

# ══════════════════════════════════════════════════════════════════════════════
# Clonar repos
# ══════════════════════════════════════════════════════════════════════════════
if $WANT_CODE; then
  step "Clonando repositorios"

mkdir -p "$LAIA_DIR"

# Código → LAIA/.laia-arch
if [[ -d "$CODE_DIR/.git" ]]; then
  warn "$CODE_DIR existe — actualizando..."
  git -C "$CODE_DIR" pull -q || err "git pull falló"
  ok "laia-arch actualizado ($(git -C "$CODE_DIR" rev-parse --short HEAD 2>/dev/null || echo '?'))"
else
  info "Clonando laia-arch..."
  git clone "$REPO_CODE" "$CODE_DIR" -q || err "git clone falló"
  ok "laia-arch clonado"
fi

# Upstream NousResearch
if ! git -C "$CODE_DIR" remote | grep -q '^upstream$'; then
  git -C "$CODE_DIR" remote add upstream https://github.com/NousResearch/hermes-agent.git
  ok "upstream añadido"
fi

  # Datos personales → LAIA/ (laia-private)
  if [[ ! -f "$LAIA_DIR/.git/config" ]]; then
    info "Inicializando laia-private..."
    git -C "$LAIA_DIR" init -q
    git -C "$LAIA_DIR" remote add origin "$REPO_PRIVATE"
    git -C "$LAIA_DIR" pull origin main -q 2>/dev/null || true
    ok "laia-private configurado"
  else
    git -C "$LAIA_DIR" pull origin main -q 2>/dev/null || true
    ok "laia-private actualizado"
  fi
fi  # end WANT_CODE

# ══════════════════════════════════════════════════════════════════════════════
# Entorno Python
# ══════════════════════════════════════════════════════════════════════════════
if $WANT_VENV; then
  step "Entorno Python"

  [[ -d "$CODE_DIR/.git" ]] || err "Falta el código — selecciona 2 (clonar) antes que 3 (venv)."

  if [[ ! -x "$VENV/bin/pip" ]]; then
    [[ -d "$VENV" ]] && { warn "Venv incompleto — recreando..."; rm -rf "$VENV"; }
    info "Creando venv en $VENV..."
    python3 -m venv "$VENV" || err "No se pudo crear venv. Instala python$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')-venv"
    register_rollback "rm -rf '$VENV'"
  fi

  info "Instalando hermes-agent (esto tarda)..."
  "$VENV/bin/pip" install --upgrade pip --disable-pip-version-check 2>&1 \
    | grep -E '^(Successfully|Collecting|Requirement|ERROR)' || true

  "$VENV/bin/pip" install -e "$CODE_DIR" --disable-pip-version-check 2>&1 \
    | grep -E '^(Successfully|Collecting|Installing|Building|ERROR|error:)' || true
  if [[ "${PIPESTATUS[0]}" -eq 0 ]]; then
    ok "hermes-agent instalado"
  else
    err "pip install -e falló (exit ${PIPESTATUS[0]})"
  fi

  if [[ -f "$WS_BACKEND/requirements.txt" ]]; then
    info "Instalando dependencias del backend..."
    # Capturamos el log completo y mostramos solo líneas útiles, pero
    # NUNCA dejamos que el exit code de `grep` decida el éxito — usamos
    # el de `pip` vía PIPESTATUS.
    PIP_BACKEND_LOG="$LOG_DIR/laia-pip-backend.log"
    "$VENV/bin/pip" install -r "$WS_BACKEND/requirements.txt" \
         --disable-pip-version-check 2>&1 \
         | tee "$PIP_BACKEND_LOG" \
         | grep -E '^(Successfully|Installing|Building|ERROR|error:|fatal:|note:)' \
         || true
    PIP_RC="${PIPESTATUS[0]}"
    if [[ "$PIP_RC" -eq 0 ]]; then
      ok "Backend deps OK"
    else
      warn "Backend deps fallaron (pip exit $PIP_RC)"
      echo -e "${DIM}  Últimas líneas del log:${RST}"
      tail -10 "$PIP_BACKEND_LOG" | sed 's/^/    /'
      echo -e "${DIM}  Log completo: ${PIP_BACKEND_LOG}${RST}"
    fi
  fi
fi

# ══════════════════════════════════════════════════════════════════════════════
# Workspace UI Frontend
# ══════════════════════════════════════════════════════════════════════════════
if $WANT_FRONTEND; then
  step "Workspace UI — Frontend"

  [[ -d "$CODE_DIR/.git" ]] || err "Falta el código — selecciona 2 (clonar) antes que 4 (frontend)."

  if [[ -f "$WS_FRONTEND/package.json" ]]; then
    info "Instalando dependencias Node (esto tarda)..."
    # Sin --silent para ver progreso de paquetes. --no-fund + --no-audit
    # reducen ruido sin ocultar lo importante.
    if [[ -f "$WS_FRONTEND/package-lock.json" ]]; then
      (cd "$WS_FRONTEND" && npm ci --no-fund --no-audit) || err "npm ci falló"
    else
      (cd "$WS_FRONTEND" && npm install --no-fund --no-audit) || err "npm install falló"
    fi

    info "Compilando (vite build)..."
    (cd "$WS_FRONTEND" && npm run build 2>&1) | tail -5
    [[ -d "$WS_FRONTEND/dist" ]] || err "Build no generó dist/"
    ok "Frontend compilado"
  else
    warn "No se encontró package.json — omitiendo frontend"
  fi
fi

# ══════════════════════════════════════════════════════════════════════════════
# Symlinks y estructura de runtime
# ══════════════════════════════════════════════════════════════════════════════
if $WANT_RUNTIME; then
  step "Estructura de symlinks"

  ln -sfn "$CODE_DIR" "$LAIA_DIR/hermes-agent"
  ok "hermes-agent → .laia-arch"

  ln -sfn "$CODE_DIR/workspace-ui" "$LAIA_DIR/workspace-ui"
  ok "workspace-ui → .laia-arch/workspace-ui"

  mkdir -p "$RUNTIME_DIR"
  ln -sfn "$CODE_DIR" "$RUNTIME_DIR/hermes-agent"
  ok "~/.hermes/hermes-agent → .laia-arch"

  ln -sfn "$CODE_DIR/workspace-ui" "$RUNTIME_DIR/workspace-ui"
  ok "~/.hermes/workspace-ui → .laia-arch/workspace-ui"

  mkdir -p "$LAIA_DIR/memories" "$LAIA_DIR/docs" "$LAIA_DIR/config" "$LAIA_DIR/workspaces"
  mkdir -p "$RUNTIME_DIR/memories" "$RUNTIME_DIR/skills" "$RUNTIME_DIR/sessions" "$RUNTIME_DIR/logs" "$RUNTIME_DIR/cron"
fi

# ══════════════════════════════════════════════════════════════════════════════
# Scripts del sistema + wrappers dinámicos
# ══════════════════════════════════════════════════════════════════════════════
if $WANT_BIN; then
  step "Scripts del sistema"

  mkdir -p "$BIN_DIR"

  # Helper: escritura atómica con rename. CRÍTICO para clone-laia, que se
  # auto-sobrescribe: si usamos `cp` (modifica in-place) bash sigue leyendo
  # del disco con offsets nuevos → syntax error. Con `mv` cambia el inode,
  # bash sigue leyendo el archivo viejo (abierto) y el nuevo es para
  # futuras invocaciones.
  _atomic_install_file() {
    local src="$1" dst="$2"
    local tmp; tmp="$(mktemp "$(dirname "$dst")/.laia-tmp.XXXXXX")" || return 1
    cat "$src" > "$tmp" && chmod 755 "$tmp" && mv -f "$tmp" "$dst"
  }

  if [[ -d "$CODE_DIR/bin" ]]; then
    # Copia archivos reales del repo (NO usa --delete para no borrar wrappers).
    # Ignora symlinks del repo: tenían paths absolutos del host de origen.
    for script in "$CODE_DIR/bin/"*; do
      [[ -f "$script" && ! -L "$script" ]] || continue
      _atomic_install_file "$script" "$BIN_DIR/$(basename "$script")" || \
        warn "No se pudo copiar $(basename "$script")"
    done
    ok "Scripts del repo copiados a ~/bin/"
  else
    warn "No hay $CODE_DIR/bin — selecciona 2 (clonar) primero."
  fi

  # Wrappers para binarios del venv con rutas dinámicas (no hardcoded).
  # Idéntico patrón atómico — por si en el futuro un wrapper acaba en uso.
  _create_wrapper() {
    local name="$1" target="$2"
    local dst="$BIN_DIR/$name"
    local tmp; tmp="$(mktemp "$BIN_DIR/.laia-tmp.XXXXXX")" || return 1
    cat > "$tmp" <<EOF
#!/usr/bin/env bash
# Wrapper generado por install-laia — apunta al venv actual
exec "$target" "\$@"
EOF
    chmod 755 "$tmp" && mv -f "$tmp" "$dst"
  }

  if [[ -x "$VENV/bin/hermes" ]]; then
    _create_wrapper "hermes" "$VENV/bin/hermes"
    ln -sf hermes "$BIN_DIR/laia-arch"
    ok "Wrappers hermes + laia-arch → $VENV/bin/hermes"
  else
    warn "No hay $VENV/bin/hermes — selecciona 3 (venv) primero."
  fi

  if [[ -x "$VENV/bin/uvicorn" ]]; then
    _create_wrapper "uvicorn" "$VENV/bin/uvicorn"
    ok "Wrapper uvicorn → $VENV/bin/uvicorn"
  fi

  # Limpia restos de temporales por si algún intento previo se interrumpió.
  rm -f "$BIN_DIR"/.laia-tmp.* 2>/dev/null || true
fi

# ══════════════════════════════════════════════════════════════════════════════
# Variables de entorno
# ══════════════════════════════════════════════════════════════════════════════
if $WANT_ENV; then
  step "Variables de entorno"

SHELL_BLOCK='# LAIA — añadido por install-laia
export HERMES_HOME="'"$LAIA_DIR"'"
export PATH="'"$HOME/bin:$HOME/.local/bin"':$PATH"
'

_inject_rc() {
  local rcfile="$1"
  [[ -f "$rcfile" ]] || return 0
  local tmpfile; tmpfile=$(mktemp)
  awk '
    /# LAIA — añadido por install-laia/ { skip=1; next }
    skip && /^export HERMES_HOME=/ { next }
    skip && /^export PATH=/ { next }
    { skip=0; print }
  ' "$rcfile" > "$tmpfile"
  printf '%s\n' "$SHELL_BLOCK" >> "$tmpfile"
  mv "$tmpfile" "$rcfile"
}

  for rcfile in "$HOME/.bashrc" "$HOME/.zshrc"; do
    _inject_rc "$rcfile" && ok "$(basename "$rcfile") actualizado"
  done

  # config.yaml desde template
  if [[ ! -f "$LAIA_DIR/config.yaml" && -f "$CODE_DIR/config.template.yaml" ]]; then
    cp "$CODE_DIR/config.template.yaml" "$LAIA_DIR/config.yaml"
    ok "config.yaml creado"
  elif [[ -f "$LAIA_DIR/config.yaml" ]]; then
    ok "config.yaml ya existe"
  fi

  # SOUL.md si no existe
  if [[ ! -f "$RUNTIME_DIR/SOUL.md" && -f "$CODE_DIR/SOUL.md" ]]; then
    cp "$CODE_DIR/SOUL.md" "$RUNTIME_DIR/SOUL.md"
    ok "SOUL.md copiado a ~/.hermes/"
  fi
fi  # end WANT_ENV

# ══════════════════════════════════════════════════════════════════════════════
# Servicios systemd
# ══════════════════════════════════════════════════════════════════════════════
if $WANT_SYSTEMD && [[ "$OS" == "linux" ]]; then
  step "Servicios systemd"

  [[ -x "$VENV/bin/hermes" ]] || warn "$VENV/bin/hermes no ejecutable"
  [[ -x "$VENV/bin/uvicorn" ]] || warn "$VENV/bin/uvicorn no ejecutable"

  # Backup
  for svc in hermes workspace-ui; do
    if [[ -f "/etc/systemd/system/${svc}.service" ]]; then
      sudo cp "/etc/systemd/system/${svc}.service" "/etc/systemd/system/${svc}.service.bak.$(date +%s)"
    fi
  done

  sudo tee /etc/systemd/system/hermes.service >/dev/null <<EOF
[Unit]
Description=Hermes Gateway (LAIA)
After=network.target

[Service]
Type=simple
User=${CURRENT_USER}
WorkingDirectory=${CODE_DIR}
ExecStart=${VENV}/bin/hermes gateway run
Restart=always
RestartSec=5
Environment=HOME=${HOME}
Environment=HERMES_HOME=${LAIA_DIR}

[Install]
WantedBy=multi-user.target
EOF
  ok "hermes.service generado"

  sudo tee /etc/systemd/system/workspace-ui.service >/dev/null <<EOF
[Unit]
Description=Workspace UI (LAIA)
After=network.target hermes.service

[Service]
Type=simple
User=${CURRENT_USER}
WorkingDirectory=${WS_BACKEND}
ExecStart=${VENV}/bin/uvicorn main:app --host 0.0.0.0 --port 8077
Restart=always
RestartSec=5
Environment=HOME=${HOME}
Environment=HERMES_HOME=${LAIA_DIR}
Environment=HERMES_VENV=${VENV}

[Install]
WantedBy=multi-user.target
EOF
  ok "workspace-ui.service generado"

  sudo systemctl daemon-reload
  sudo systemctl enable hermes.service workspace-ui.service
  ok "Servicios habilitados"
fi

# ══════════════════════════════════════════════════════════════════════════════
# Nginx
# ══════════════════════════════════════════════════════════════════════════════
if $WANT_NGINX_STEP && [[ "$OS" == "linux" ]]; then
  if [[ -z "$OPT_NGINX" ]]; then
    warn "Nginx requiere --nginx DOMINIO. Re-ejecuta con: clone-laia --nginx tu-dominio"
  else
  step "Nginx — ${OPT_NGINX}"

  if ! command -v nginx &>/dev/null; then
    warn "nginx no está instalado — instalando..."
    sudo apt-get install -y --no-install-recommends nginx || err "No se pudo instalar nginx"
  fi

  if [[ -f "/etc/nginx/sites-available/laia" ]]; then
    sudo cp "/etc/nginx/sites-available/laia" "/etc/nginx/sites-available/laia.bak.$(date +%s)"
  fi

  sudo tee /etc/nginx/sites-available/laia >/dev/null <<EOF
server {
    listen 80;
    server_name ${OPT_NGINX} www.${OPT_NGINX};

    location /workspace/ {
        proxy_pass http://127.0.0.1:8077/;
        proxy_set_header Host \$host;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_http_version 1.1;
        proxy_read_timeout 86400;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8000/;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }

    location / {
        root ${WS_FRONTEND}/dist;
        try_files \$uri \$uri/ /index.html;
        gzip_static on;
    }
}
EOF

  sudo ln -sf /etc/nginx/sites-available/laia /etc/nginx/sites-enabled/laia
  sudo rm -f /etc/nginx/sites-enabled/default 2>/dev/null || true
  sudo nginx -t || err "Config nginx inválida"
  sudo systemctl reload nginx || sudo systemctl restart nginx
  ok "Nginx configurado"
  fi  # end OPT_NGINX guard
fi  # end WANT_NGINX_STEP

# ══════════════════════════════════════════════════════════════════════════════
# Tailscale (red privada)
# ══════════════════════════════════════════════════════════════════════════════
if $WANT_TAILSCALE && [[ "$OS" == "linux" ]]; then
  step "Red privada (Tailscale)"

  if ! command -v tailscale &>/dev/null; then
    warn "Tailscale no encontrado — instalando..."
    curl -fsSL https://tailscale.com/install.sh | sh || warn "Instalación de Tailscale falló"
  fi

  if command -v tailscale &>/dev/null; then
    if tailscale status &>/dev/null; then
      ok "Tailscale activo ($(tailscale ip -4 2>/dev/null || echo '?'))"
    else
      warn "Tailscale instalado pero no conectado"
      echo -e "  ${DIM}Ejecuta: sudo tailscale up${RST}"
      echo -e "  ${DIM}Abre el enlace en tu navegador e inicia sesión${RST}"
    fi
  else
    warn "Tailscale no disponible"
  fi
fi

# ══════════════════════════════════════════════════════════════════════════════
# Claves SSH (para restore)
# ══════════════════════════════════════════════════════════════════════════════
if $WANT_SSH; then
  step "Claves SSH"

  if [[ ! -f "$HOME/.ssh/id_ed25519" ]]; then
    info "Generando clave SSH..."
    mkdir -p "$HOME/.ssh"
    ssh-keygen -t ed25519 -C "${CURRENT_USER}@$(hostname)" -f "$HOME/.ssh/id_ed25519" -N "" || err "No se pudo generar clave SSH"
    ok "Clave SSH generada"
  else
    ok "Clave SSH ya existe"
  fi

  if [[ -n "$OPT_RESTORE" ]]; then
    if ssh -o ConnectTimeout=10 -o BatchMode=yes -o StrictHostKeyChecking=accept-new "$OPT_RESTORE" 'echo ok' &>/dev/null; then
      ok "SSH sin contraseña — conectividad OK"
    else
      warn "SSH requiere autenticación"
      echo ""
      echo -e "  ${BLD}Ejecuta manualmente:${RST}"
      echo -e "  ${DIM}  ssh-copy-id ${OPT_RESTORE}${RST}"
      echo -e "  ${DIM}  (introduce la contraseña del servidor origen una vez)${RST}"
      echo ""
      echo -e "  ${BLD}Alternativa sin SSH:${RST}"
      echo -e "  ${DIM}  clone-laia --backup-local  (en el servidor origen)${RST}"
      echo -e "  ${DIM}  scp backup.tar.gz ${CURRENT_USER}@IP_VM:/tmp/${RST}"
      echo ""
    fi
  fi
fi

# ══════════════════════════════════════════════════════════════════════════════
# Restaurar estado
# ══════════════════════════════════════════════════════════════════════════════
if $WANT_RESTORE; then
  if [[ -z "$OPT_RESTORE" ]]; then
    warn "Restore requiere --restore USER@HOST. Re-ejecuta con: clone-laia --restore usuario@host"
  else
  step "Restaurar estado desde ${OPT_RESTORE}"

  if ssh -o ConnectTimeout=10 -o BatchMode=yes "$OPT_RESTORE" 'echo ok' &>/dev/null; then
    info "Conexión SSH verificada — restaurando..."

    # Determinar rutas en el servidor origen
    SRC_HOME=$(ssh -o ConnectTimeout=10 "$OPT_RESTORE" 'echo $HOME')
    SRC_HERMES_HOME=$(ssh -o ConnectTimeout=10 "$OPT_RESTORE" 'echo ${HERMES_HOME:-$HOME/.hermes}')
    SRC_LAIA_DIR=$(ssh -o ConnectTimeout=10 "$OPT_RESTORE" 'echo ${LAIA_INSTALL_DIR:-$HOME/LAIA}')
    info "Origen: HOME=${SRC_HOME}  HERMES_HOME=${SRC_HERMES_HOME}  LAIA=${SRC_LAIA_DIR}"

    # Helper: rsync de un archivo/directorio remoto al local, con exclude file
    # opcional. Si la fuente no existe, se omite silenciosamente.
    _restore_tree() {
      local src_path="$1" dst_path="$2" label="$3" exclude_file="${4:-}"
      info "Restaurando ${label}..."
      if ! ssh -o ConnectTimeout=10 "$OPT_RESTORE" "test -e '${src_path}'" 2>/dev/null; then
        warn "${label} — no encontrado en origen, omitido"
        return 0
      fi
      mkdir -p "$dst_path"
      local rsync_args=(-az --info=progress2,stats0 --delete-excluded)
      [[ -n "$exclude_file" && -f "$exclude_file" ]] && rsync_args+=("--exclude-from=$exclude_file")
      if rsync "${rsync_args[@]}" "${OPT_RESTORE}:${src_path}/" "$dst_path/"; then
        ok "${label} OK"
      else
        warn "${label} falló"
      fi
    }

    _restore_file() {
      local src_path="$1" dst_path="$2" label="$3"
      info "Restaurando ${label}..."
      if ! ssh -o ConnectTimeout=10 "$OPT_RESTORE" "test -f '${src_path}'" 2>/dev/null; then
        warn "${label} — no encontrado en origen, omitido"
        return 0
      fi
      mkdir -p "$(dirname "$dst_path")"
      if rsync -az "${OPT_RESTORE}:${src_path}" "$dst_path"; then
        ok "${label} OK"
      else
        warn "${label} falló"
      fi
    }

    # ── Exclude file: lo que NO transferimos ─────────────────────────
    # Código (se clona vía git), entornos derivados, caches grandes,
    # symlinks que se recrean, basura del sistema.
    LAIA_EXCLUDES=$(mktemp)
    cat > "$LAIA_EXCLUDES" <<'EXCLUDES'
# Código (clonado vía git)
.laia-arch/
laia-ui/
.laia-ui-link
hermes-agent
workspace-ui

# Entornos derivados
.git/
venv/
node_modules/
.turbo/
**/__pycache__/
**/*.pyc
.pytest_cache/

# Backups y temporales del propio script / editor
*.bak
*.bak.*
*.swp
.DS_Store
._.DS_Store

# Lockfiles de runtime — el agente nuevo creará los suyos
*.lock
gateway.pid
EXCLUDES

    HERMES_EXCLUDES=$(mktemp)
    cat > "$HERMES_EXCLUDES" <<'EXCLUDES'
# Symlinks que recrea el wizard
hermes-agent
workspace-ui
# Lockfiles y temporales
*.lock
.DS_Store
**/__pycache__/
EXCLUDES

    # ── ~/LAIA/ (datos + state.db + workspaces + todo lo demás) ──────
    _restore_tree "${SRC_LAIA_DIR}" "${LAIA_DIR}" "LAIA/ (todo el estado del agente)" "$LAIA_EXCLUDES"

    # ── ~/.hermes/ (runtime espejo) ──────────────────────────────────
    _restore_tree "${SRC_HERMES_HOME}" "${RUNTIME_DIR}" "~/.hermes/ (runtime)" "$HERMES_EXCLUDES"

    rm -f "$LAIA_EXCLUDES" "$HERMES_EXCLUDES"

    # ── Herramientas de IA y configs del usuario (directorio home) ──

    # Claude Code cc1: config user-level + directorio entero (proyectos, MCP)
    # Excluimos snapshots y caches pesados que se regeneran solos.
    _restore_file "${SRC_HOME}/.claude.json" "${HOME}/.claude.json" ".claude.json (cc1 user config)"
    CLAUDE_EXCL=$(mktemp)
    cat > "$CLAUDE_EXCL" <<'X'
shell-snapshots/
ide/
statsig/
__pycache__/
*.log
X
    _restore_tree "${SRC_HOME}/.claude" "${HOME}/.claude" ".claude/ (cc1 sessions/projects)" "$CLAUDE_EXCL"
    rm -f "$CLAUDE_EXCL"

    # Claude Code cc2 — directorio completo de segunda cuenta
    _restore_tree "${SRC_HOME}/.claude-cuenta2" "${HOME}/.claude-cuenta2" ".claude-cuenta2/ (cc2)"

    # Codex — config + auth + state (sin logs pesados)
    CODEX_EXCL=$(mktemp)
    cat > "$CODEX_EXCL" <<'X'
log/
logs/
*.log
sessions/
X
    _restore_tree "${SRC_HOME}/.codex" "${HOME}/.codex" ".codex/ (auth + config)" "$CODEX_EXCL"
    rm -f "$CODEX_EXCL"

    # OpenCode — config (sin binario de 146MB; se reinstala en --setup-server)
    OPEN_EXCL=$(mktemp)
    cat > "$OPEN_EXCL" <<'X'
bin/opencode
X
    _restore_tree "${SRC_HOME}/.opencode" "${HOME}/.opencode" ".opencode/ (config)" "$OPEN_EXCL"
    rm -f "$OPEN_EXCL"

    # Otras CLIs de IA con auth/config
    for d in .copilot .gemini .waveterm; do
      _restore_tree "${SRC_HOME}/${d}" "${HOME}/${d}" "${d}/"
    done

    # Configs del usuario que el agente necesita
    _restore_file "${SRC_HOME}/.gitconfig" "${HOME}/.gitconfig" ".gitconfig (git user global)"

    # PM2 — proceso saved dump (si existe)
    _restore_file "${SRC_HOME}/.pm2/dump.pm2" "${HOME}/.pm2/dump.pm2" ".pm2/dump.pm2 (procesos saved)"

    # Docker — credenciales de registries (si las hay)
    _restore_file "${SRC_HOME}/.docker/config.json" "${HOME}/.docker/config.json" ".docker/config.json (registries)"

  else
    warn "No se puede conectar por SSH a ${OPT_RESTORE}"
    echo -e "  ${DIM}1. Asegúrate de que Tailscale está activo: sudo tailscale up${RST}"
    echo -e "  ${DIM}2. Configura SSH sin contraseña: ssh-copy-id ${OPT_RESTORE}${RST}"
    echo -e "  ${DIM}3. Re-ejecuta: clone-laia --restore ${OPT_RESTORE} --yes${RST}"
    echo ""
  fi
  fi  # end OPT_RESTORE guard
fi  # end WANT_RESTORE

# ══════════════════════════════════════════════════════════════════════════════
# Arrancar servicios
# ══════════════════════════════════════════════════════════════════════════════
if $WANT_START && [[ "$OS" == "linux" ]]; then
  step "Arrancando servicios"

  if systemctl is-system-running &>/dev/null || [[ "$(systemctl is-system-running 2>/dev/null)" == "degraded" ]]; then
    for svc in hermes workspace-ui; do
      if sudo systemctl start "$svc" 2>/dev/null; then
        ok "$svc arrancado"
      else
        warn "$svc falló — journalctl -u $svc -n 30"
      fi
    done
  else
    warn "systemd no disponible — omite arranque"
  fi
fi

# ══════════════════════════════════════════════════════════════════════════════
# Backup local (opcional)
# ══════════════════════════════════════════════════════════════════════════════
if [[ "$OPT_BACKUP_LOCAL" == true ]]; then
  step "Backup local"

  BACKUP_FILE="$HOME/laia-backup-$(date +%Y%m%d_%H%M%S).tar.gz"
  info "Creando backup en $BACKUP_FILE..."

  tar -czf "$BACKUP_FILE" \
    -C "$HOME" \
    .hermes/auth.json \
    .hermes/state.db \
    .hermes/SOUL.md \
    .hermes/memories/ \
    .hermes/sessions/ \
    .hermes/skills/ \
    .hermes/cron/ \
    LAIA/memories/ \
    LAIA/config/ \
    LAIA/workspaces/ \
    LAIA/skills/ \
    LAIA/cron/ \
    LAIA/auth.json \
    LAIA/config.yaml \
    LAIA/SOUL.md \
    LAIA/.env \
    .codex/auth.json \
    .codex/config.toml \
    .codex/state_5.sqlite \
    .opencode/package.json \
    .claude/.credentials.json \
    .claude-cuenta2/ \
    2>/dev/null || true

  if [[ -f "$BACKUP_FILE" ]]; then
    size=$(du -h "$BACKUP_FILE" | cut -f1)
    ok "Backup creado: $BACKUP_FILE ($size)"
    echo ""
    echo -e "  ${BLD}Para transferir a otra máquina:${RST}"
    echo -e "  ${DIM}  scp $BACKUP_FILE usuario@IP_VM:/tmp/${RST}"
    echo -e "  ${DIM}  ssh usuario@IP_VM 'tar -xzf /tmp/$(basename "$BACKUP_FILE") -C ~/'${RST}"
    echo ""
  else
    warn "No se pudo crear el backup"
  fi
fi

# ══════════════════════════════════════════════════════════════════════════════
# CLI tools (cada uno con su propio WANT_*)
# ══════════════════════════════════════════════════════════════════════════════

# ── Claude Code cc1 ─────────────────────────────────────────────────────────
if $WANT_CC1; then
  step "Claude Code cc1"
  if ! command -v claude &>/dev/null; then
    info "Instalando @anthropic-ai/claude-code..."
    if npm_global_install @anthropic-ai/claude-code@latest; then
      ok "Claude Code: $(_bin_version claude)"
    else
      warn "Instalación de Claude Code falló — revisa el log."
    fi
  else
    ok "Claude Code ya instalado: $(_bin_version claude)"
  fi
  if [[ ! -f "$HOME/.claude/.credentials.json" ]]; then
    warn "cc1 necesita OAuth — ejecuta: claude"
  fi
fi

# ── Claude Code cc2 (Docker) ────────────────────────────────────────────────
if $WANT_CC2; then
  step "Claude Code cc2 (Docker)"
  if _docker_setup; then
    if ! $DOCKER ps -a --format '{{.Names}}' 2>/dev/null | grep -q '^claude-secondary$'; then
      info "Creando contenedor claude-secondary..."
      mkdir -p "$HOME/.claude-cuenta2"
      if $DOCKER run -d \
          --name claude-secondary \
          --restart unless-stopped \
          -v "${HOME}/LAIA:/home/claude/LAIA" \
          -v "${HOME}/.claude-cuenta2:/home/claude/.claude" \
          -w "/home/claude/LAIA" \
          node:22-bookworm-slim \
          bash -c "tail -f /dev/null" >/dev/null; then
        ok "Contenedor claude-secondary creado"
        info "Instalando Claude Code dentro del contenedor..."
        if $DOCKER exec claude-secondary bash -c \
            "npm install -g @anthropic-ai/claude-code@latest 2>&1 | tail -3"; then
          ok "Claude Code instalado en contenedor"
        else
          warn "npm install dentro del contenedor falló"
        fi
      else
        warn "No se pudo crear claude-secondary"
      fi
    else
      ok "Contenedor claude-secondary ya existe"
    fi
    if [[ ! -f "$HOME/.claude-cuenta2/.credentials.json" ]]; then
      warn "cc2 necesita OAuth — ejecuta: sclaude  (pedirá autenticación)"
    fi
  else
    warn "Docker no disponible para esta sesión — selecciona 19 (Docker) primero,"
    warn "o cierra sesión y reentra para que el grupo docker se aplique."
  fi
fi

# ── Codex (OpenAI) ──────────────────────────────────────────────────────────
if $WANT_CODEX; then
  step "Codex CLI"
  if ! command -v codex &>/dev/null; then
    info "Instalando @openai/codex..."
    if npm_global_install @openai/codex@latest; then
      ok "Codex: $(_bin_version codex)"
    else
      warn "Instalación de Codex falló — revisa el log."
    fi
  else
    ok "Codex ya instalado: $(_bin_version codex)"
  fi
  if [[ ! -f "$HOME/.codex/auth.json" ]]; then
    warn "Codex necesita OAuth — ejecuta: codex login"
  fi
fi

# ── OpenCode (Minimax) ──────────────────────────────────────────────────────
if $WANT_OPENCODE; then
  step "OpenCode CLI"
  if [[ ! -x "$HOME/.opencode/bin/opencode" ]]; then
    mkdir -p "$HOME/.opencode/bin"
    OC_LATEST=$(curl -s https://api.github.com/repos/sst/opencode/releases/latest \
      | grep '"tag_name"' | cut -d'"' -f4 2>/dev/null || echo "")
    if [[ -n "$OC_LATEST" ]]; then
      OC_URL="https://github.com/sst/opencode/releases/download/${OC_LATEST}/opencode-linux-x64"
      if curl -fL "$OC_URL" -o "$HOME/.opencode/bin/opencode" && chmod +x "$HOME/.opencode/bin/opencode"; then
        ok "OpenCode ${OC_LATEST}"
      else
        warn "Descarga de OpenCode falló — instala desde github.com/sst/opencode"
      fi
    else
      warn "No se pudo obtener versión de OpenCode"
    fi
  else
    ok "OpenCode ya instalado"
  fi
  for rc in "$HOME/.bashrc" "$HOME/.zshrc"; do
    [[ -f "$rc" ]] || continue
    grep -q '.opencode/bin' "$rc" 2>/dev/null || \
      echo 'export PATH="$HOME/.opencode/bin:$PATH"' >> "$rc"
  done
fi

# ── NVM + Node.js v22 ───────────────────────────────────────────────────────
if $WANT_NVM; then
  step "NVM + Node.js v22"
  if [[ ! -d "$HOME/.nvm" ]]; then
    info "Instalando NVM..."
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash || warn "NVM falló"
  fi

  # NVM aborta con exit 11 (no return) si ~/.npmrc tiene prefix= o
  # globalconfig= — eso mataría la shell del script entero. Limpiamos ANTES.
  if [[ -f "$HOME/.npmrc" ]] && grep -qE '^(prefix|globalconfig)=' "$HOME/.npmrc"; then
    info "Limpiando prefix/globalconfig de ~/.npmrc (incompatible con NVM)..."
    sed -i.laia-bak -E '/^(prefix|globalconfig)=/d' "$HOME/.npmrc"
  fi

  # Ejecutar todo el flujo de NVM en SUBSHELL para que un exit/die dentro
  # de las funciones nvm_* no aborte el script padre. La subshell hereda
  # set -e pero su salida la captura el if/else externo.
  if (
    set +e
    export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
    # shellcheck source=/dev/null
    [[ -s "$NVM_DIR/nvm.sh" ]] && . "$NVM_DIR/nvm.sh"
    if ! command -v nvm &>/dev/null; then
      echo "NVM no se cargó — abre una nueva shell o ejecuta: source ~/.bashrc" >&2
      exit 2
    fi
    nvm install 22 && nvm use 22 >/dev/null && nvm alias default 22 >/dev/null
  ); then
    # Recargar en el shell padre para tener `node` y `nvm` accesibles
    # en pasos posteriores (pm2, etc).
    export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
    # shellcheck source=/dev/null
    [[ -s "$NVM_DIR/nvm.sh" ]] && . "$NVM_DIR/nvm.sh" 2>/dev/null || true
    hash -r 2>/dev/null || true
    ok "Node.js $(node --version 2>/dev/null) vía NVM"
  else
    warn "nvm install 22 falló (mira las líneas anteriores para la causa)"
  fi
fi

# ── PM2 ─────────────────────────────────────────────────────────────────────
if $WANT_PM2; then
  step "PM2"
  if ! command -v pm2 &>/dev/null; then
    info "Instalando PM2..."
    if npm_global_install pm2; then
      ok "PM2 $(_bin_version pm2)"
    else
      warn "Instalación de PM2 falló — revisa el log."
    fi
  else
    ok "PM2 ya instalado: $(_bin_version pm2)"
  fi
  if command -v pm2 &>/dev/null; then
    pm2 startup systemd -u "$CURRENT_USER" --hp "$HOME" 2>/dev/null \
      | grep -E "^sudo" | bash 2>/dev/null || true
    echo -e "  ${DIM}Usa: pm2 save  para persistir procesos${RST}"
  fi
fi

# ── Docker ──────────────────────────────────────────────────────────────────
if $WANT_DOCKER; then
  step "Docker"
  if ! command -v docker &>/dev/null; then
    info "Instalando Docker engine..."
    if curl -fsSL https://get.docker.com | sh; then
      ok "Docker $(docker --version 2>/dev/null | awk '{print $3}' | tr -d ',')"
    else
      warn "Docker install.sh falló"
    fi
  else
    ok "Docker ya instalado: $(docker --version 2>/dev/null | awk '{print $3}' | tr -d ',')"
  fi
  if command -v docker &>/dev/null; then
    if ! groups "$CURRENT_USER" 2>/dev/null | grep -qw docker; then
      sudo usermod -aG docker "$CURRENT_USER" && \
        warn "Añadido al grupo docker — cierra sesión para aplicar (o usa 'newgrp docker' en esta sesión)"
    fi
  fi
fi

# ── Samba ───────────────────────────────────────────────────────────────────
if $WANT_SAMBA; then
  step "Samba"
  if ! command -v smbd &>/dev/null; then
    info "Instalando Samba..."
    sudo apt-get install -y --no-install-recommends samba || { warn "Samba apt falló"; }
  fi
  if command -v smbd &>/dev/null && ! grep -q "\[laia-arch\]" /etc/samba/smb.conf 2>/dev/null; then
    sudo tee -a /etc/samba/smb.conf >/dev/null <<SMBEOF

[laia-arch]
   comment = LAIA Home
   path = ${HOME}
   valid users = ${CURRENT_USER}
   read only = no
   browseable = yes
SMBEOF
    sudo systemctl restart smbd 2>/dev/null || true
    ok "Samba configurado — acceso: smb://$(hostname -I | awk '{print $1}')/"
    warn "Establece contraseña Samba: sudo smbpasswd -a ${CURRENT_USER}"
  fi
fi

# ── UFW Firewall ────────────────────────────────────────────────────────────
if $WANT_UFW; then
  step "UFW Firewall"
  if ! command -v ufw &>/dev/null; then
    info "Instalando UFW..."
    sudo apt-get install -y --no-install-recommends ufw || warn "UFW apt falló"
  fi
  if command -v ufw &>/dev/null; then
    sudo ufw allow 22/tcp   comment 'SSH'   2>/dev/null || true
    sudo ufw allow 80/tcp   comment 'HTTP'  2>/dev/null || true
    sudo ufw allow 443/tcp  comment 'HTTPS' 2>/dev/null || true
    sudo ufw allow 8077/tcp comment 'Workspace UI' 2>/dev/null || true
    sudo ufw --force enable
    ok "UFW activo"
    sudo ufw status numbered
  fi
fi

# ── Git config global ───────────────────────────────────────────────────────
if $WANT_GITCFG; then
  step "Git config global"
  _git_name=$(git config --global user.name 2>/dev/null || echo "")
  _git_email=$(git config --global user.email 2>/dev/null || echo "")
  if [[ -z "$_git_name" ]]; then
    ask "Git user.name:" ""
    [[ -n "$REPLY" ]] && git config --global user.name "$REPLY"
  else
    ok "git user.name = ${_git_name}"
  fi
  if [[ -z "$_git_email" ]]; then
    ask "Git user.email:" ""
    [[ -n "$REPLY" ]] && git config --global user.email "$REPLY"
  else
    ok "git user.email = ${_git_email}"
  fi
  git config --global pull.rebase false
  git config --global init.defaultBranch main
  ok "Git configurado"
fi

# ══════════════════════════════════════════════════════════════════════════════
# laia-ui — nueva UI (monorepo pnpm + turbo)
# ══════════════════════════════════════════════════════════════════════════════
if $WANT_LAIA_UI; then
  step "laia-ui — nueva UI (pnpm monorepo)"

  LAIA_UI_DIR="$LAIA_DIR/laia-ui"

  # Clonar o actualizar
  if [[ -d "$LAIA_UI_DIR/.git" ]]; then
    info "$LAIA_UI_DIR existe — actualizando..."
    if git -C "$LAIA_UI_DIR" pull -q; then
      ok "laia-ui actualizado ($(git -C "$LAIA_UI_DIR" rev-parse --short HEAD 2>/dev/null))"
    else
      warn "git pull falló en laia-ui"
    fi
  else
    info "Clonando laia-ui desde $REPO_LAIA_UI..."
    if git clone "$REPO_LAIA_UI" "$LAIA_UI_DIR" -q; then
      ok "laia-ui clonado"
    else
      warn "git clone laia-ui falló — verifica autenticación (repo privado)"
    fi
  fi

  # Instalar pnpm si no está
  if [[ -d "$LAIA_UI_DIR/.git" ]]; then
    if ! command -v pnpm &>/dev/null; then
      info "Instalando pnpm..."
      if command -v corepack &>/dev/null; then
        # Forma oficial recomendada: corepack viene con Node 16.10+
        corepack enable 2>/dev/null || true
        corepack prepare pnpm@latest --activate 2>/dev/null && ok "pnpm $(pnpm --version)" || \
          warn "corepack prepare pnpm falló — intentando npm..."
      fi
      if ! command -v pnpm &>/dev/null; then
        if npm_global_install pnpm; then
          ok "pnpm $(pnpm --version 2>/dev/null || echo '?')"
        else
          warn "pnpm install falló — instala manualmente: npm install -g pnpm"
        fi
      fi
    else
      ok "pnpm $(pnpm --version) ya instalado"
    fi

    if command -v pnpm &>/dev/null; then
      info "Instalando dependencias del monorepo (esto tarda)..."
      # COREPACK_ENABLE_DOWNLOAD_PROMPT=0: el package.json del monorepo declara
      # `packageManager: pnpm@X.Y.Z` y corepack pide [Y/n] interactivo para
      # bajar esa versión exacta — bloquea el wizard. Con la env auto-acepta.
      # Sin --silent: el usuario ve el progreso paquete a paquete.
      if (cd "$LAIA_UI_DIR" && COREPACK_ENABLE_DOWNLOAD_PROMPT=0 pnpm install --reporter=append-only); then
        ok "Deps del monorepo instaladas"
      else
        warn "pnpm install falló — revisa con: cd $LAIA_UI_DIR && pnpm install"
      fi

      info "Compilando (turbo run build)..."
      if (cd "$LAIA_UI_DIR" && COREPACK_ENABLE_DOWNLOAD_PROMPT=0 pnpm run build); then
        ok "laia-ui compilado"
      else
        warn "build falló — revisa con: cd $LAIA_UI_DIR && pnpm run build"
      fi
    fi

    # Symlink visible en LAIA/ para mantener la convención
    ln -sfn "laia-ui" "$LAIA_DIR/.laia-ui-link" 2>/dev/null || true
  fi
fi

# ══════════════════════════════════════════════════════════════════════════════
# Resumen
# ══════════════════════════════════════════════════════════════════════════════
echo ""
echo -e "${YEL}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RST}"
echo -e "${GRN}${BLD}  ✓ LAIA instalado correctamente${RST}"
echo -e "${YEL}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RST}"
echo ""
echo -e "  ${BLD}Estructura:${RST}"
echo -e "  ${DIM}  ${LAIA_DIR}/              — Datos + runtime${RST}"
echo -e "  ${DIM}  ${CODE_DIR}/   — Código (Hermes + Workspace UI)${RST}"
echo -e "  ${DIM}  ${RUNTIME_DIR}/          — Runtime de Hermes${RST}"
echo -e "  ${DIM}  ${BIN_DIR}/              — Scripts del sistema${RST}"
echo ""

if [[ "$OS" == "linux" && "$OPT_SERVICES" == true ]]; then
  echo -e "  ${BLD}Servicios:${RST}"
  for svc in hermes workspace-ui; do
    if systemctl is-active --quiet "$svc" 2>/dev/null; then
      echo -e "  ${GRN}  ✓ $svc — activo${RST}"
    else
      echo -e "  ${YEL}  ⚠ $svc — inactivo${RST}"
    fi
  done
  echo ""
fi

if [[ -f "$LAIA_DIR/auth.json" || -f "$RUNTIME_DIR/auth.json" ]]; then
  echo -e "  ${GRN}✓ auth.json presente${RST}"
else
  echo -e "  ${YEL}⚠  auth.json no encontrado${RST}"
  echo -e "  ${DIM}  Restaura: clone-laia --restore usuario@host${RST}"
fi

echo ""
echo -e "  ${BLD}Próximos pasos:${RST}"
echo -e "  ${DIM}  source ~/.bashrc  — activar HERMES_HOME y PATH${RST}"
[[ -z "$OPT_RESTORE" && "$OPT_BACKUP_LOCAL" == false ]] && \
  echo -e "  ${DIM}  clone-laia --restore usuario@host  — migrar datos desde otro servidor${RST}"
echo -e "  ${DIM}  clone-laia  — re-ejecuta el wizard para instalar lo que falte${RST}"
[[ "$OS" == "linux" && "$OPT_SERVICES" == true ]] && \
  echo -e "  ${DIM}  journalctl -u hermes -f  — logs en tiempo real${RST}"
echo -e "  ${DIM}  laia-stop --disable  — apagar agente para moverlo a otra máquina${RST}"
echo -e "  ${DIM}  Log: ${LOG_FILE}${RST}"
echo ""

trap - EXIT
exit 0
